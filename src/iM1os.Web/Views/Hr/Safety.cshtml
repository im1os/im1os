@model HrWorkspacePage

@{
    ViewData["Title"] = "OSHA / Safety";
    var admin = Model.Administration;
    var timeClock = admin.TimeClock;
}

@await Html.PartialAsync("_HrHeader", Model)

<section class="im1-workspace-grid">
    <article class="im1-workspace-card span-5">
        <header class="im1-section-header"><div><h2>Log Incident</h2><p>Record safety incidents and OSHA status.</p></div></header>
        <div class="connector-readiness">
            <div><span>Incidents</span><strong>@timeClock.SafetySummary.IncidentCount</strong></div>
            <div><span>Recordable</span><strong>@timeClock.SafetySummary.OshaRecordableCount</strong></div>
            <div><span>Reported</span><strong>@timeClock.SafetySummary.ReportedToOshaCount</strong></div>
            <div><span>Lost Time</span><strong>@timeClock.SafetySummary.LostTimeHours.ToString("0.00") hrs</strong></div>
        </div>
        <form asp-controller="Hr" asp-action="AddSafetyIncident" method="post" class="form-grid">
            <input type="hidden" name="organizationId" value="@admin.OrganizationId" />
            <label>
                Employee
                <select name="EmployeeId">
                    <option value="">Company-wide</option>
                    @foreach (var employee in timeClock.Employees)
                    {
                        <option value="@employee.Id">@employee.Name</option>
                    }
                </select>
            </label>
            <label>Date <input name="IncidentDate" type="date" required /></label>
            <label>Type <input name="IncidentType" required /></label>
            <label>Severity <input name="Severity" /></label>
            <label>Lost Time Hours <input name="LostTimeHours" type="number" step="0.25" min="0" value="0" /></label>
            <label class="checkbox"><input name="IsOshaRecordable" type="checkbox" value="true" /> OSHA Recordable</label><input name="IsOshaRecordable" type="hidden" value="false" />
            <label class="checkbox"><input name="ReportedToOsha" type="checkbox" value="true" /> Reported to OSHA</label><input name="ReportedToOsha" type="hidden" value="false" />
            <label class="im1-full-span">Description <input name="Description" /></label>
            <button class="primary-action" type="submit">Log Incident</button>
        </form>
    </article>

    <article class="im1-workspace-card span-7">
        <header class="im1-section-header"><div><h2>Incident Log</h2><p>Safety and OSHA activity.</p></div></header>
        <div class="table-scroll">
            <table class="data-table">
                <thead><tr><th>Date</th><th>Employee</th><th>Type</th><th>Lost</th><th>Recordable</th><th>Reported</th></tr></thead>
                <tbody>
                @foreach (var incident in timeClock.SafetyIncidents)
                {
                    <tr>
                        <td>@incident.IncidentDate.ToString("MMM d, yyyy")</td>
                        <td>@incident.EmployeeName</td>
                        <td>@incident.IncidentType</td>
                        <td>@incident.LostTimeHours.ToString("0.00")</td>
                        <td>@(incident.IsOshaRecordable ? "Yes" : "No")</td>
                        <td>@(incident.ReportedToOsha ? "Yes" : "No")</td>
                    </tr>
                }
                @if (timeClock.SafetyIncidents.Count == 0)
                {
                    <tr><td colspan="6">No safety incidents.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </article>
</section>
