@model HrWorkspacePage

@{
    ViewData["Title"] = "Documents";
}

@await Html.PartialAsync("_HrHeader", Model)

<section class="im1-workspace-grid">
    <article class="im1-workspace-card span-12">
        <header class="im1-section-header"><div><h2>Employee Documents</h2><p>Open an employee record to add or review HR files.</p></div></header>
        <div class="table-scroll">
            <table class="data-table">
                <thead><tr><th>Employee</th><th>Email</th><th>Status</th><th>Action</th></tr></thead>
                <tbody>
                @foreach (var employee in Model.Employees.Employees)
                {
                    <tr>
                        <td>@employee.Name</td>
                        <td>@(employee.Email ?? "-")</td>
                        <td>@employee.Status</td>
                        <td><a class="im1-button im1-button-secondary" asp-controller="Employees" asp-action="Edit" asp-route-employeeId="@employee.Id" asp-fragment="documents">Documents</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </article>
</section>
