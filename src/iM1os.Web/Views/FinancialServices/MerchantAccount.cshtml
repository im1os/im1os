@model iM1os.Application.FinancialServices.Merchant.CompanyMerchantAccountWorkspace
@using System.Text.Json
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Merchant Account";
    var account = Model.Account;
    var app = Model.Application;
    var canEdit = app.CanEdit;
    var sandboxApplicationFixtureEnabled =
        Configuration.GetValue<bool>("NmiPayments:EnableSandboxApplicationFixture") &&
        string.Equals(Configuration["NmiPayments:Environment"], "Sandbox", StringComparison.OrdinalIgnoreCase);
    var configuredLegalConsentHelperUrl = Configuration["NmiPayments:LegalConsentHelperUrl"] ??
        "https://sandbox.signup.nmi.com/build/consent-helper-1.0.0.umd.js";
    var legalConsentHelperUrlIsAllowed =
        Uri.TryCreate(configuredLegalConsentHelperUrl, UriKind.Absolute, out var legalConsentHelperUri) &&
        legalConsentHelperUri.Scheme == Uri.UriSchemeHttps &&
        (legalConsentHelperUri.Host.Equals("sandbox.signup.nmi.com", StringComparison.OrdinalIgnoreCase) ||
         legalConsentHelperUri.Host.Equals("signup.nmi.com", StringComparison.OrdinalIgnoreCase));
    var legalConsentHelperUrl = legalConsentHelperUrlIsAllowed ? legalConsentHelperUri!.AbsoluteUri : null;
    var saveLabel = app.Status is "Submitted" or "Approved" ? "Save Changes" : "Save Draft";
    var hero = new IM1WorkspaceHeroModel(
        "Merchant Account",
        "Payments & Finance",
        "Complete the merchant application, track approval, and confirm payment readiness.",
        new[]
        {
            new IM1WorkspaceStatModel("Status", account?.Status ?? "Not Started", "Merchant account"),
            new IM1WorkspaceStatModel("Provider", account?.ProviderDisplayName ?? "Pending", "Gateway"),
            new IM1WorkspaceStatModel("Payments", Model.IsProcessingReady ? "Enabled" : "Disabled", "Processing readiness"),
            new IM1WorkspaceStatModel("Relationship", account?.ProviderRelationshipStatus ?? "Pending", "Provider state")
        },
        new[]
        {
            new IM1ActionModel("Payments & Finance", Url.Action("Index", "FinancialServices"), "secondary"),
            new IM1ActionModel("Edit Application", Url.Action("MerchantApplication", "FinancialServices") + "#merchant-application", canEdit ? "secondary" : "quiet"),
            new IM1ActionModel("Test Payment", Url.Action("Index", "Payments"), "primary")
        },
        Model.IsProcessingReady ? "Active" : "Setup needed");
}

@await Html.PartialAsync("IM1WorkspaceHero", hero)

@if (TempData["MerchantStatus"] is string status)
{
    <div class="im1-alert im1-alert-success">@status</div>
}
@if (TempData["MerchantError"] is string error)
{
    <div class="im1-alert im1-alert-error">@error</div>
}

<section class="im1-workspace-grid">
    <article class="im1-workspace-card span-4">
        <header class="im1-section-header">
            <div>
                <h2>Status</h2>
                <p>Company-facing payment account state.</p>
            </div>
        </header>
        <div class="im1-key-value-list">
            <div><dt>Merchant status</dt><dd>@(account?.Status ?? "Not Started")</dd></div>
            <div><dt>Provider</dt><dd>@(account?.ProviderDisplayName ?? "Pending")</dd></div>
            <div><dt>Merchant ID</dt><dd>@(account?.HasProviderMerchant == true ? "Configured" : "Pending")</dd></div>
            <div><dt>Gateway status</dt><dd>@(account?.ProviderRelationshipStatus ?? "Pending")</dd></div>
            <div><dt>Environment</dt><dd>Sandbox</dd></div>
            <div><dt>Payments enabled</dt><dd>@(account?.PaymentsEnabled == true ? "Yes" : "No")</dd></div>
        </div>
    </article>

    <article class="im1-workspace-card span-8">
        <header class="im1-section-header">
            <div>
                <h2>Next Steps</h2>
                <p>What must happen before payments can run.</p>
            </div>
        </header>
        @if (Model.RequiredNextSteps.Count == 0)
        {
            <p class="im1-empty-state">Merchant account is active and ready for test payments.</p>
        }
        else
        {
            <ul class="event-list">
                @foreach (var step in Model.RequiredNextSteps)
                {
                    <li>@step</li>
                }
            </ul>
        }
    </article>
</section>

@if (Model.LegalConsent.IsRequired)
{
    <section class="im1-workspace-grid">
        <article class="im1-workspace-card span-12">
            <header class="im1-section-header">
                <div>
                    <h2>NMI Legal Consent</h2>
                    <p>An authorized company signer must complete this consent before iM1 can submit the application to NMI.</p>
                </div>
            </header>
            @if (!string.IsNullOrWhiteSpace(Model.LegalConsent.LegalConsentUrl) && legalConsentHelperUrl is not null)
            {
                <div id="nmi-legal-consent-widget"
                     style="width:100%;min-height:680px;border:1px solid var(--im1-border-color);border-radius:12px;overflow:hidden"></div>
                <p id="nmi-legal-consent-status" class="im1-form-help" role="status">
                    Complete every required signature in the NMI consent form. Submission unlocks only after NMI confirms acceptance.
                </p>
                <form id="nmi-legal-consent-form" method="post" asp-controller="FinancialServices" asp-action="CompleteNmiLegalConsent">
                    @Html.AntiForgeryToken()
                    <p class="im1-form-help">iM1 records only the completion time. Signatures and consent documents remain with NMI.</p>
                    <button id="nmi-legal-consent-submit"
                            class="im1-button im1-button-primary"
                            type="submit"
                            disabled
                            aria-disabled="true">Submit application to NMI</button>
                </form>
                <script src="@legalConsentHelperUrl"></script>
                <script>
                    (() => {
                        const consentUrl = @Html.Raw(JsonSerializer.Serialize(Model.LegalConsent.LegalConsentUrl));
                        const form = document.getElementById("nmi-legal-consent-form");
                        const submitButton = document.getElementById("nmi-legal-consent-submit");
                        const status = document.getElementById("nmi-legal-consent-status");

                        const showLoadError = () => {
                            submitButton.disabled = true;
                            submitButton.setAttribute("aria-disabled", "true");
                            status.textContent = "NMI legal consent could not be loaded. Refresh the page or contact iM1 support.";
                        };

                        form.addEventListener("submit", event => {
                            if (submitButton.disabled) {
                                event.preventDefault();
                            }
                        });

                        if (!window.LegalConsent || typeof window.LegalConsent.load !== "function") {
                            showLoadError();
                            return;
                        }

                        try {
                            window.LegalConsent.load(
                                consentUrl,
                                { selector: "#nmi-legal-consent-widget", overlay: "transparent" },
                                {
                                    onAccepted: result => {
                                        const accepted = result?.accepted === true;
                                        submitButton.disabled = !accepted;
                                        submitButton.setAttribute("aria-disabled", accepted ? "false" : "true");
                                        status.textContent = accepted
                                            ? "NMI confirmed legal consent. You may now submit the application."
                                            : "Complete every required signature before submitting the application.";
                                    },
                                    onError: showLoadError
                                });
                        } catch {
                            showLoadError();
                        }
                    })();
                </script>
            }
            else
            {
                <div class="im1-alert im1-alert-error">The NMI consent link is unavailable. Contact iM1 support.</div>
            }
        </article>
    </section>
}

<section class="im1-workspace-grid">
    <article id="merchant-application" class="im1-workspace-card span-12">
        <header class="im1-section-header">
            <div>
                <h2>Merchant Application</h2>
                <p>@(canEdit ? "Edit the application details and save before approval or activation." : "Application details are locked for this status.")</p>
            </div>
            @if (sandboxApplicationFixtureEnabled && canEdit)
            {
                <form method="post" asp-controller="FinancialServices" asp-action="FillMerchantApplicationSandboxData">
                    @Html.AntiForgeryToken()
                    <button class="im1-button im1-button-secondary" type="submit">Fill NMI Sandbox Test Data</button>
                </form>
            }
        </header>
        <form class="im1-form-grid" method="post">
            @Html.AntiForgeryToken()
            <label>
                Business Name
                <input name="BusinessName" value="@app.BusinessName" maxlength="200" required @(canEdit ? null : "readonly") />
            </label>
            <label>
                DBA
                <input name="Dba" value="@app.Dba" maxlength="200" @(canEdit ? null : "readonly") />
            </label>
            <label>
                EIN
                <input name="Ein" value="" placeholder="@(app.Ein ?? "Enter EIN")" maxlength="20" autocomplete="off" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Tax ID
                <input name="TaxId" value="" placeholder="@(app.TaxId ?? "Enter tax ID")" maxlength="20" autocomplete="off" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Business Description
                <input name="BusinessDescription" value="@app.BusinessDescription" maxlength="500" placeholder="Goods and services sold" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Years in Business
                <input name="YearsInBusiness" type="number" min="0" value="@app.YearsInBusiness" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Business Type
                <input name="BusinessType" value="@app.BusinessType" maxlength="120" placeholder="LLC, corporation, sole proprietor" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Website
                <input name="Website" value="@app.Website" maxlength="300" @(canEdit ? null : "readonly") />
            </label>
            <label>
                MCC
                <input name="Mcc" value="@app.Mcc" maxlength="10" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Expected Monthly Volume
                <input name="ExpectedMonthlyVolume" type="number" min="0" step="0.01" value="@app.ExpectedMonthlyVolume" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Average Ticket
                <input name="AverageTicket" type="number" min="0" step="0.01" value="@app.AverageTicket" @(canEdit ? null : "readonly") />
            </label>
            <label>
                High Ticket
                <input name="HighTicket" type="number" min="0" step="0.01" value="@app.HighTicket" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Card Present %
                <input name="CardPresentPercentage" type="number" min="0" max="100" step="0.01" value="@app.CardPresentPercentage" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Key Entered %
                <input name="KeyEnteredPercentage" type="number" min="0" max="100" step="0.01" value="@app.KeyEnteredPercentage" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Ecommerce %
                <input name="EcommercePercentage" type="number" min="0" max="100" step="0.01" value="@app.EcommercePercentage" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Mail/Phone Order %
                <input name="MotoPercentage" type="number" min="0" max="100" step="0.01" value="@app.MotoPercentage" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Physical Address
                <input name="PhysicalAddressLine1" value="@app.PhysicalAddressLine1" maxlength="200" required @(canEdit ? null : "readonly") />
            </label>
            <label>
                Address 2
                <input name="PhysicalAddressLine2" value="@app.PhysicalAddressLine2" maxlength="200" @(canEdit ? null : "readonly") />
            </label>
            <label>
                City
                <input name="PhysicalCity" value="@app.PhysicalCity" maxlength="120" required @(canEdit ? null : "readonly") />
            </label>
            <label>
                State
                <input name="PhysicalRegion" value="@app.PhysicalRegion" maxlength="80" required @(canEdit ? null : "readonly") />
            </label>
            <label>
                ZIP
                <input name="PhysicalPostalCode" value="@app.PhysicalPostalCode" maxlength="20" required @(canEdit ? null : "readonly") />
            </label>
            <input type="hidden" name="PhysicalCountry" value="US" />
            <label>
                Mailing Address
                <input name="MailingAddressLine1" value="@app.MailingAddressLine1" maxlength="200" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Mailing City
                <input name="MailingCity" value="@app.MailingCity" maxlength="120" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Mailing State
                <input name="MailingRegion" value="@app.MailingRegion" maxlength="80" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Mailing ZIP
                <input name="MailingPostalCode" value="@app.MailingPostalCode" maxlength="20" @(canEdit ? null : "readonly") />
            </label>
            <input type="hidden" name="MailingCountry" value="US" />
            <label>
                Owner Name
                <input name="OwnerName" value="@app.OwnerName" maxlength="200" required @(canEdit ? null : "readonly") />
            </label>
            <label>
                Owner Email
                <input name="OwnerEmail" type="email" value="@app.OwnerEmail" maxlength="320" required @(canEdit ? null : "readonly") />
            </label>
            <label>
                Owner Phone
                <input name="OwnerPhone" value="@app.OwnerPhone" maxlength="40" required @(canEdit ? null : "readonly") />
            </label>
            <label>
                Owner Title
                <input name="OwnerTitle" value="@app.OwnerTitle" maxlength="120" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Ownership %
                <input name="OwnerOwnershipPercentage" type="number" min="0.01" max="100" step="0.01" value="@app.OwnerOwnershipPercentage" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Owner Date of Birth
                <input name="OwnerDateOfBirth" type="date" value="" placeholder="@app.OwnerDateOfBirthMasked" autocomplete="off" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Owner SSN
                <input name="OwnerSsn" type="password" value="" placeholder="@(app.OwnerSsnLastFour ?? "Enter SSN")" maxlength="20" autocomplete="new-password" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Bank Name
                <input name="BankName" value="@app.BankName" maxlength="160" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Routing Number
                <input name="BankRoutingNumber" value="" placeholder="@(app.BankRoutingLastFour ?? "Enter routing number")" maxlength="20" autocomplete="off" @(canEdit ? null : "readonly") />
            </label>
            <label>
                Account Number
                <input name="BankAccountNumber" type="password" value="" placeholder="@(app.BankAccountLastFour ?? "Enter account number")" maxlength="30" autocomplete="new-password" @(canEdit ? null : "readonly") />
            </label>
            @if (canEdit)
            {
                <div class="span-2">
                    <button class="im1-button im1-button-secondary" formaction="@Url.Action("SaveMerchantApplication", "FinancialServices")" type="submit">@saveLabel</button>
                    @if (app.CanSubmit)
                    {
                        <button class="im1-button im1-button-primary" formaction="@Url.Action("SubmitMerchantApplication", "FinancialServices")" type="submit">Submit Application</button>
                    }
                </div>
            }
        </form>
    </article>
</section>

<section class="im1-workspace-grid">
    <article class="im1-workspace-card span-12">
        <header class="im1-section-header">
            <div>
                <h2>Payment History</h2>
                <p>Use Test Payment to process a sandbox transaction and view it in transaction history.</p>
            </div>
        </header>
        <a class="im1-button im1-button-primary" href="@Url.Action("Index", "Payments")">Open Test Payment</a>
    </article>
</section>
