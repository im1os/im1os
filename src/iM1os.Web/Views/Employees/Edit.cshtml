@model iM1os.Application.Employees.EmployeesWorkspace

@{
    var employee = Model.SelectedEmployee ?? throw new InvalidOperationException("Employee is required.");
    var login = employee.LoginAccount;
    ViewData["Title"] = $"Edit {employee.DisplayName}";
    var activeCompensation = employee.Compensation.OrderByDescending(x => x.EffectiveStartDate).FirstOrDefault();
    var jobFlags = new[]
    {
        employee.IsTechnician ? "Technician" : null,
        employee.IsServiceAdvisor ? "Service Advisor" : null,
        employee.IsSales ? "Sales" : null,
        employee.IsParts ? "Parts" : null,
        employee.IsAccounting ? "Accounting" : null,
        employee.IsInventory ? "Inventory" : null,
        employee.IsManager ? "Manager" : null
    }.Where(x => !string.IsNullOrWhiteSpace(x)).ToArray();
    var hero = new IM1WorkspaceHeroModel(
        employee.DisplayName,
        "Employee workspace",
        $"{employee.EmploymentType} employee. {(string.IsNullOrWhiteSpace(employee.JobTitle) ? "No job title set." : employee.JobTitle)}",
        new[]
        {
            new IM1WorkspaceStatModel("Status", employee.Status, "Employment state"),
            new IM1WorkspaceStatModel("Login", login?.Status ?? "No Login", login is null ? "Employee record only" : login.CompanyRole),
            new IM1WorkspaceStatModel("Payroll", activeCompensation?.PayrollType ?? "Not Set", activeCompensation is null ? "No active compensation" : $"Effective {activeCompensation.EffectiveStartDate:yyyy-MM-dd}"),
            new IM1WorkspaceStatModel("Job Functions", jobFlags.Length == 0 ? "None" : jobFlags.Length.ToString(), jobFlags.Length == 0 ? "No dropdown eligibility" : string.Join(", ", jobFlags)),
            new IM1WorkspaceStatModel("Documents", employee.Documents.Count.ToString(), "HR files"),
            new IM1WorkspaceStatModel("Activity", employee.Activity.Count.ToString(), "Recent events")
        },
        new[]
        {
            new IM1ActionModel("Edit Details", "#general", "primary"),
            new IM1ActionModel("Add Compensation", "#compensation", "secondary"),
            new IM1ActionModel("Documents", "#documents", "secondary")
        },
        employee.Status);
    var page = new IM1PageModel(
        employee.DisplayName,
        "HR / Employees",
        "Manage employee information, employment details, optional login account, permissions, security, and activity.",
        Breadcrumbs: new[]
        {
            new IM1BreadcrumbModel("Company", Url.Action("Dashboard", "Business")),
            new IM1BreadcrumbModel("Employees", Url.Action("Index", "Employees")),
            new IM1BreadcrumbModel(employee.DisplayName)
        },
        Toolbar: new IM1ToolbarModel(
            Actions: new[] { new IM1ActionModel("Back to Employees", Url.Action("Index", "Employees"), "secondary") }));
    var editorTabs = new IM1TabsModel(
        "Employee editor sections",
        new[]
        {
            new IM1TabItemModel("overview", "Overview", true),
            new IM1TabItemModel("general", "Edit Details"),
            new IM1TabItemModel("employment", "Employment"),
            new IM1TabItemModel("compensation", "Compensation"),
            new IM1TabItemModel("login-account", "Login Account"),
            new IM1TabItemModel("permissions", "Permissions"),
            new IM1TabItemModel("security", "Security"),
            new IM1TabItemModel("documents", "Documents"),
            new IM1TabItemModel("activity", "Activity")
        });
}

@await Html.PartialAsync("IM1Page", page)
@await Html.PartialAsync("IM1WorkspaceHero", hero)

@if (TempData["EmployeeError"] is string errorMessage)
{
    <div class="form-alert error">@errorMessage</div>
}

<section class="im1-page">
    @await Html.PartialAsync("IM1Tabs", editorTabs)

    <section class="tab-panel is-active" id="overview" role="tabpanel">
            <section class="im1-workspace-grid">
                <article class="im1-workspace-card span-4">
                    <header class="im1-section-header"><div><h2>Employee</h2><p>Primary employee information.</p></div></header>
                    <dl class="im1-key-value-list">
                        <div><dt>Email</dt><dd>@(employee.Email ?? "-")</dd></div>
                        <div><dt>Phone</dt><dd>@(employee.Phone ?? "-")</dd></div>
                        <div><dt>Department</dt><dd>@(employee.Department ?? "-")</dd></div>
                        <div><dt>Employee #</dt><dd>@(employee.EmployeeNumber ?? "Not assigned")</dd></div>
                    </dl>
                </article>
                <article class="im1-workspace-card span-4">
                    <header class="im1-section-header"><div><h2>Employment</h2><p>Work status and eligibility.</p></div></header>
                    <dl class="im1-key-value-list">
                        <div><dt>Type</dt><dd>@employee.EmploymentType</dd></div>
                        <div><dt>Hire Date</dt><dd>@(employee.HireDate?.ToString("yyyy-MM-dd") ?? "-")</dd></div>
                        <div><dt>Termination</dt><dd>@(employee.TerminationDate?.ToString("yyyy-MM-dd") ?? "-")</dd></div>
                        <div><dt>Functions</dt><dd>@(jobFlags.Length == 0 ? "None" : string.Join(", ", jobFlags))</dd></div>
                    </dl>
                </article>
                <article class="im1-workspace-card span-4">
                    <header class="im1-section-header"><div><h2>Login Account</h2><p>Authentication is optional.</p></div></header>
                    @if (login is null)
                    {
                        <p class="im1-empty-state">This employee does not have a login account.</p>
                    }
                    else
                    {
                        <dl class="im1-key-value-list">
                            <div><dt>Username</dt><dd>@login.Username</dd></div>
                            <div><dt>Role</dt><dd>@login.CompanyRole</dd></div>
                            <div><dt>Status</dt><dd>@login.Status</dd></div>
                            <div><dt>PIN</dt><dd>@(login.HasPin ? "Set" : "Not Set")</dd></div>
                        </dl>
                    }
                </article>
                <article class="im1-workspace-card span-6">
                    <header class="im1-section-header"><div><h2>Compensation</h2><p>Current payroll and commission context.</p></div><a class="im1-button im1-button-secondary" href="#compensation">Manage</a></header>
                    @if (activeCompensation is null)
                    {
                        <p class="im1-empty-state">No compensation records found.</p>
                    }
                    else
                    {
                        <dl class="im1-key-value-list">
                            <div><dt>Payroll Type</dt><dd>@activeCompensation.PayrollType</dd></div>
                            <div><dt>Hourly</dt><dd>@(activeCompensation.HourlyRate?.ToString("C") ?? "-")</dd></div>
                            <div><dt>Salary</dt><dd>@(activeCompensation.SalaryAmount?.ToString("C") ?? "-")</dd></div>
                            <div><dt>Commissions</dt><dd>WO @(activeCompensation.WorkOrderCommissionRate?.ToString("P2") ?? "-") / Sales @(activeCompensation.SalesCommissionRate?.ToString("P2") ?? "-")</dd></div>
                        </dl>
                    }
                </article>
                <article class="im1-workspace-card span-6">
                    <header class="im1-section-header"><div><h2>Recent Activity</h2><p>Employee and login timeline.</p></div></header>
                    <ol class="company-activity-list">
                        @foreach (var item in employee.Activity.Take(5))
                        {
                            <li><strong>@item.EventType</strong><span>@item.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm")</span><p>@item.Summary</p></li>
                        }
                        @if (employee.Activity.Count == 0)
                        {
                            <li>No activity found.</li>
                        }
                    </ol>
                </article>
            </section>
    </section>

    <form asp-action="Update" method="post" class="im1-form">
        <input type="hidden" name="EmployeeId" value="@employee.Id" />
        <section class="tab-panel" id="general" role="tabpanel" hidden>
            <div class="im1-form-grid">
                <label>First Name <input name="FirstName" value="@employee.FirstName" /></label>
                <label>Last Name <input name="LastName" value="@employee.LastName" /></label>
                <label>Display Name <input name="DisplayName" value="@employee.DisplayName" /></label>
                <label>Email <input name="Email" value="@employee.Email" type="email" /></label>
                <label>Phone <input name="Phone" value="@employee.Phone" /></label>
                <label>Employee Number <input name="EmployeeNumber" value="@employee.EmployeeNumber" /></label>
            </div>
        </section>

        <section class="tab-panel" id="employment" role="tabpanel" hidden>
            <div class="im1-form-grid">
                <label>Job Title <input name="JobTitle" value="@employee.JobTitle" /></label>
                <label>Department <input name="Department" value="@employee.Department" /></label>
                <label>Employment Type
                    <select name="EmploymentType">
                        @foreach (var type in new[] { "Full Time", "Part Time", "Employee", "Contractor", "Seasonal", "Temporary" })
                        {
                            <option value="@type" selected="@(type == employee.EmploymentType)">@type</option>
                        }
                    </select>
                </label>
                <label>Status
                    <select name="Status">
                        @foreach (var status in new[] { "Active", "Inactive", "On Leave", "Terminated" })
                        {
                            <option value="@status" selected="@(status == employee.Status)">@status</option>
                        }
                    </select>
                </label>
                <label>Hire Date <input name="HireDate" type="date" value="@employee.HireDate?.ToString("yyyy-MM-dd")" /></label>
                <label>Termination Date <input name="TerminationDate" type="date" value="@employee.TerminationDate?.ToString("yyyy-MM-dd")" /></label>
                <div class="im1-checkbox-group">
                    <span class="im1-checkbox-group-title">Dropdown Eligibility</span>
                    <div class="im1-checkbox-options">
                        <label class="im1-checkbox"><input name="IsTechnician" type="checkbox" value="true" checked="@employee.IsTechnician" /> Technician</label><input name="IsTechnician" type="hidden" value="false" />
                        <label class="im1-checkbox"><input name="IsServiceAdvisor" type="checkbox" value="true" checked="@employee.IsServiceAdvisor" /> Service Advisor</label><input name="IsServiceAdvisor" type="hidden" value="false" />
                        <label class="im1-checkbox"><input name="IsSales" type="checkbox" value="true" checked="@employee.IsSales" /> Sales</label><input name="IsSales" type="hidden" value="false" />
                        <label class="im1-checkbox"><input name="IsParts" type="checkbox" value="true" checked="@employee.IsParts" /> Parts</label><input name="IsParts" type="hidden" value="false" />
                        <label class="im1-checkbox"><input name="IsAccounting" type="checkbox" value="true" checked="@employee.IsAccounting" /> Accounting</label><input name="IsAccounting" type="hidden" value="false" />
                        <label class="im1-checkbox"><input name="IsInventory" type="checkbox" value="true" checked="@employee.IsInventory" /> Inventory</label><input name="IsInventory" type="hidden" value="false" />
                        <label class="im1-checkbox"><input name="IsManager" type="checkbox" value="true" checked="@employee.IsManager" /> Manager</label><input name="IsManager" type="hidden" value="false" />
                    </div>
                </div>
                @if (login is not null)
                {
                    <label>Company Role
                        <select name="RoleName">
                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role.Name" selected="@(role.Name == login.CompanyRole)">@role.Name</option>
                            }
                        </select>
                    </label>
                }
            </div>
        </section>

        <div class="im1-form-actions">
            <button class="im1-button im1-button-primary" type="submit">Save Employee</button>
        </div>
    </form>

    <section class="tab-panel" id="compensation" role="tabpanel" hidden>
        <form asp-action="Compensation" method="post" class="im1-form" data-compensation-form>
            <input type="hidden" name="EmployeeId" value="@employee.Id" />
            <div class="im1-form-grid">
                <label>Payroll Type
                    <select name="PayrollType" data-payroll-type>
                        <option>Hourly</option>
                        <option>Salary</option>
                        <option>Commission Only</option>
                    </select>
                </label>
                <label data-payroll-field="Hourly">Hourly Rate <input name="HourlyRate" type="number" min="0" step="0.01" /></label>
                <label data-payroll-field="Salary" hidden>Salary Amount <input name="SalaryAmount" type="number" min="0" step="0.01" /></label>
                <label>Work Order Commission % <input name="WorkOrderCommissionRate" type="number" min="0" max="100" step="0.01" /></label>
                <label>Sales Commission % <input name="SalesCommissionRate" type="number" min="0" max="100" step="0.01" /></label>
                <label>Effective Start <input name="EffectiveStartDate" type="date" required /></label>
                <label>Effective End <input name="EffectiveEndDate" type="date" /></label>
                <label>Notes <input name="Notes" /></label>
            </div>
            <div class="im1-form-actions">
                <button class="im1-button im1-button-primary" type="submit">Add Compensation</button>
            </div>
        </form>

        <div class="im1-data-grid">
            <table>
                <thead>
                    <tr>
                        <th>Payroll Type</th>
                        <th>Hourly</th>
                        <th>Salary</th>
                        <th>Work Order Commission</th>
                        <th>Sales Commission</th>
                        <th>Effective Dates</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (employee.Compensation.Count == 0)
                    {
                        <tr><td colspan="7">No compensation records found.</td></tr>
                    }
                    else
                    {
                        @foreach (var compensation in employee.Compensation)
                        {
                            <tr>
                                <td>@compensation.PayrollType</td>
                                <td>@(compensation.HourlyRate?.ToString("C") ?? "")</td>
                                <td>@(compensation.SalaryAmount?.ToString("C") ?? "")</td>
                                <td>@(compensation.WorkOrderCommissionRate?.ToString("P2") ?? "")</td>
                                <td>@(compensation.SalesCommissionRate?.ToString("P2") ?? "")</td>
                                <td>@compensation.EffectiveStartDate.ToString("yyyy-MM-dd") - @(compensation.EffectiveEndDate?.ToString("yyyy-MM-dd") ?? "Current")</td>
                                <td>
                                    <form asp-action="DeleteCompensation" method="post" onsubmit="return confirm('Delete this compensation entry?');">
                                        <input type="hidden" name="EmployeeId" value="@employee.Id" />
                                        <input type="hidden" name="CompensationId" value="@compensation.Id" />
                                        <input type="hidden" name="returnTab" value="compensation" />
                                        <button class="im1-button im1-button-danger" type="submit">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="tab-panel" id="login-account" role="tabpanel" hidden>
        @if (login is null)
        {
            <form asp-action="EnableLogin" method="post" class="im1-form">
                <input type="hidden" name="EmployeeId" value="@employee.Id" />
                <div class="im1-form-grid">
                    <label>Email <input name="Email" value="@employee.Email" type="email" autocomplete="username" /></label>
                    <label>Company Role
                        <select name="RoleName">
                            @foreach (var role in Model.Roles)
                            {
                                <option value="@role.Name">@role.Name</option>
                            }
                        </select>
                    </label>
                    <label>Initial Password <input name="InitialPassword" type="password" autocomplete="new-password" /></label>
                </div>
                <label class="im1-checkbox"><input name="SendInvitationEmail" type="checkbox" value="true" checked /> Send Invitation Email</label>
                <div class="im1-form-actions">
                    <button class="im1-button im1-button-primary" type="submit">Enable Login Account</button>
                </div>
            </form>
        }
        else
        {
            <div class="company-security-grid">
                <article><span>Username</span><strong>@login.Username</strong></article>
                <article><span>Email</span><strong>@login.Email</strong></article>
                <article><span>Company Role</span><strong>@login.CompanyRole</strong></article>
                <article><span>Login Status</span><strong>@login.Status</strong></article>
                <article><span>PIN</span><strong>@(login.HasPin ? "Set" : "Not Set")</strong></article>
            </div>
            <form asp-action="Pin" method="post" class="im1-form">
                <input type="hidden" name="EmployeeId" value="@employee.Id" />
                <div class="im1-form-grid">
                    <label>Employee PIN <input name="Pin" type="password" inputmode="numeric" minlength="4" maxlength="4" pattern="[0-9]{4}" autocomplete="off" /></label>
                </div>
                <div class="im1-form-actions">
                    <button class="im1-button im1-button-primary" type="submit">Save PIN</button>
                </div>
            </form>
        }
    </section>

    <section class="tab-panel" id="permissions" role="tabpanel" hidden>
        @if (login is null)
        {
            <p class="im1-page-status">This employee does not have a login account.</p>
        }
        else
        {
            <form asp-action="Permissions" method="post" class="im1-form">
                <input type="hidden" name="EmployeeId" value="@employee.Id" />
                <div class="company-permission-list">
                    @for (var i = 0; i < employee.Permissions.Count; i++)
                    {
                        var permission = employee.Permissions.ElementAt(i);
                        <article>
                            <input type="hidden" name="Overrides[@i].PermissionId" value="@permission.PermissionId" />
                            <strong>@permission.Key</strong>
                            <span>@permission.Description</span>
                            <em>Role: @(permission.RoleAllows ? "Allowed" : "Not allowed")</em>
                            <label class="im1-checkbox"><input name="Overrides[@i].IsOverridden" type="checkbox" value="true" checked="@(permission.OverrideAllows is not null)" /> Override</label>
                            <select name="Overrides[@i].IsAllowed">
                                <option value="true" selected="@(permission.OverrideAllows == true)">Allow</option>
                                <option value="false" selected="@(permission.OverrideAllows == false)">Deny</option>
                            </select>
                        </article>
                    }
                </div>
                <div class="im1-form-actions">
                    <button class="im1-button im1-button-primary" type="submit">Save Permissions</button>
                </div>
            </form>
        }
    </section>

    <section class="tab-panel" id="security" role="tabpanel" hidden>
        @if (login is null)
        {
            <p class="im1-page-status">Security is available after login is enabled.</p>
        }
        else
        {
            <div class="company-security-grid">
                <article><span>Password</span><strong>********</strong></article>
                <article><span>Last Password Change</span><strong>@(login.Security.LastPasswordChangedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</strong></article>
                <article><span>Last Login</span><strong>@(login.Security.LastLoginAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</strong></article>
                <article><span>Failed Login Attempts</span><strong>@login.Security.FailedLoginAttempts</strong></article>
                <article><span>MFA Status</span><strong>@(login.Security.MfaEnabled ? "Enabled" : "Disabled")</strong></article>
                <article><span>Account Locked</span><strong>@(login.Security.AccountLocked ? "Yes" : "No")</strong></article>
                <article><span>Active Sessions</span><strong>@login.Security.ActiveSessions</strong></article>
                <article><span>Must Change Password</span><strong>@(login.Security.MustChangePassword ? "Yes" : "No")</strong></article>
            </div>
            <div class="action-row company-security-actions">
                <form asp-action="Security" method="post">
                    <input type="hidden" name="EmployeeId" value="@employee.Id" />
                    <input type="hidden" name="Action" value="ResetPassword" />
                    <input name="NewPassword" type="password" autocomplete="new-password" placeholder="New password" />
                    <button class="im1-button im1-button-secondary" type="submit">Reset Password</button>
                </form>
                @foreach (var action in new[] { ("SendPasswordResetEmail", "Send Password Reset Email"), ("UnlockAccount", "Unlock Account"), ("ForcePasswordChange", "Force Password Change"), ("SignOutAllSessions", "Sign Out All Sessions"), (login.Status == "Active" ? "DisableLogin" : "EnableLogin", login.Status == "Active" ? "Disable Login" : "Enable Login") })
                {
                    <form asp-action="Security" method="post">
                        <input type="hidden" name="EmployeeId" value="@employee.Id" />
                        <input type="hidden" name="Action" value="@action.Item1" />
                        <button class="im1-button im1-button-secondary" type="submit">@action.Item2</button>
                    </form>
                }
            </div>
        }
    </section>

    <section class="tab-panel" id="documents" role="tabpanel" hidden>
        @await Html.PartialAsync("IM1DocumentDropzone", new IM1DocumentDropzoneModel(
            Url.Action("AddDocument", "Employees") ?? "/Employees/AddDocument",
            "EmployeeId",
            employee.Id,
            "documents",
            "Add Employee Document",
            "Drop HR, payroll, certification, safety, and employee documents here.",
            "Add Document",
            new[] { "General", "HR", "Payroll", "Certification", "Safety", "Agreement", "Photo", "Video" }))

        <div class="im1-data-grid">
            <table>
                <thead><tr><th>Type</th><th>File</th><th>Uploaded</th><th>Link</th></tr></thead>
                <tbody>
                    @foreach (var document in employee.Documents)
                    {
                        <tr>
                            <td>@document.DocumentType</td>
                            <td>@document.FileName</td>
                            <td>@document.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>@if (!string.IsNullOrWhiteSpace(document.Url)) { <a href="@document.Url" target="_blank" rel="noopener">Open</a> }</td>
                        </tr>
                    }
                    @if (employee.Documents.Count == 0)
                    {
                        <tr><td colspan="4">No documents found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="tab-panel" id="activity" role="tabpanel" hidden>
        <ol class="company-activity-list">
            @foreach (var item in employee.Activity)
            {
                <li>
                    <strong>@item.EventType</strong>
                    <span>@item.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm")</span>
                    <p>@item.Summary</p>
                </li>
            }
        </ol>
    </section>
</section>
