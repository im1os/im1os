@model iM1os.Application.Employees.EmployeesWorkspace

@{
    ViewData["Title"] = "New Employee";
    var page = new IM1PageModel(
        "New Employee",
        "HR / Employees",
        "Create an employee record. Login access is optional.",
        Breadcrumbs: new[]
        {
            new IM1BreadcrumbModel("Company", Url.Action("Dashboard", "Business")),
            new IM1BreadcrumbModel("Employees", Url.Action("Index", "Employees")),
            new IM1BreadcrumbModel("New Employee")
        },
        Toolbar: new IM1ToolbarModel(Actions: new[] { new IM1ActionModel("Back to Employees", Url.Action("Index", "Employees"), "secondary") }));
}

@await Html.PartialAsync("IM1Page", page)

<section class="im1-page">
    <form asp-action="Create" method="post" class="im1-form">
        <div class="im1-form-grid">
            <label>Name <input name="Name" /></label>
            <label>Email <input name="Email" type="email" autocomplete="username" /></label>
            <label>Phone <input name="Phone" /></label>
            <label>Job Title <input name="JobTitle" /></label>
            <label>Department <input name="Department" /></label>
            <label>Employment Type
                <select name="EmploymentType">
                    <option>Full Time</option>
                    <option>Part Time</option>
                    <option>Employee</option>
                    <option>Contractor</option>
                    <option>Seasonal</option>
                    <option>Temporary</option>
                </select>
            </label>
            <label>Status
                <select name="Status">
                    <option>Active</option>
                    <option>Inactive</option>
                    <option>On Leave</option>
                    <option>Terminated</option>
                </select>
            </label>
            <label class="im1-checkbox"><input name="EnableLoginAccount" type="checkbox" value="true" /> Enable Login Account</label><input name="EnableLoginAccount" type="hidden" value="false" />
            <label>Company Role
                <select name="RoleName">
                    <option value="">No login role</option>
                    @foreach (var role in Model.Roles)
                    {
                        <option value="@role.Name">@role.Name</option>
                    }
                </select>
            </label>
            <label>Initial Password <input name="InitialPassword" type="password" autocomplete="new-password" /></label>
            <label class="im1-checkbox"><input name="SendInvitationEmail" type="checkbox" value="true" checked /> Send Invitation Email</label><input name="SendInvitationEmail" type="hidden" value="false" />
        </div>
        <div class="im1-form-actions">
            <button class="im1-button im1-button-primary" type="submit">Create Employee</button>
        </div>
    </form>
</section>
