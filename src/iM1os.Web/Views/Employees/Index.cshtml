@model iM1os.Application.Employees.EmployeesWorkspace

@{
    ViewData["Title"] = "Employees";
    var grid = new IM1DataGridModel(
        Columns: new[]
        {
            new IM1DataGridColumnModel("name", "Name"),
            new IM1DataGridColumnModel("email", "Email"),
            new IM1DataGridColumnModel("jobTitle", "Job Title"),
            new IM1DataGridColumnModel("status", "Status"),
            new IM1DataGridColumnModel("login", "Login"),
            new IM1DataGridColumnModel("role", "Company Role"),
            new IM1DataGridColumnModel("lastLogin", "Last Login"),
            new IM1DataGridColumnModel("created", "Created Date"),
            new IM1DataGridColumnModel("actions", "Actions", false, false)
        },
        Rows: Model.Employees.Select(employee => new Dictionary<string, object?>
        {
            ["__url"] = Url.Action("Edit", "Employees", new { employeeId = employee.Id }),
            ["name"] = employee.Name,
            ["email"] = employee.Email ?? "",
            ["jobTitle"] = employee.JobTitle ?? "",
            ["status"] = employee.Status,
            ["login"] = employee.LoginStatus,
            ["role"] = employee.CompanyRole,
            ["lastLogin"] = employee.LastLoginAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "Never",
            ["created"] = employee.CreatedAtUtc.ToString("yyyy-MM-dd"),
            ["actions"] = new Microsoft.AspNetCore.Html.HtmlString($"<a class=\"im1-button im1-button-secondary\" href=\"{Url.Action("Edit", "Employees", new { employeeId = employee.Id })}\">Edit</a>")
        }).ToArray(),
        Toolbar: new IM1ToolbarModel(
            Actions: new[] { new IM1ActionModel("New Employee", Url.Action("New", "Employees"), "primary") },
            SearchPlaceholder: "Search employees",
            ShowRefresh: true,
            ShowExport: true),
        EmptyText: "No employees found.",
        PageSize: 10);
    var page = new IM1PageModel(
        "Employees",
        "Administration",
        "Manage employee records, employment details, optional login accounts, permissions, security, and activity.",
        Breadcrumbs: new[]
        {
            new IM1BreadcrumbModel("Company", Url.Action("Dashboard", "Business")),
            new IM1BreadcrumbModel("Administration", Url.Action("Administration", "Business")),
            new IM1BreadcrumbModel("Employees")
        });
}

@await Html.PartialAsync("IM1Page", page)

<form class="im1-toolbar" method="get" asp-controller="Employees" asp-action="Index">
    <select name="status">
        <option value="">All statuses</option>
        @foreach (var status in new[] { "Active", "Inactive", "On Leave", "Terminated" })
        {
            <option value="@status" selected="@(Model.Status == status)">@status</option>
        }
    </select>
    <select name="role">
        <option value="">All login roles</option>
        @foreach (var role in Model.Roles)
        {
            <option value="@role.Name" selected="@(Model.Role == role.Name)">@role.Name</option>
        }
    </select>
    <button class="im1-button im1-button-secondary" type="submit">Apply Filters</button>
</form>

@await Html.PartialAsync("IM1DataGrid", grid)
