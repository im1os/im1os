@model iM1os.Application.Employees.EmployeesWorkspace

@{
    ViewData["Title"] = "Employees";
    var showNewEmployee = Context.Request.Query["newEmployee"] == "true";
    var grid = new IM1DataGridModel(
        Columns: new[]
        {
            new IM1DataGridColumnModel("avatar", "Avatar", false, false),
            new IM1DataGridColumnModel("name", "Name"),
            new IM1DataGridColumnModel("email", "Email"),
            new IM1DataGridColumnModel("jobTitle", "Job Title"),
            new IM1DataGridColumnModel("status", "Status"),
            new IM1DataGridColumnModel("login", "Login"),
            new IM1DataGridColumnModel("role", "Company Role"),
            new IM1DataGridColumnModel("lastLogin", "Last Login"),
            new IM1DataGridColumnModel("created", "Created Date"),
            new IM1DataGridColumnModel("actions", "Actions", false, false)
        },
        Rows: Model.Employees.Select(employee => new Dictionary<string, object?>
        {
            ["avatar"] = employee.Avatar,
            ["name"] = employee.Name,
            ["email"] = employee.Email ?? "",
            ["jobTitle"] = employee.JobTitle ?? "",
            ["status"] = employee.Status,
            ["login"] = employee.LoginStatus,
            ["role"] = employee.CompanyRole,
            ["lastLogin"] = employee.LastLoginAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "Never",
            ["created"] = employee.CreatedAtUtc.ToString("yyyy-MM-dd"),
            ["actions"] = new Microsoft.AspNetCore.Html.HtmlString($"<a class=\"im1-button im1-button-secondary\" href=\"{Url.Action("Edit", "Employees", new { employeeId = employee.Id })}\">Edit</a>")
        }).ToArray(),
        Toolbar: new IM1ToolbarModel(
            Actions: new[] { new IM1ActionModel("New Employee", Url.Action("Index", "Employees", new { newEmployee = true }), "primary") },
            SearchPlaceholder: "Search employees",
            ShowRefresh: true,
            ShowExport: true),
        EmptyText: "No employees found.",
        PageSize: 10);
    var page = new IM1PageModel(
        "Employees",
        "Administration",
        "Manage employee records, employment details, optional login accounts, permissions, security, and activity.",
        Breadcrumbs: new[]
        {
            new IM1BreadcrumbModel("Company", Url.Action("Dashboard", "Business")),
            new IM1BreadcrumbModel("Administration", Url.Action("Administration", "Business")),
            new IM1BreadcrumbModel("Employees")
        });
}

@await Html.PartialAsync("IM1Page", page)

<form class="im1-toolbar" method="get" asp-controller="Employees" asp-action="Index">
    <select name="status">
        <option value="">All statuses</option>
        @foreach (var status in new[] { "Active", "Inactive", "On Leave", "Terminated" })
        {
            <option value="@status" selected="@(Model.Status == status)">@status</option>
        }
    </select>
    <select name="role">
        <option value="">All login roles</option>
        @foreach (var role in Model.Roles)
        {
            <option value="@role.Name" selected="@(Model.Role == role.Name)">@role.Name</option>
        }
    </select>
    <button class="im1-button im1-button-secondary" type="submit">Apply Filters</button>
</form>

@await Html.PartialAsync("IM1DataGrid", grid)

@if (showNewEmployee)
{
    <div class="im1-side-panel-backdrop is-open" data-side-panel="new-employee">
        <aside class="im1-side-panel" aria-labelledby="new-employee-title">
            <header class="im1-side-panel-header">
                <div>
                    <h2 id="new-employee-title">New Employee</h2>
                    <p>Create the employee record first. Login access is optional.</p>
                </div>
                <a class="im1-dialog-close" asp-controller="Employees" asp-action="Index" aria-label="Close">X</a>
            </header>
            <div class="im1-side-panel-body">
                <form asp-action="Create" method="post" class="im1-form">
                    <div class="im1-form-grid">
                        <label>Name <input name="Name" /></label>
                        <label>Email <input name="Email" type="email" autocomplete="username" /></label>
                        <label>Phone <input name="Phone" /></label>
                        <label>Job Title <input name="JobTitle" /></label>
                        <label>Department <input name="Department" /></label>
                        <label>Employment Type
                            <select name="EmploymentType">
                                <option>Full Time</option>
                                <option>Part Time</option>
                                <option>Employee</option>
                                <option>Contractor</option>
                                <option>Seasonal</option>
                                <option>Temporary</option>
                            </select>
                        </label>
                        <label>Status
                            <select name="Status">
                                <option>Active</option>
                                <option>Inactive</option>
                                <option>On Leave</option>
                                <option>Terminated</option>
                            </select>
                        </label>
                    </div>
                    <label class="im1-checkbox"><input name="EnableLoginAccount" type="checkbox" value="true" /> Enable Login Account</label>
                    <div class="im1-form-grid">
                        <label>Company Role
                            <select name="RoleName">
                                <option value="">No login role</option>
                                @foreach (var role in Model.Roles)
                                {
                                    <option value="@role.Name">@role.Name</option>
                                }
                            </select>
                        </label>
                        <label>Initial Password <input name="InitialPassword" type="password" autocomplete="new-password" /></label>
                    </div>
                    <label class="im1-checkbox"><input name="SendInvitationEmail" type="checkbox" value="true" checked /> Send Invitation Email</label>
                    <div class="im1-form-actions">
                        <button class="im1-button im1-button-primary" type="submit">Create Employee</button>
                    </div>
                </form>
            </div>
        </aside>
    </div>
}
