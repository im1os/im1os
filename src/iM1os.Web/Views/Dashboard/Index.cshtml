@{
    ViewData["Title"] = "Dashboard";
    var hero = new IM1WorkspaceHeroModel(
        "iM1 OS Platform",
        "Foundation workspace",
        "Foundation shell for authentication, company context, configuration, audit, background processing, and future modules.",
        new[]
        {
            new IM1WorkspaceStatModel("Identity", "Ready", "Authentication and roles"),
            new IM1WorkspaceStatModel("Company Context", "Ready", "Tenant boundaries"),
            new IM1WorkspaceStatModel("Operations", "Ready", "Health and audit"),
            new IM1WorkspaceStatModel("Extensibility", "Ready", "Feature flags and settings")
        },
        new[] { new IM1ActionModel("Health", "/health", "primary") },
        "Healthy");
}

@await Html.PartialAsync("IM1WorkspaceHero", hero)

<section class="im1-workspace-card">
    <header class="im1-section-header"><div><h2>Foundation Scope</h2><p>The platform foundation is ready for module workspaces.</p></div></header>
    <p class="im1-empty-state">Business modules should now be designed as workspaces following the iM1 Experience Standard.</p>
</section>
