                    any.value = "";
                    any.textContent = "All";
                    select.append(any);
                    values.forEach(value => {
                        const option = document.createElement("option");
                        option.value = value;
                        option.textContent = value;
                        select.append(option);
                    });
                    select.value = values.includes(selected) ? selected : "";
                };
                const createFilter = label => {
                    const field = document.createElement("label");
                    const text = document.createElement("span");
                    const select = document.createElement("select");
                    text.textContent = label;
                    select.dataset.fitmentFilter = label.toLowerCase();
                    field.append(text, select);
                    return field;
                };
                const yearFilter = createFilter("Year");
                const makeFilter = createFilter("Make");
                const modelFilter = createFilter("Model");
                const count = document.createElement("span");
                count.className = "im1-fitment-filter-count";
                controls.append(yearFilter, makeFilter, modelFilter, count);
                const yearSelect = yearFilter.querySelector("select");
                const makeSelect = makeFilter.querySelector("select");
                const modelSelect = modelFilter.querySelector("select");
                fitmentRows.forEach((fitment) => {
                    const row = document.createElement("tr");
                    row.dataset.year = fitment.year === null || fitment.year === undefined ? "" : String(fitment.year);
                    row.dataset.make = fitment.make || "";
                    row.dataset.model = fitment.model || "";
                    [
                        fitment.year,
                        fitment.make,
                        fitment.model
                    ].forEach((value) => {
                        const cell = document.createElement("td");
                        cell.textContent = valueOrDash(value);
                        row.append(cell);
                    });
                    tbody.append(row);
                });
                const refreshDependentOptions = () => {
                    const selectedYear = yearSelect.value;
                    const yearRows = selectedYear
                        ? fitmentRows.filter(fitment => String(fitment.year ?? "") === selectedYear)
                        : fitmentRows;
                    setSelectOptions(makeSelect, uniqueOptions(yearRows, fitment => fitment.make));
                    const makeRows = makeSelect.value
                        ? yearRows.filter(fitment => (fitment.make || "") === makeSelect.value)
                        : yearRows;
                    setSelectOptions(modelSelect, uniqueOptions(makeRows, fitment => fitment.model));
                };
                const applyFilter = () => {
                    const selectedYear = yearSelect.value;
                    const selectedMake = makeSelect.value;
                    const selectedModel = modelSelect.value;
                    let visibleCount = 0;
                    [...tbody.rows].forEach(row => {
                        const visible = (!selectedYear || row.dataset.year === selectedYear) &&
                            (!selectedMake || row.dataset.make === selectedMake) &&
                            (!selectedModel || row.dataset.model === selectedModel);
                        row.hidden = !visible;
                        if (visible) visibleCount++;
                    });
                    count.textContent = `${visibleCount.toLocaleString()} shown`;
                };
                setSelectOptions(yearSelect, uniqueOptions(fitmentRows, fitment => fitment.year).sort((a, b) => Number(b) - Number(a)));
                refreshDependentOptions();
                yearSelect.addEventListener("change", () => {
                    makeSelect.value = "";
                    modelSelect.value = "";
                    refreshDependentOptions();
                    applyFilter();
                });
                makeSelect.addEventListener("change", () => {
                    modelSelect.value = "";
                    refreshDependentOptions();
                    applyFilter();
                });
                modelSelect.addEventListener("change", applyFilter);
                applyFilter();
                table.append(thead, tbody);
                wrapper.append(table);
                details.append(summary, controls, wrapper);
                return details;
            };
            const createInventoryPanel = (item) => {
                if ((!item.inventoryUrl && !item.inventoryBatchUrl) || !item.inventoryLabel) return null;
                const section = document.createElement("section");
                section.className = "im1-live-inventory";
                if (item.supplierCode) section.dataset.supplierCode = item.supplierCode;
                if (item.supplierProductId) section.dataset.supplierProductId = item.supplierProductId;
                if (item.inventoryUrl) section.dataset.inventoryUrl = item.inventoryUrl;
                if (item.inventoryBatchUrl) {
                    section.dataset.inventoryBatchUrl = item.inventoryBatchUrl;
                    section.dataset.supplierProductId = item.supplierProductId;
                }
                const header = document.createElement("header");
                const title = document.createElement("strong");
                const status = document.createElement("span");
                title.textContent = inventoryPanelTitle(item);
                status.textContent = "Loading live inventory...";
                header.append(title, status);
                const grid = document.createElement("div");
                grid.className = "im1-live-inventory-grid";
                section.append(header, grid);
                return section;
            };
            const createInventorySummary = (offers) => {
                if (!offers.length) return null;
                const summary = document.createElement("div");
                summary.className = "im1-inventory-summary im1-inventory-summary-primary";
                summary.setAttribute("aria-label", "Inventory");
                offers.forEach((offer) => {
                    const value = document.createElement("span");
                    value.dataset.inventorySummaryCode = offer.supplierCode || "";
                    if (offer.supplierProductId) value.dataset.supplierProductId = offer.supplierProductId;
                    if (offer.inventoryUrl) value.dataset.inventorySummaryUrl = offer.inventoryUrl;
                    if (offer.inventoryBatchUrl) {
                        value.dataset.inventorySummaryBatchUrl = offer.inventoryBatchUrl;
                        value.dataset.supplierProductId = offer.supplierProductId;
                    }
                    value.textContent = `${offer.supplierCode}: ${formatInventoryTotal(offer)}`;
                    summary.append(value);
                });
                return summary;
            };
            const routeFromTemplate = (template, supplierProductId) => {
                if (!template || !supplierProductId) return null;
                return template.replace("SUPPLIER_PRODUCT_ID", encodeURIComponent(supplierProductId));
            };
            const withCatalogRoutes = (item) => {
                const resultList = document.querySelector("[data-item-results]");
                if (!resultList || !item) return item;
                const routeOffer = (offer) => {
                    if (!offer) return offer;
                    const code = (offer.supplierCode || "").toUpperCase();
                    return {
                        ...offer,
                        inventoryUrl: offer.inventoryUrl || (code === "WPS"
                            ? routeFromTemplate(resultList.dataset.wpsInventoryTemplate, offer.supplierProductId)
                            : code === "TURN14"
                                ? routeFromTemplate(resultList.dataset.turn14InventoryTemplate, offer.supplierProductId)
                                : null),
                        inventoryBatchUrl: offer.inventoryBatchUrl || (code === "PU" ? resultList.dataset.puInventoryUrl : null),
                        inventoryLabel: offer.inventoryLabel || (code === "WPS"
                            ? "WPS Warehouse Inventory"
                            : code === "TURN14"
                                ? "Turn14 Warehouse Inventory"
                                : code === "PU"
                                    ? "Parts Unlimited Warehouse Inventory"
                                    : null),
                        fetchFitmentUrl: offer.fetchFitmentUrl || routeFromTemplate(resultList.dataset.fitmentTemplate, offer.supplierProductId)
                    };
                };
                const offers = (item.offers || []).map(routeOffer);
                const primary = routeOffer(item);
                return {
                    ...primary,
                    offers,
                    fetchFitmentUrl: item.fetchFitmentUrl || routeFromTemplate(resultList.dataset.fitmentTemplate, item.supplierProductId)
                };
            };
            const imagePopout = document.querySelector("[data-image-popout]");
            const openImagePopout = (imageUrl, title) => {
                if (!imagePopout || !imageUrl) return;
                const image = imagePopout.querySelector("[data-image-popout-img]");
                const titleElement = imagePopout.querySelector("[data-image-popout-title]");
                image.src = imageUrl;
                titleElement.textContent = title || "Product image";
                imagePopout.showModal();
            };
            document.querySelector("[data-close-image-popout]")?.addEventListener("click", () => imagePopout?.close());
            imagePopout?.addEventListener("click", event => {
                if (event.target === imagePopout) {
                    imagePopout.close();
                }
            });
            const createSupplierOffers = (item) => {
                const offers = item.offers || [];
                if (offers.length === 0) return null;
                const isPlatformCatalog = document.querySelector("[data-item-results]")?.dataset.platformCatalog === "true";
                const details = document.createElement("details");
                details.className = "im1-supplier-offers";
                const summary = document.createElement("summary");
                summary.textContent = `Supplier Inventory (${offers.length.toLocaleString()})`;
                const grid = document.createElement("div");
                grid.className = "im1-supplier-offer-grid";
                offers.forEach((offer) => {
                    const row = document.createElement("article");
                    row.className = `im1-supplier-offer${offer.isDefaultOffer ? " im1-supplier-offer-selected" : ""}`;
                    row.dataset.offerRow = "";
                    row.dataset.offerSupplierProductId = offer.supplierProductId || "";
                    row.dataset.offerCost = String(offer.actualCost ?? offer.dealerCost ?? Number.MAX_VALUE);
                    row.dataset.hasInventory = offer.hasCachedInventory ? "true" : "false";
                    row.dataset.isPreferredSupplier = offer.isPreferredSupplier ? "true" : "false";
                    row.dataset.preferredWarehouseCode = offer.preferredWarehouseCode || "";
                    const media = document.createElement("div");
                    media.className = "im1-supplier-offer-media";
                    if (offer.imageUrl) {
                        const button = document.createElement("button");
                        button.type = "button";
                        button.className = "im1-supplier-offer-image-button";
                        button.setAttribute("aria-label", "Open supplier product image");
                        const img = document.createElement("img");
                        img.src = offer.imageUrl;
                        img.alt = "";
                        img.loading = "lazy";
                        img.referrerPolicy = "no-referrer";
                        button.append(img);
                        button.addEventListener("click", () => openImagePopout(offer.imageUrl, offer.title || offer.supplierSku || "Supplier product image"));
                        media.append(button);
                    } else {
                        const mediaIcon = createSupplierIcon(offer.supplierCode, offer.supplierName);
                        if (mediaIcon) {
                            media.append(mediaIcon);
                        } else {
                            media.textContent = offer.supplierCode || "";
                        }
                    }
                    const header = document.createElement("header");
                    const supplier = document.createElement("strong");
                    const icon = createSupplierIcon(offer.supplierCode, offer.supplierName);
                    if (icon) supplier.append(icon);
                    supplier.append(document.createTextNode(offer.supplierName || offer.supplierCode || "-"));
                    header.append(supplier);
                    const metrics = document.createElement("dl");
                    const metricRows = [
                        createMetric("SKU", createCopyableValue(offer.supplierSku, "SKU")),
                        createMetric("MFG Part#", createCopyableValue(offer.manufacturerPartNumber, "MFG Part#")),
                        createMetric("Retail", formatCurrency(offer.msrp))
                    ];
                    if (!isPlatformCatalog) {
                        metricRows.push(createMetric("Actual", formatCurrency(offer.actualCost)));
                    }
                    metrics.append(...metricRows);
                    row.append(media, header, metrics);
                    const inventory = createInventoryPanel(offer);
                    if (inventory) row.append(inventory);
                    grid.append(row);
                });
                details.append(summary, grid);
                return details;
            };
            const createItemResult = (item) => {
                item = withCatalogRoutes(item);
                const article = document.createElement("article");
                article.className = "im1-workorder-item-result im1-catalog-item-result";
                article.dataset.itemResult = "";

                const media = document.createElement("div");
                media.className = "im1-workorder-item-media";
                const image = document.createElement("div");
                image.className = "im1-workorder-item-image";
                if (item.imageUrl) {
                    const button = document.createElement("button");
                    button.type = "button";
                    button.className = "im1-workorder-item-image-button";
                    button.setAttribute("aria-label", "Open product image");
                    const img = document.createElement("img");
                    img.src = item.imageUrl;
                    img.alt = "";
                    img.loading = "lazy";
                    img.referrerPolicy = "no-referrer";
                    button.append(img);
                    button.addEventListener("click", () => openImagePopout(item.imageUrl, item.title || item.supplierSku || "Product image"));
                    image.append(button);
                } else {
                    const placeholder = document.createElement("span");
                    placeholder.textContent = "No Image";
                    image.append(placeholder);
                }
                media.append(image);

                const body = document.createElement("div");
                body.className = "im1-workorder-item-result-body";
                const title = document.createElement("strong");
                title.className = "im1-workorder-item-title";
                title.textContent = item.title || "-";
                const meta = document.createElement("span");
                meta.className = "im1-workorder-item-meta";
                renderSupplierMeta(meta, item);

                const metrics = document.createElement("dl");
                const offers = item.offers || [];
                const offerFor = supplierCode => offers.find(candidate => (candidate.supplierCode || "").toUpperCase() === supplierCode);
                const isPlatformCatalog = document.querySelector("[data-item-results]")?.dataset.platformCatalog === "true";
                const metricRows = isPlatformCatalog
                    ? [
                        { label: "Retail", value: formatCurrency(item.msrp) },
                        { label: "Status", value: valueOrDash(item.status) },
                        { label: "Category", value: valueOrDash(item.category) }
                    ]
                    : [
                        { label: "Retail", value: formatCurrency(item.msrp) },
                        { label: "WPS Actual", supplierCode: "WPS" },
                        { label: "Turn14 Actual", supplierCode: "TURN14" },
                        { label: "Parts Unlimited Actual", supplierCode: "PU" }
                    ];
                metricRows.forEach(metric => {
                    const offer = metric.supplierCode ? offerFor(metric.supplierCode) : null;
                    const wrapper = document.createElement("div");
                    const term = document.createElement("dt");
                    const detail = document.createElement("dd");
                    term.textContent = metric.label;
                    if (offer) {
                        wrapper.className = "im1-supplier-actual-tile";
                        wrapper.dataset.actualSupplierProductId = offer.supplierProductId || "";
                        wrapper.dataset.preferredWarehouseCode = offer.preferredWarehouseCode || "";
                        if ((offer.supplierCode || "").toUpperCase() === (item.supplierCode || "").toUpperCase()) {
                            wrapper.classList.add("im1-supplier-actual-tile-selected");
                        }
                        const price = document.createElement("span");
                        price.textContent = formatCurrency(offer.actualCost);
                        const stock = document.createElement("span");
                        stock.className = "im1-top-actual-stock";
                        stock.dataset.actualStock = "";
                        detail.append(price, stock);
                    } else {
                        detail.textContent = metric.value || "-";
                    }
                    wrapper.append(term, detail);
                    metrics.append(wrapper);
                });
                body.append(title, meta, metrics);
                const supplierOffers = createSupplierOffers(item);
                if (supplierOffers) body.append(supplierOffers);
                const productDetailPopout = createProductDetailPopout(item);
                if (productDetailPopout) body.append(productDetailPopout);
                const fitmentPopout = createFitmentPopout(item);
                if (fitmentPopout) body.append(fitmentPopout);
                const inventorySummary = createInventorySummary(offers);
                if (inventorySummary) media.append(inventorySummary);
                article.append(media, body);
                selectLeastCostInStockOffer(article);
                return article;
            };
            const createLegacyItemResult = (item) => {
                const article = document.createElement("article");
                article.className = "im1-item-result";
                article.dataset.itemResult = "";

                const media = document.createElement("div");
                media.className = "im1-item-result-media";
                const image = document.createElement("div");
                image.className = "im1-item-result-image";
                if (item.imageUrl) {
                    const img = document.createElement("img");
                    img.src = item.imageUrl;
                    img.alt = "";
                    img.loading = "lazy";
                    img.referrerPolicy = "no-referrer";
                    image.append(img);
                } else {
                    const placeholder = document.createElement("span");
                    placeholder.textContent = "No Image";
                    image.append(placeholder);
                }
                media.append(image);

                const body = document.createElement("div");
                body.className = "im1-item-result-body";
                const heading = document.createElement("div");
                heading.className = "im1-item-result-title";
                const title = document.createElement("strong");
                const brand = document.createElement("span");
                title.textContent = item.title || "-";
                brand.textContent = item.brand || "";
                heading.append(title, brand);

                const metrics = document.createElement("dl");
                metrics.append(
                    createMetric("Supplier", item.supplierCode),
                    createMetric("SKU", item.supplierSku),
                    createMetric("MFG Part#", valueOrDash(item.manufacturerPartNumber)),
                    createMetric("UPC", valueOrDash(item.upc)),
                    createMetric("Status", valueOrDash(item.status)),
                    createMetric("Fitment", createFitmentValue(item)),
                    createMetric("MSRP", formatCurrency(item.msrp)),
                    createMetric("Actual Cost", formatCurrency(item.actualCost)),
                    createMetric("Category", valueOrDash(item.category)));
                const offers = item.offers || [];
                const inventorySummary = createInventorySummary(offers);
                if (inventorySummary) media.append(inventorySummary);
                body.append(heading, metrics);
                const fitmentPopout = createFitmentPopout(item);
                if (fitmentPopout) body.append(fitmentPopout);
                const supplierOffers = createSupplierOffers(item);
                if (supplierOffers) body.append(supplierOffers);
                article.append(media, body);
                return article;
            };
            const resultList = document.querySelector("[data-item-results]");
            const scrollStatus = document.querySelector("[data-scroll-status]");
            const initialResultsScript = document.getElementById("initial-supplier-item-results");
            if (resultList && initialResultsScript?.textContent?.trim()) {
                try {
                    const initialResults = JSON.parse(initialResultsScript.textContent);
                    if (Array.isArray(initialResults)) {
                        const fragment = document.createDocumentFragment();
                        initialResults.forEach((item) => fragment.append(createItemResult(item)));
                        resultList.replaceChildren(fragment);
                    }
                } catch {
                }
            }
            let loadingResults = false;
            const loadMoreResults = async () => {
                if (!resultList || loadingResults || resultList.dataset.hasMore !== "true") return;
                loadingResults = true;
                if (scrollStatus) scrollStatus.textContent = "Loading more items...";
                const params = new URLSearchParams(window.location.search);
                params.set("offset", resultList.dataset.nextOffset || "0");
                try {
                    const response = await fetch(`${resultList.dataset.resultsUrl}?${params.toString()}`, {
                        credentials: "same-origin",
                        headers: { "Accept": "application/json" }
                    });
                    if (!response.ok) {
                        if (scrollStatus) scrollStatus.textContent = `Could not load more items (${response.status}).`;
                        return;
                    }

                    const page = await response.json();
                    const items = page.results || [];
                    const fragment = document.createDocumentFragment();
                    items.forEach((item) => fragment.append(createItemResult(item)));
                    resultList.append(fragment);
                    wireFitmentButtons(resultList);
                    wireSupplierOfferDetails(resultList);
                    resultList.dataset.nextOffset = page.nextOffset?.toString() || resultList.dataset.nextOffset;
                    resultList.dataset.hasMore = page.hasMore ? "true" : "false";
                    if (scrollStatus) scrollStatus.textContent = page.hasMore ? "Load more items" : "All loaded items are shown.";
                    await loadInventoryPanels(resultList);
                } catch {
                    if (scrollStatus) scrollStatus.textContent = "Could not load more items.";
                } finally {
                    loadingResults = false;
                }
            };
            if (scrollStatus && resultList?.dataset.hasMore === "true" && "IntersectionObserver" in window) {
                const observer = new IntersectionObserver((entries) => {
                    if (entries.some((entry) => entry.isIntersecting)) {
                        loadMoreResults();
                    }
                }, { rootMargin: "600px" });
                observer.observe(scrollStatus);
            }
            scrollStatus?.addEventListener("click", loadMoreResults);
            wireFitmentButtons();
            wireSupplierOfferDetails();
            loadInventoryPanels();
        })();
    </script>
}
