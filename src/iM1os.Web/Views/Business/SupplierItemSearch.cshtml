@model iM1os.Application.GlobalCatalog.SupplierItemSearchPage

@{
    ViewData["Title"] = "Company Item Search";
    var organizationId = ViewBag.OrganizationId as Guid?;
    var routeOrganizationId = User.FindFirst("platform_user_id") is null ? null : organizationId;
    var enabledSupplierCodes = ViewBag.CompanySupplierConnectorCodes as IReadOnlySet<string> ?? new HashSet<string>(StringComparer.OrdinalIgnoreCase);
    var supplierActions = new List<IM1ActionModel>();
    if (enabledSupplierCodes.Contains("WPS"))
    {
        supplierActions.Add(new IM1ActionModel("WPS", Url.Action("SupplierWpsConnector", "Business", new { organizationId = routeOrganizationId }), "secondary"));
    }

    if (enabledSupplierCodes.Contains("PU"))
    {
        supplierActions.Add(new IM1ActionModel("Parts Unlimited", Url.Action("SupplierPartsUnlimitedConnector", "Business", new { organizationId = routeOrganizationId }), "secondary"));
    }

    if (enabledSupplierCodes.Contains("TURN14"))
    {
        supplierActions.Add(new IM1ActionModel("Turn14", Url.Action("SupplierTurn14Connector", "Business", new { organizationId = routeOrganizationId }), "secondary"));
    }

    var hero = new IM1WorkspaceHeroModel(
        "Item Search",
        "Company Suppliers / Catalog",
        "Search supplier items and compare platform dealer cost to company actual cost.",
        new[]
        {
            new IM1WorkspaceStatModel("Results", Model.IsSearchExecuted ? Model.TotalResults.ToString() : "Ready", string.IsNullOrWhiteSpace(Model.Query) ? "Use text or YMM" : Model.Query),
            new IM1WorkspaceStatModel("Pricing", "Actual Cost", "Company scoped")
        },
        supplierActions,
        "Read-only supplier item lookup");

    static string FormatCurrency(decimal? value)
    {
        if (value is null)
        {
            return "-";
        }

        var amount = value.Value;
        var prefix = amount < 0 ? "-$" : "$";
        return $"{prefix}{Math.Abs(amount).ToString("N2", System.Globalization.CultureInfo.InvariantCulture)}";
    }

    static string FormatInventoryTotal(int? value, bool hasInventory)
    {
        return value is not null
            ? value.Value.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)
            : hasInventory ? "Available" : "-";
    }

    static string? SupplierIconSrc(string? supplierCode, string? supplierName)
    {
        var value = $"{supplierCode} {supplierName}".ToLowerInvariant();
        if (value.Contains("turn14") || value.Contains("turn 14"))
        {
            return "/images/suppliers/turn14.png";
        }

        if (string.Equals(supplierCode, "PU", StringComparison.OrdinalIgnoreCase) || value.Contains("parts unlimited") || value.Contains("partsunlimited"))
        {
            return "/images/suppliers/parts-unlimited.png";
        }

        if (value.Contains("wps") || value.Contains("western power sports") || value.Contains("westernpowersports"))
        {
            return "/images/suppliers/wps.png";
        }

        return null;
    }

    var initialResultsJson = System.Text.Json.JsonSerializer.Serialize(
        Model.Results,
        new System.Text.Json.JsonSerializerOptions(System.Text.Json.JsonSerializerDefaults.Web));
    var tireWidths = new[] { 60, 70, 80, 90, 100, 110, 120, 130, 140, 150, 160, 170, 180, 190 };
    var tireRatios = new[] { 25, 30, 35, 40, 50, 55, 60, 65, 70, 80, 90, 100 };
    var tireRims = new[] { 8, 10, 11, 12, 14, 15, 16, 17, 18, 19, 21 };
    var hasActiveSearch = Model.IsSearchExecuted &&
        (!string.IsNullOrWhiteSpace(Model.Query) ||
            !string.IsNullOrWhiteSpace(Model.SupplierCode) ||
            !string.IsNullOrWhiteSpace(Model.Category) ||
            !string.IsNullOrWhiteSpace(Model.Brand) ||
            Model.TireWidth is not null ||
            Model.TireAspectRatio is not null ||
            Model.TireRimDiameter is not null ||
            !string.IsNullOrWhiteSpace(Model.VehicleType) ||
            Model.Year is not null ||
            !string.IsNullOrWhiteSpace(Model.Make) ||
            !string.IsNullOrWhiteSpace(Model.Model));
}

<nav class="im1-breadcrumbs" aria-label="Breadcrumb">
    <span>Company Suppliers</span>
    <span>Catalog</span>
    <span>Item Search</span>
</nav>

@await Html.PartialAsync("IM1WorkspaceHero", hero)

<section class="im1-settings-panel">
    <header class="im1-section-header">
        <div>
            <h2>Search Items</h2>
            <p>Find supplier catalog rows by supplier SKU, MFG part number, UPC, title, or year/make/model fitment.</p>
        </div>
    </header>
    <div class="im1-inline-action-bar im1-configured-suppliers-bar">
        <strong>Enabled suppliers</strong>
        @if (Model.ConfiguredSuppliers.Count == 0)
        {
            <span>No company suppliers enabled.</span>
        }
        else
        {
            @foreach (var supplier in Model.ConfiguredSuppliers)
            {
                <span class="im1-connector-status @(supplier.IsConfigured && supplier.IsEnabled ? "im1-connector-status-configured" : "im1-connector-status-unconfigured")">
                    <span aria-hidden="true">@(supplier.IsConfigured && supplier.IsEnabled ? Html.Raw("&#10003;") : Html.Raw("&#10005;"))</span>
                    <span>@supplier.Code</span>
                </span>
            }
        }
    </div>
    @if (hasActiveSearch)
    {
        <div class="im1-search-active-indicator">
            <span class="im1-status-pill im1-status-success">Search active</span>
            <span>@Model.TotalResults.ToString("N0") results matching the current filters</span>
        </div>
    }

    <form class="im1-item-search-layout im1-item-search-form-ymm" asp-action="SupplierItemSearch" asp-route-organizationId="@routeOrganizationId" method="get">
        <input type="hidden" name="searchExecuted" value="true" />
        @if (routeOrganizationId is not null)
        {
            <input type="hidden" name="organizationId" value="@routeOrganizationId" />
        }
        <aside class="im1-item-filter-panel" aria-label="Item filters">
            <div class="im1-item-filter-group">
                <h3>Category</h3>
                <label class="im1-field">
                    <span>Category</span>
                    <select name="category">
                        <option value="">All categories</option>
                        @if (!string.IsNullOrWhiteSpace(Model.Category) && !Model.AvailableCategories.Any(x => string.Equals(x, Model.Category, StringComparison.OrdinalIgnoreCase)))
                        {
                            <option value="@Model.Category" selected="selected">@Model.Category</option>
                        }
                        @foreach (var category in Model.AvailableCategories)
                        {
                            <option value="@category" selected="@(string.Equals(Model.Category, category, StringComparison.OrdinalIgnoreCase))">@category</option>
                        }
                    </select>
                </label>
                <label class="im1-field">
                    <span>Brand</span>
                    <select name="brand">
                        <option value="">All brands</option>
                        @if (!string.IsNullOrWhiteSpace(Model.Brand) && !Model.AvailableBrands.Any(x => string.Equals(x, Model.Brand, StringComparison.OrdinalIgnoreCase)))
                        {
                            <option value="@Model.Brand" selected="selected">@Model.Brand</option>
                        }
                        @foreach (var brand in Model.AvailableBrands)
                        {
                            <option value="@brand" selected="@(string.Equals(Model.Brand, brand, StringComparison.OrdinalIgnoreCase))">@brand</option>
                        }
                    </select>
                </label>
            </div>
            <div class="im1-item-filter-group">
                <h3>Attributes</h3>
                <label class="im1-field">
                    <span>Width</span>
                    <select name="tireWidth">
                        <option value="">Any width</option>
                        @foreach (var width in tireWidths)
                        {
                            <option value="@width" selected="@(Model.TireWidth == width)">@width</option>
                        }
                    </select>
                </label>
                <label class="im1-field">
                    <span>Ratio</span>
                    <select name="tireAspectRatio">
                        <option value="">Any ratio</option>
                        @foreach (var ratio in tireRatios)
                        {
                            <option value="@ratio" selected="@(Model.TireAspectRatio == ratio)">@ratio</option>
                        }
                    </select>
                </label>
                <label class="im1-field">
                    <span>Rim</span>
                    <select name="tireRimDiameter">
                        <option value="">Any rim</option>
                        @foreach (var rim in tireRims)
                        {
                            <option value="@rim" selected="@(Model.TireRimDiameter == rim)">@rim</option>
                        }
                    </select>
                </label>
            </div>
        </aside>
        <div class="im1-item-search-main">
            <div class="im1-item-search-form im1-item-search-main-controls">
                <label class="im1-field im1-field-wide">
                    <span>Search</span>
                    <input name="query" value="@Model.Query" placeholder="SKU, MFG Part#, title, or UPC" autocomplete="off" />
                </label>
                <label class="im1-field">
                    <span>Supplier</span>
                    <select name="supplierCode">
                        <option value="">All suppliers</option>
                        @foreach (var supplier in Model.AvailableSuppliers)
                        {
                            <option value="@supplier.Code" selected="@(string.Equals(Model.SupplierCode, supplier.Code, StringComparison.OrdinalIgnoreCase))">@supplier.Name</option>
                        }
                    </select>
                </label>
                <label class="im1-field">
                    <span>Type</span>
                    <select name="vehicleType" data-ymm-parent>
                        <option value="">Any type</option>
                        @foreach (var vehicleType in Model.AvailableVehicleTypes)
                        {
                            <option value="@vehicleType" selected="@(string.Equals(Model.VehicleType, vehicleType, StringComparison.OrdinalIgnoreCase))">@vehicleType</option>
                        }
                    </select>
                </label>
                <label class="im1-field">
                    <span>Year</span>
                    <select name="year" data-ymm-parent>
                        <option value="">Any year</option>
                        @foreach (var year in Model.AvailableYears)
                        {
                            <option value="@year" selected="@(Model.Year == year)">@year</option>
                        }
                    </select>
                </label>
                <label class="im1-field">
                    <span>Make</span>
                    <select name="make" data-ymm-parent disabled="@(Model.Year is null)">
                        <option value="">Any make</option>
                        @foreach (var make in Model.AvailableMakes)
                        {
                            <option value="@make" selected="@(string.Equals(Model.Make, make, StringComparison.OrdinalIgnoreCase))">@make</option>
                        }
                    </select>
                </label>
                <label class="im1-field">
                    <span>Model</span>
                    <select name="model" disabled="@(Model.Year is null || string.IsNullOrWhiteSpace(Model.Make))">
                        <option value="">Any model</option>
                        @foreach (var vehicleModel in Model.AvailableModels)
                        {
                            <option value="@vehicleModel" selected="@(string.Equals(Model.Model, vehicleModel, StringComparison.OrdinalIgnoreCase))">@vehicleModel</option>
                        }
                    </select>
                </label>
                <button class="im1-button im1-button-primary" type="submit">Search</button>
                <a class="im1-button im1-button-secondary" asp-action="SupplierItemSearch" asp-route-organizationId="@routeOrganizationId">Reset</a>
            </div>
        </div>
    </form>
</section>

<section class="im1-settings-panel">
    @Html.AntiForgeryToken()
    <header class="im1-section-header">
        <div>
            <h2>Items</h2>
            <p>Read-only supplier catalog matches with company actual cost.</p>
        </div>
    </header>

    @if (!Model.IsSearchExecuted)
    {
        <p class="im1-empty-state">Enter a search, choose a supplier, or select a full year/make/model fitment, then run the search.</p>
    }
    else if (Model.Results.Count == 0)
    {
        <p class="im1-empty-state">No supplier items matched this search.</p>
    }
    else
    {
        <div class="im1-item-result-list"
             data-item-results
             data-results-url="@Url.Action("SupplierItemSearchResults", new { organizationId = routeOrganizationId })"
             data-wps-inventory-template="@Url.Action("SupplierWpsInventory", new { supplierProductId = "SUPPLIER_PRODUCT_ID", organizationId = routeOrganizationId })"
             data-turn14-inventory-template="@Url.Action("SupplierTurn14Inventory", new { supplierProductId = "SUPPLIER_PRODUCT_ID", organizationId = routeOrganizationId })"
             data-pu-inventory-url="@Url.Action("SupplierPartsUnlimitedInventory", new { organizationId = routeOrganizationId })"
             data-fitment-template="@Url.Action("SupplierFetchItemFitment", new { supplierProductId = "SUPPLIER_PRODUCT_ID", organizationId = routeOrganizationId })"
             data-next-offset="@Model.TotalResults"
             data-has-more="@Model.HasMore.ToString().ToLowerInvariant()">
            @foreach (var item in Model.Results)
            {
                <article class="im1-item-result" data-item-result>
                    <div class="im1-item-result-media">
                        <div class="im1-item-result-image">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="" loading="lazy" referrerpolicy="no-referrer" />
                            }
                            else
                            {
                                <span>No Image</span>
                            }
                        </div>
                        @if ((item.Offers?.Count ?? 0) > 0)
                        {
                            <div class="im1-inventory-summary im1-inventory-summary-primary" aria-label="Inventory">
                                @foreach (var offer in item.Offers!)
                                {
                                    if (offer.SupplierCode == "WPS")
                                    {
                                        <span data-inventory-summary-code="@offer.SupplierCode" data-supplier-product-id="@offer.SupplierProductId" data-inventory-summary-url="@Url.Action("SupplierWpsInventory", new { supplierProductId = offer.SupplierProductId, organizationId = routeOrganizationId })">@offer.SupplierCode: @FormatInventoryTotal(offer.CachedInventoryTotal, offer.HasCachedInventory)</span>
                                    }
                                    else if (offer.SupplierCode == "TURN14")
                                    {
                                        <span data-inventory-summary-code="@offer.SupplierCode" data-supplier-product-id="@offer.SupplierProductId" data-inventory-summary-url="@Url.Action("SupplierTurn14Inventory", new { supplierProductId = offer.SupplierProductId, organizationId = routeOrganizationId })">@offer.SupplierCode: @FormatInventoryTotal(offer.CachedInventoryTotal, offer.HasCachedInventory)</span>
                                    }
                                    else if (offer.SupplierCode == "PU")
                                    {
                                        <span data-inventory-summary-code="@offer.SupplierCode" data-inventory-summary-batch-url="@Url.Action("SupplierPartsUnlimitedInventory", new { organizationId = routeOrganizationId })" data-supplier-product-id="@offer.SupplierProductId">@offer.SupplierCode: @FormatInventoryTotal(offer.CachedInventoryTotal, offer.HasCachedInventory)</span>
                                    }
                                    else
                                    {
                                        <span data-inventory-summary-code="@offer.SupplierCode">@offer.SupplierCode: @FormatInventoryTotal(offer.CachedInventoryTotal, offer.HasCachedInventory)</span>
                                    }
                                }
                            </div>
                        }
                    </div>
                    <div class="im1-item-result-body">
                        <div class="im1-item-result-title">
                            <strong>@item.Title</strong>
                            <span>@item.Brand</span>
                        </div>
                        <dl>
                            <div>
                                <dt>Supplier</dt>
                                <dd>@item.SupplierCode</dd>
                            </div>
                            <div>
                                <dt>SKU</dt>
                                <dd>@item.SupplierSku</dd>
                            </div>
                            <div>
                                <dt>MFG Part#</dt>
                                <dd>@(item.ManufacturerPartNumber ?? "-")</dd>
                            </div>
                            <div>
                                <dt>UPC</dt>
                                <dd>@(item.Upc ?? "-")</dd>
                            </div>
                            <div>
                                <dt>Status</dt>
                                <dd>@item.Status</dd>
                            </div>
                            <div>
                                <dt>Fitment</dt>
                                <dd class="im1-fitment-cell">
                                    <span>@item.FitmentRecordCount.ToString("N0") records</span>
                                    <button class="im1-fitment-refresh-button" type="button" title="Fetch fitment" aria-label="Fetch fitment for @item.SupplierSku" data-fetch-fitment-url="@Url.Action("SupplierFetchItemFitment", new { supplierProductId = item.SupplierProductId, organizationId = routeOrganizationId })">
                                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                            <path d="M17 1v5h-5"></path>
                                            <path d="M20 11a8 8 0 0 0-14.9-4"></path>
                                            <path d="M7 23v-5h5"></path>
                                            <path d="M4 13a8 8 0 0 0 14.9 4"></path>
                                        </svg>
                                    </button>
                                    <span class="im1-fitment-fetch-status" data-fitment-fetch-status></span>
                                </dd>
                            </div>
                            <div>
                                <dt>MSRP</dt>
                                <dd>@FormatCurrency(item.Msrp)</dd>
                            </div>
                            <div>
                                <dt>Actual Cost</dt>
                                <dd>@FormatCurrency(item.ActualCost)</dd>
                            </div>
                            <div>
                                <dt>Category</dt>
                                <dd>@(item.Category ?? "-")</dd>
                            </div>
                        </dl>
                        @if ((item.Fitment?.Count ?? 0) > 0)
                        {
                            <details class="im1-fitment-popout">
                                <summary>Fitment (@item.Fitment!.Count.ToString("N0"))</summary>
                                <div class="im1-fitment-grid-wrap">
                                    <table class="im1-fitment-grid">
                                        <thead>
                                            <tr>
                                                <th>Year</th>
                                                <th>Make</th>
                                                <th>Model</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var fitment in item.Fitment!)
                                            {
                                                <tr>
                                                    <td>@fitment.Year</td>
                                                    <td>@fitment.Make</td>
                                                    <td>@fitment.Model</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </details>
                        }
                        @if ((item.Offers?.Count ?? 0) > 0)
                        {
                            <details class="im1-supplier-offers">
                                <summary>Supplier Inventory (@item.Offers!.Count.ToString("N0"))</summary>
                                <div class="im1-supplier-offer-grid">
                                    @foreach (var offer in item.Offers!)
                                    {
                                        var supplierIconSrc = SupplierIconSrc(offer.SupplierCode, offer.SupplierName);
                                        <article class="im1-supplier-offer @(offer.IsDefaultOffer ? "im1-supplier-offer-selected" : string.Empty)" data-offer-row data-offer-supplier-product-id="@offer.SupplierProductId" data-offer-cost="@(offer.ActualCost ?? offer.DealerCost ?? decimal.MaxValue)" data-has-inventory="@offer.HasCachedInventory.ToString().ToLowerInvariant()">
                                            <div class="im1-supplier-offer-media">
                                                @if (!string.IsNullOrWhiteSpace(offer.ImageUrl))
                                                {
                                                    <img src="@offer.ImageUrl" alt="" loading="lazy" referrerpolicy="no-referrer" />
                                                }
                                                else if (!string.IsNullOrWhiteSpace(supplierIconSrc))
                                                {
                                                    <span class="im1-supplier-code-icon"><img src="@supplierIconSrc" alt="@offer.SupplierName" /></span>
                                                }
                                                else
                                                {
                                                    <span>@offer.SupplierCode</span>
                                                }
                                            </div>
                                            <header>
                                                <strong>
                                                    @if (!string.IsNullOrWhiteSpace(supplierIconSrc))
                                                    {
                                                        <span class="im1-supplier-code-icon"><img src="@supplierIconSrc" alt="@offer.SupplierName" /></span>
                                                    }
                                                    @offer.SupplierName
                                                </strong>
                                            </header>
                                            <dl>
                                                <div><dt>SKU</dt><dd>@offer.SupplierSku</dd></div>
                                                <div><dt>MFG Part#</dt><dd>@(offer.ManufacturerPartNumber ?? "-")</dd></div>
                                                <div><dt>Retail</dt><dd>@FormatCurrency(offer.Msrp)</dd></div>
                                                <div><dt>Actual</dt><dd>@FormatCurrency(offer.ActualCost)</dd></div>
                                            </dl>
                                            @if (offer.SupplierCode == "WPS")
                                            {
                                                <section class="im1-live-inventory" data-supplier-code="@offer.SupplierCode" data-supplier-product-id="@offer.SupplierProductId" data-inventory-url="@Url.Action("SupplierWpsInventory", new { supplierProductId = offer.SupplierProductId, organizationId = routeOrganizationId })">
                                                    <header><strong>WPS Warehouses</strong><span>Loading live inventory...</span></header>
                                                    <div class="im1-live-inventory-grid"></div>
                                                </section>
                                            }
                                            @if (offer.SupplierCode == "TURN14")
                                            {
                                                <section class="im1-live-inventory" data-supplier-code="@offer.SupplierCode" data-supplier-product-id="@offer.SupplierProductId" data-inventory-url="@Url.Action("SupplierTurn14Inventory", new { supplierProductId = offer.SupplierProductId, organizationId = routeOrganizationId })">
                                                    <header><strong>Turn14 Warehouses</strong><span>Loading live inventory...</span></header>
                                                    <div class="im1-live-inventory-grid"></div>
                                                </section>
                                            }
                                            @if (offer.SupplierCode == "PU")
                                            {
                                                <section class="im1-live-inventory" data-supplier-code="@offer.SupplierCode" data-inventory-batch-url="@Url.Action("SupplierPartsUnlimitedInventory", new { organizationId = routeOrganizationId })" data-supplier-product-id="@offer.SupplierProductId">
                                                    <header><strong>Parts Unlimited Warehouses</strong><span>Loading live inventory...</span></header>
                                                    <div class="im1-live-inventory-grid"></div>
                                                </section>
                                            }
                                        </article>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                </article>
            }
        </div>
        <div class="im1-infinite-scroll-status" data-scroll-status>
            @(Model.HasMore ? "Load more items" : "All loaded items are shown.")
        </div>
        <script type="application/json" id="initial-supplier-item-results">@Html.Raw(initialResultsJson)</script>
    }
</section>

<dialog class="im1-image-popout-dialog" data-image-popout>
    <div class="im1-image-popout-inner">
        <header>
            <strong data-image-popout-title>Product image</strong>
            <button class="im1-icon-button" type="button" data-close-image-popout aria-label="Close">x</button>
        </header>
        <div class="im1-image-popout-frame">
            <img data-image-popout-img alt="" />
        </div>
    </div>
</dialog>

@section Scripts {
    <script>
        (() => {
            const searchForm = document.querySelector(".im1-item-search-form-ymm");
            if (searchForm) {
                const vehicleType = searchForm.querySelector("[name='vehicleType']");
                const year = searchForm.querySelector("[name='year']");
                const make = searchForm.querySelector("[name='make']");
                const model = searchForm.querySelector("[name='model']");
                vehicleType?.addEventListener("change", () => {
                    if (year) year.value = "";
                    if (make) make.value = "";
                    if (model) model.value = "";
                    searchForm.submit();
                });
                year?.addEventListener("change", () => {
                    if (make) make.value = "";
                    if (model) model.value = "";
                    searchForm.submit();
                });
                make?.addEventListener("change", () => {
                    if (model) model.value = "";
                    searchForm.submit();
                });
            }

            const formatCurrency = (value) => {
                if (value === null || value === undefined) return "-";
                const amount = Number(value);
                if (!Number.isFinite(amount)) return "-";
                return `${amount < 0 ? "-$" : "$"}${Math.abs(amount).toFixed(2)}`;
            };
            const valueOrDash = (value) => value === null || value === undefined || value === "" ? "-" : value;
            const canCopyValue = value => value !== null && value !== undefined && value !== "";
            const writeClipboardText = async value => {
                if (navigator.clipboard?.writeText && window.isSecureContext) {
                    await navigator.clipboard.writeText(value);
                    return;
                }

                const input = document.createElement("textarea");
                input.value = value;
                input.setAttribute("readonly", "");
                input.style.position = "fixed";
                input.style.opacity = "0";
                document.body.append(input);
                input.select();
                document.execCommand("copy");
                input.remove();
            };
            const createCopyButton = (value, label) => {
                if (!canCopyValue(value)) {
                    return null;
                }

                const button = document.createElement("button");
                button.type = "button";
                button.className = "im1-copy-button";
                button.title = `Copy ${label}`;
                button.setAttribute("aria-label", `Copy ${label}`);
                button.addEventListener("click", async event => {
                    event.stopPropagation();
                    const previous = button.title;
                    try {
                        await writeClipboardText(String(value));
                        button.classList.add("im1-copy-button-copied");
                        button.title = "Copied";
                        setTimeout(() => {
                            button.classList.remove("im1-copy-button-copied");
                            button.title = previous;
                        }, 900);
                    } catch {
                        button.title = "Copy failed";
                        setTimeout(() => {
                            button.title = previous;
                        }, 900);
                    }
                });
                return button;
            };
            const createCopyableValue = (value, label) => {
                const wrapper = document.createElement("span");
                wrapper.className = "im1-copyable-value";
                const text = document.createElement("span");
                text.textContent = valueOrDash(value);
