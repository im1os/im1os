@model iM1os.Application.BusinessAdministration.BusinessAdministrationWorkspace

@{
    ViewData["Title"] = "Company Administration";
    var administrationRoute = Model.OrganizationId;
    var pageToolbar = new IM1ToolbarModel(
        Actions: new[]
        {
            new IM1ActionModel("Dashboard", Url.Action("Dashboard", "Business", new { organizationId = administrationRoute }), "secondary")
        });
    var page = new IM1PageModel(
        Title: Model.Profile.BusinessName,
        Eyebrow: "Company administration",
        Description: Model.IsReadyForOperations ? "Your company is now ready to begin operations." : "Configure identity, locations, employees, permissions, labor, taxes, notifications, and suppliers.",
        Breadcrumbs: new[]
        {
            new IM1BreadcrumbModel("Company", Url.Action("Dashboard", "Business", new { organizationId = administrationRoute })),
            new IM1BreadcrumbModel("Administration")
        },
        Toolbar: pageToolbar);
    var tabs = new IM1TabsModel(
        "Company administration sections",
        new[]
        {
            new IM1TabItemModel("overview", "Overview", true),
            new IM1TabItemModel("profile", "Company Profile"),
            new IM1TabItemModel("locations", "Locations"),
            new IM1TabItemModel("roles", "Roles"),
            new IM1TabItemModel("operations", "Operations"),
            new IM1TabItemModel("connectors", "Suppliers"),
            new IM1TabItemModel("activity", "Activity")
        });
    var locationGrid = new IM1DataGridModel(
        Columns: new[]
        {
            new IM1DataGridColumnModel("name", "Name"),
            new IM1DataGridColumnModel("code", "Code"),
            new IM1DataGridColumnModel("status", "Status"),
            new IM1DataGridColumnModel("city", "City"),
            new IM1DataGridColumnModel("phone", "Phone"),
            new IM1DataGridColumnModel("laborRate", "Labor Rate")
        },
        Rows: Model.Locations.Select(location => new Dictionary<string, object?>
        {
            ["name"] = location.Name,
            ["code"] = location.Code,
            ["status"] = location.Status,
            ["city"] = $"{location.City}, {location.Region}",
            ["phone"] = location.Phone ?? "-",
            ["laborRate"] = location.DefaultLaborRate.ToString("C")
        }).ToArray(),
        Toolbar: new IM1ToolbarModel(SearchPlaceholder: "Search locations", ShowRefresh: true, ShowFilters: true, ShowExport: true),
        EmptyText: "No company locations have been configured.",
        PageSize: 10);
    var hero = new IM1WorkspaceHeroModel(
        Model.Profile.BusinessName,
        "Company administration",
        Model.IsReadyForOperations ? "Ready for daily operations." : "Finish required setup before daily operations begin.",
        new[]
        {
            new IM1WorkspaceStatModel("Setup", $"{Model.SetupProgress}%", "Administration readiness"),
            new IM1WorkspaceStatModel("Locations", Model.Locations.Count.ToString(), "Configured shops"),
            new IM1WorkspaceStatModel("Employees", Model.Employees.Count.ToString(), "People records"),
            new IM1WorkspaceStatModel("Status", Model.IsReadyForOperations ? "Ready" : "Setup", "Operational state")
        },
        new[] { new IM1ActionModel("Company Dashboard", Url.Action("Dashboard", "Business", new { organizationId = administrationRoute }), "secondary") },
        Model.IsReadyForOperations ? "Ready" : "Setup needed");
}

@await Html.PartialAsync("IM1Page", page)
@await Html.PartialAsync("IM1WorkspaceHero", hero)

@if (TempData["CompanyAdminStatus"] is string statusMessage)
{
    <div class="form-alert success">@statusMessage</div>
}
@if (TempData["CompanyAdminError"] is string errorMessage)
{
    <div class="form-alert error">@errorMessage</div>
}

<section class="admin-tabs" data-tabs>
    @await Html.PartialAsync("IM1Tabs", tabs)

    <div class="tab-panel is-active" id="overview" role="tabpanel">
        <section class="im1-workspace-grid">
            <article class="im1-workspace-card span-4">
                <header class="im1-section-header"><div><h2>Company</h2><p>Identity and billing-facing information.</p></div></header>
                <dl class="im1-key-value-list">
                    <div><dt>Legal Name</dt><dd>@(Model.Profile.LegalName ?? "-")</dd></div>
                    <div><dt>DBA</dt><dd>@(Model.Profile.Dba ?? "-")</dd></div>
                    <div><dt>Email</dt><dd>@(Model.Profile.Email ?? "-")</dd></div>
                    <div><dt>Phone</dt><dd>@(Model.Profile.Phone ?? "-")</dd></div>
                </dl>
            </article>
            <article class="im1-workspace-card span-4">
                <header class="im1-section-header"><div><h2>Operations</h2><p>Defaults that affect service work.</p></div></header>
                <dl class="im1-key-value-list">
                    <div><dt>Labor Rate</dt><dd>@Model.Configuration.DefaultLaborRate.ToString("C")</dd></div>
                    <div><dt>Tax Rate</dt><dd>@Model.Configuration.DefaultTaxRate.ToString("P2")</dd></div>
                    <div><dt>Currency</dt><dd>@Model.Profile.Currency</dd></div>
                    <div><dt>Time Zone</dt><dd>@Model.Profile.TimeZone</dd></div>
                </dl>
            </article>
            <article class="im1-workspace-card span-4">
                <header class="im1-section-header"><div><h2>Next Actions</h2><p>Common administration work.</p></div></header>
                <div class="im1-action-strip">
                    <button class="im1-button im1-button-secondary" type="button" data-tab-target="profile">Edit Profile</button>
                    <button class="im1-button im1-button-secondary" type="button" data-tab-target="locations">Add Location</button>
                    <button class="im1-button im1-button-secondary" type="button" data-tab-target="operations">Configure Operations</button>
                </div>
            </article>
            <article class="im1-workspace-card span-12">
                <header class="im1-section-header"><div><h2>Recent Activity</h2><p>Latest administration events.</p></div></header>
                <ul class="event-list">
                    @foreach (var item in Model.RecentActivity.Take(8))
                    {
                        <li>@item</li>
                    }
                    @if (Model.RecentActivity.Count == 0)
                    {
                        <li>No recent activity.</li>
                    }
                </ul>
            </article>
        </section>
    </div>

    <div class="tab-panel" id="profile" role="tabpanel" hidden>
        <article class="im1-workspace-card span-12">
            <header class="im1-section-header"><div><h2>Company Profile</h2><p>Edit identity, contact, address, and formatting defaults.</p></div></header>
            <form asp-action="Profile" asp-route-organizationId="@administrationRoute" method="post" class="form-grid">
                <input type="hidden" name="organizationId" value="@Model.OrganizationId" />
                <label>Company Name <input name="BusinessName" value="@Model.Profile.BusinessName" /></label>
                <label>Legal Name <input name="LegalName" value="@Model.Profile.LegalName" /></label>
                <label>DBA <input name="Dba" value="@Model.Profile.Dba" /></label>
                <label>Logo URL <input name="LogoUrl" value="@Model.Profile.LogoUrl" /></label>
                <label>Website <input name="Website" value="@Model.Profile.Website" /></label>
                <label>Phone <input name="Phone" value="@Model.Profile.Phone" /></label>
                <label>Email <input name="Email" value="@Model.Profile.Email" /></label>
                <label>Tax ID <input name="TaxId" value="@Model.Profile.TaxId" /></label>
                <label>Address <input name="AddressLine1" value="@Model.Profile.AddressLine1" /></label>
                <label>Address 2 <input name="AddressLine2" value="@Model.Profile.AddressLine2" /></label>
                <label>City <input name="City" value="@Model.Profile.City" /></label>
                <label>State/Region <input name="Region" value="@Model.Profile.Region" /></label>
                <label>Postal Code <input name="PostalCode" value="@Model.Profile.PostalCode" /></label>
                <label>Country <input name="Country" value="@Model.Profile.Country" /></label>
                <label>Time Zone <input name="TimeZone" value="@Model.Profile.TimeZone" /></label>
                <label>Language <input name="Language" value="@Model.Profile.Language" /></label>
                <label>Currency <input name="Currency" value="@Model.Profile.Currency" /></label>
                <label>Date Format <input name="DateFormat" value="@Model.Profile.DateFormat" /></label>
                <label>Time Format <input name="TimeFormat" value="@Model.Profile.TimeFormat" /></label>
                <button class="primary-action" type="submit">Save Profile</button>
            </form>
        </article>
    </div>

    <div class="tab-panel" id="locations" role="tabpanel" hidden>
        <article class="page-band">
            <h2>Company Locations</h2>
            @await Html.PartialAsync("IM1DataGrid", locationGrid)
            <form asp-action="Location" asp-route-organizationId="@administrationRoute" method="post" class="form-grid form-grid-spaced">
                <input type="hidden" name="organizationId" value="@Model.OrganizationId" />
                <label>Name <input name="Name" /></label>
                <label>Code <input name="Code" /></label>
                <label>Phone <input name="Phone" /></label>
                <label>Address <input name="AddressLine1" /></label>
                <label>Address 2 <input name="AddressLine2" /></label>
                <label>City <input name="City" /></label>
                <label>State/Region <input name="Region" /></label>
                <label>Postal Code <input name="PostalCode" /></label>
                <label>Time Zone <input name="TimeZone" value="@Model.Profile.TimeZone" /></label>
                <label>Default Labor Rate <input name="DefaultLaborRate" type="number" step="0.01" value="@Model.Configuration.DefaultLaborRate" /></label>
                <label>Default Tax Region <input name="DefaultTaxRegion" /></label>
                <label>Status <input name="Status" value="Active" /></label>
                <button class="primary-action" type="submit">Add Location</button>
            </form>
        </article>
    </div>

    <div class="tab-panel" id="roles" role="tabpanel" hidden>
        <article class="page-band">
            <h2>Roles And Permissions</h2>
            <div class="compact-list">
                @foreach (var role in Model.Roles)
                {
                    <p><strong>@role.Name</strong> @(role.IsSystemRole ? "System" : "Custom-ready") - @(role.Permissions.Count == 0 ? "Permissions pending" : string.Join(", ", role.Permissions))</p>
                }
            </div>
        </article>
    </div>

    <div class="tab-panel" id="operations" role="tabpanel" hidden>
        <div class="split-grid">
            <article id="labor" class="page-band">
                <h2>Labor Configuration</h2>
                <form asp-action="Labor" asp-route-organizationId="@administrationRoute" method="post" class="form-grid">
                    <input type="hidden" name="organizationId" value="@Model.OrganizationId" />
                    <label>Default Labor Rate <input name="DefaultLaborRate" type="number" step="0.01" value="@Model.Configuration.DefaultLaborRate" /></label>
                    <label>Diagnostic Rate <input name="DiagnosticRate" type="number" step="0.01" value="@Model.Configuration.DiagnosticRate" /></label>
                    <label>Emergency Rate <input name="EmergencyRate" type="number" step="0.01" value="@Model.Configuration.EmergencyRate" /></label>
                    <label>Weekend Rate <input name="WeekendRate" type="number" step="0.01" value="@Model.Configuration.WeekendRate" /></label>
                    <label>Environmental Fee <input name="EnvironmentalFee" type="number" step="0.01" value="@Model.Configuration.EnvironmentalFee" /></label>
                    <label>Shop Supplies % <input name="ShopSuppliesPercent" type="number" step="0.01" value="@Model.Configuration.ShopSuppliesPercent" /></label>
                    <label class="checkbox"><input name="LaborLineItemsTaxable" type="checkbox" value="true" checked="@Model.Configuration.LaborLineItemsTaxable" /> Labor Line Items Taxable</label><input name="LaborLineItemsTaxable" type="hidden" value="false" />
                    <button class="primary-action" type="submit">Save Labor</button>
                </form>
            </article>

            <article id="taxes" class="page-band">
                <h2>Taxes</h2>
                <form asp-action="Taxes" asp-route-organizationId="@administrationRoute" method="post" class="form-grid single">
                    <input type="hidden" name="organizationId" value="@Model.OrganizationId" />
                    <label>Default Tax Rate <input name="DefaultTaxRate" type="number" step="0.0001" value="@Model.Configuration.DefaultTaxRate" /></label>
                    <label>Regional Overrides JSON <input name="RegionalOverridesJson" value="@Model.Configuration.RegionalTaxOverridesJson" /></label>
                    <button class="primary-action" type="submit">Save Taxes</button>
                </form>
            </article>

            <article id="notifications" class="page-band">
                <h2>Notification Preferences</h2>
                <form asp-action="Notifications" asp-route-organizationId="@administrationRoute" method="post" class="form-grid single">
                    <input type="hidden" name="organizationId" value="@Model.OrganizationId" />
                    <label class="checkbox"><input name="EmailEnabled" type="checkbox" value="true" checked /> Email</label>
                    <label class="checkbox"><input name="SmsEnabled" type="checkbox" value="true" /> SMS</label>
                    <label class="checkbox"><input name="PushFutureEnabled" type="checkbox" value="true" /> Push Future</label>
                    <label class="checkbox"><input name="CustomerNotificationsEnabled" type="checkbox" value="true" checked /> Customer Notifications</label>
                    <label class="checkbox"><input name="TechnicianNotificationsEnabled" type="checkbox" value="true" checked /> Technician Notifications</label>
                    <button class="primary-action" type="submit">Save Notifications</button>
                </form>
            </article>
        </div>
    </div>

    <div class="tab-panel" id="connectors" role="tabpanel" hidden>
        <article class="page-band">
            <header class="im1-section-header">
                <div>
                    <h2>Suppliers</h2>
                    <p>Read-only supplier access and credential status for this company.</p>
                </div>
            </header>
            <div class="connector-grid">
                @if (Model.Connectors.Count == 0)
                {
                    <p class="im1-empty-state">No suppliers are enabled for this company.</p>
                }
                else
                {
                    @foreach (var connector in Model.Connectors)
                    {
                        <div class="connector-summary @(connector.IsEnabled ? "connector-summary-active" : null)">
                            <strong>@connector.Name</strong>
                            <span>@connector.Category</span>
                            <em>@connector.Status</em>
                            <p>@connector.Description</p>
                        </div>
                    }
                }
            </div>
        </article>

        <section class="connector-workspace">
            @foreach (var connector in Model.Connectors)
            {
                <article class="page-band">
                    <header class="im1-section-header">
                        <div>
                            <h2>@connector.Name</h2>
                            <p>@connector.Description</p>
                        </div>
                        <span class="connector-status">@connector.Status</span>
                    </header>

                    <div class="connector-readiness">
                        <div>
                            <span>Platform Access</span>
                            <strong>Enabled</strong>
                        </div>
                        <div>
                            <span>Company Supplier</span>
                            <strong>@(connector.IsEnabled ? "Enabled" : "Disabled")</strong>
                        </div>
                        <div>
                            <span>Credentials</span>
                            <strong>@(connector.WpsConfiguration?.CredentialStatus ?? (connector.Status == "Ready" ? "Ready" : "Missing"))</strong>
                        </div>
                        <div>
                            <span>Sync</span>
                            <strong>@connector.SyncCadence</strong>
                        </div>
                        <div>
                            <span>Last Sync</span>
                            <strong>@(connector.LastSyncAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "-")</strong>
                        </div>
                    </div>

                    <h3>Capabilities</h3>
                    <ul class="check-list">
                        @foreach (var capability in connector.Capabilities)
                        {
                            <li>@capability</li>
                        }
                    </ul>
                </article>
            }
        </section>
    </div>

    <div class="tab-panel" id="activity" role="tabpanel" hidden>
        <article class="page-band">
            <h2>Audit Activity</h2>
            <ul class="event-list">
                @foreach (var item in Model.RecentActivity)
                {
                    <li>@item</li>
                }
            </ul>
        </article>
    </div>
</section>
