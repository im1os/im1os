@model iM1os.Application.TenantIdentity.BusinessDashboardSummary
@{
    var isOwner = User.IsInRole("Owner");
    var isCompanyAdmin = User.IsInRole("Administrator");
    var isPlatformAdmin = User.IsInRole("Platform Administrator");
    var organizationId = ViewBag.OrganizationId as Guid?;
}

@{
    ViewData["Title"] = "Company Dashboard";
}

<section class="dashboard-header">
    <div>
        <p class="eyebrow">Company dashboard</p>
        <h1>@Model.BusinessName</h1>
        <p class="subtle">@(Model.SetupProgress >= 100 ? "Your company is now ready to begin operations." : "Finish company administration to prepare this shop for operations.")</p>
    </div>
    @if (isOwner || isCompanyAdmin || isPlatformAdmin)
    {
        <a class="primary-action" asp-controller="Business" asp-action="Administration" asp-route-organizationId="@organizationId">Company Administration</a>
    }
</section>

<section class="metric-grid">
    <article><span>Subscription</span><strong>@Model.Subscription</strong><p>Current plan.</p></article>
    <article><span>Status</span><strong>@Model.OrganizationStatus</strong><p>Company state.</p></article>
    <article><span>Locations</span><strong>@Model.Locations</strong><p>Configured locations.</p></article>
    <article><span>Employees</span><strong>@Model.Employees</strong><p>Active users.</p></article>
</section>

<section class="split-grid">
    <article class="page-band">
        <h2>Setup Progress</h2>
        <p>@Model.SetupProgress% complete</p>
    </article>
    <article class="page-band">
        <h2>Quick Actions</h2>
        @if (isOwner || isCompanyAdmin || isPlatformAdmin)
        {
            <div class="action-row">
                <a class="secondary-action" asp-controller="Business" asp-action="Administration" asp-route-organizationId="@organizationId" asp-fragment="employees">Invite Employee</a>
                <a class="secondary-action" asp-controller="Business" asp-action="Administration" asp-route-organizationId="@organizationId" asp-fragment="connectors">Connect Supplier</a>
                <a class="secondary-action" asp-controller="Business" asp-action="Administration" asp-route-organizationId="@organizationId" asp-fragment="labor">Configure Labor Rates</a>
                <a class="secondary-action" asp-controller="Business" asp-action="Administration" asp-route-organizationId="@organizationId">Open Company Administration</a>
            </div>
        }
        else
        {
            <p>Administration actions are available to company owners and administrators.</p>
        }
    </article>
    <article class="page-band">
        <h2>Recent Activity</h2>
        <ul class="event-list">
            @foreach (var item in Model.RecentActivity)
            {
                <li>@item</li>
            }
        </ul>
    </article>
</section>
