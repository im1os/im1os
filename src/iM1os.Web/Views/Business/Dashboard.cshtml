@model iM1os.Application.TenantIdentity.BusinessDashboardSummary
@{
    var workspace = ViewBag.AdminWorkspace as iM1os.Application.BusinessAdministration.BusinessAdministrationWorkspace;
}

@{
    ViewData["Title"] = "Business Dashboard";
}

<section class="dashboard-header">
    <div>
        <p class="eyebrow">Business dashboard</p>
        <h1>@Model.BusinessName</h1>
        <p class="subtle">@(workspace?.IsReadyForOperations == true ? "Your business is now ready to begin operations." : "Finish business administration to prepare this shop for operations.")</p>
    </div>
    <a class="primary-action" asp-controller="Business" asp-action="Administration">Business Administration</a>
</section>

<section class="metric-grid">
    <article><span>Subscription</span><strong>@Model.Subscription</strong><p>Current plan.</p></article>
    <article><span>Status</span><strong>@Model.OrganizationStatus</strong><p>Organization state.</p></article>
    <article><span>Locations</span><strong>@Model.Locations</strong><p>Configured locations.</p></article>
    <article><span>Employees</span><strong>@Model.Employees</strong><p>Active users.</p></article>
</section>

<section class="split-grid">
    <article class="page-band">
        <h2>Setup Progress</h2>
        <p>@Model.SetupProgress% complete</p>
    </article>
    <article class="page-band">
        <h2>Quick Actions</h2>
        <div class="action-row">
            <a class="secondary-action" asp-controller="Business" asp-action="Administration" asp-fragment="employees">Invite Employee</a>
            <a class="secondary-action" asp-controller="Business" asp-action="Administration" asp-fragment="connectors">Connect Supplier</a>
            <a class="secondary-action" asp-controller="Business" asp-action="Administration" asp-fragment="labor">Configure Labor Rates</a>
            <a class="secondary-action" asp-controller="Business" asp-action="Administration">Open Business Administration</a>
        </div>
    </article>
    <article class="page-band">
        <h2>Recent Activity</h2>
        <ul class="event-list">
            @foreach (var item in Model.RecentActivity)
            {
                <li>@item</li>
            }
        </ul>
    </article>
</section>
