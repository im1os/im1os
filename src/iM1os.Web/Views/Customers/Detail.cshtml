@model iM1os.Application.Customers.CustomerDetail

@{
    ViewData["Title"] = Model.DisplayName;
    var statusOptions = new[] { "Active", "Prospect", "Inactive", "Archived" };
    var customerTypeOptions = new[] { "Individual", "Business", "Government", "Internal" };
    var preferredContactOptions = new[] { "Phone", "Text", "Email", "Mail", "None" };
    var referralSourceOptions = new[] { "Walk-In", "Website", "Referral", "Employee", "Event", "Social Media", "Advertising", "Other" };
    var languageOptions = new[] { "English", "Spanish", "French", "Other" };
    var stateOptions = new[] { "AL", "AK", "AZ", "AR", "CA", "CO", "CT", "DE", "FL", "GA", "HI", "IA", "ID", "IL", "IN", "KS", "KY", "LA", "MA", "MD", "ME", "MI", "MN", "MO", "MS", "MT", "NC", "ND", "NE", "NH", "NJ", "NM", "NV", "NY", "OH", "OK", "OR", "PA", "RI", "SC", "SD", "TN", "TX", "UT", "VA", "VT", "WA", "WI", "WV", "WY" };
    var unitTypeOptions = new[] { "Off-Road", "Motorcycle", "ATV", "UTV", "Watercraft", "Snowmobile", "Trailer", "Other" };
    var attachmentTypeOptions = new[] { "Photo", "Video", "Document" };
    var primaryAddress = Model.Addresses.OrderByDescending(address => address.IsPrimary).FirstOrDefault();
    var contactValue = Model.MobilePhone ?? Model.Phone ?? Model.Email ?? "No contact method";
    var heroActions = new List<IM1ActionModel>();
    if (!string.IsNullOrWhiteSpace(Model.MobilePhone ?? Model.Phone))
    {
        heroActions.Add(new IM1ActionModel("Call", $"tel:{Model.MobilePhone ?? Model.Phone}", "primary"));
    }
    if (!string.IsNullOrWhiteSpace(Model.Email))
    {
        heroActions.Add(new IM1ActionModel("Email", $"mailto:{Model.Email}", "secondary"));
    }
    heroActions.Add(new IM1ActionModel("Insert Note", "#notes", "secondary"));
    heroActions.Add(new IM1ActionModel("Add Unit", "#units", "secondary"));
    var hero = new IM1WorkspaceHeroModel(
        Model.DisplayName,
        "Customer workspace",
        $"{Model.CustomerType} customer. Preferred contact: {(Model.PreferredContactMethod ?? "Not set")}.",
        new[]
        {
            new IM1WorkspaceStatModel("Status", Model.Status, "Customer state"),
            new IM1WorkspaceStatModel("Contact", contactValue, "Primary reach method"),
            new IM1WorkspaceStatModel("Lifetime Sales", Model.LifetimeSales.ToString("C"), "Recorded value"),
            new IM1WorkspaceStatModel("Balance", Model.CurrentBalance.ToString("C"), "Open balance"),
            new IM1WorkspaceStatModel("Units", Model.Units.Count.ToString(), "Customer vehicles"),
            new IM1WorkspaceStatModel("Last Purchase", Model.LastPurchaseAtUtc?.ToString("yyyy-MM-dd") ?? "None", "Most recent sale")
        },
        heroActions,
        Model.TaxExempt ? "Tax exempt" : Model.Status);
    var page = new IM1PageModel(
        Model.DisplayName,
        "CRM / Customers",
        "Shared customer profile used across sales, service, work orders, invoicing, payments, scheduling, marketing, and future modules.",
        Breadcrumbs: new[]
        {
            new IM1BreadcrumbModel("Company", Url.Action("Dashboard", "Business")),
            new IM1BreadcrumbModel("Customers", Url.Action("Index", "Customers")),
            new IM1BreadcrumbModel(Model.DisplayName)
        },
        Toolbar: new IM1ToolbarModel(Actions: new[] { new IM1ActionModel("Back to Customers", Url.Action("Index", "Customers"), "secondary") }));
    var tabs = new IM1TabsModel(
        "Customer sections",
        new[]
        {
            new IM1TabItemModel("overview", "Overview", true),
            new IM1TabItemModel("general", "Edit Details"),
            new IM1TabItemModel("units", "Units"),
            new IM1TabItemModel("purchases", "Purchases"),
            new IM1TabItemModel("timeline", "Timeline"),
            new IM1TabItemModel("notes", "Notes"),
            new IM1TabItemModel("documents", "Documents"),
            new IM1TabItemModel("marketing", "Marketing"),
            new IM1TabItemModel("financial", "Financial")
        });
}

@await Html.PartialAsync("IM1Page", page)
@await Html.PartialAsync("IM1WorkspaceHero", hero)

@if (TempData["CustomerError"] is string errorMessage)
{
    <div class="form-alert error">@errorMessage</div>
}

<section class="im1-page">
    @await Html.PartialAsync("IM1Tabs", tabs)

    <section class="tab-panel is-active" id="overview" role="tabpanel">
        <section class="im1-workspace-grid">
            <article class="im1-workspace-card span-4">
                <header class="im1-section-header"><div><h2>Contact</h2><p>How this customer prefers to communicate.</p></div></header>
                <dl class="im1-key-value-list">
                    <div><dt>Email</dt><dd>@(Model.Email ?? "-")</dd></div>
                    <div><dt>Mobile</dt><dd>@(Model.MobilePhone ?? Model.Phone ?? "-")</dd></div>
                    <div><dt>Work</dt><dd>@(Model.WorkPhone ?? "-")</dd></div>
                    <div><dt>Preferred</dt><dd>@(Model.PreferredContactMethod ?? "Not set")</dd></div>
                </dl>
            </article>
            <article class="im1-workspace-card span-4">
                <header class="im1-section-header"><div><h2>Primary Address</h2><p>Default billing and service location.</p></div></header>
                @if (primaryAddress is null)
                {
                    <p class="im1-empty-state">No primary address on file.</p>
                }
                else
                {
                    <dl class="im1-key-value-list">
                        <div><dt>Address</dt><dd>@primaryAddress.Line1 @(primaryAddress.Line2)</dd></div>
                        <div><dt>City/State</dt><dd>@primaryAddress.City, @primaryAddress.Region @primaryAddress.PostalCode</dd></div>
                        <div><dt>Country</dt><dd>@primaryAddress.Country</dd></div>
                    </dl>
                }
            </article>
            <article class="im1-workspace-card span-4">
                <header class="im1-section-header"><div><h2>Financial</h2><p>Account state at a glance.</p></div></header>
                <dl class="im1-key-value-list">
                    <div><dt>Lifetime Sales</dt><dd>@Model.LifetimeSales.ToString("C")</dd></div>
                    <div><dt>Balance</dt><dd>@Model.CurrentBalance.ToString("C")</dd></div>
                    <div><dt>Store Credit</dt><dd>@Model.StoreCredit.ToString("C")</dd></div>
                    <div><dt>Credit Limit</dt><dd>@(Model.CreditLimit?.ToString("C") ?? "Not set")</dd></div>
                </dl>
            </article>
            <article class="im1-workspace-card span-6">
                <header class="im1-section-header"><div><h2>Recent Notes</h2><p>Newest customer context.</p></div><a class="im1-button im1-button-secondary" href="#notes">Insert Note</a></header>
                <ol class="company-activity-list">
                    @foreach (var note in Model.Notes.Take(3))
                    {
                        <li><strong>@(note.IsPinned ? "Anchored " : "")@note.NoteType</strong><span>@note.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm") by @(note.AuthorDisplayName ?? "Unknown")</span><p>@note.Body</p></li>
                    }
                    @if (Model.Notes.Count == 0)
                    {
                        <li>No notes found.</li>
                    }
                </ol>
            </article>
            <article class="im1-workspace-card span-6">
                <header class="im1-section-header"><div><h2>Units</h2><p>Customer vehicles and equipment.</p></div><a class="im1-button im1-button-secondary" href="#units">Manage Units</a></header>
                <div class="im1-key-value-list">
                    @foreach (var unit in Model.Units.Take(4))
                    {
                        var unitName = string.Join(" ", new[] { unit.Year?.ToString(), unit.Make, unit.Model }.Where(value => !string.IsNullOrWhiteSpace(value)));
                        <div><dt>@unit.Type</dt><dd>@(string.IsNullOrWhiteSpace(unitName) ? "Unnamed unit" : unitName) @(string.IsNullOrWhiteSpace(unit.Vin) ? "" : $"VIN {unit.Vin}")</dd></div>
                    }
                    @if (Model.Units.Count == 0)
                    {
                        <p class="im1-empty-state">No units found.</p>
                    }
                </div>
            </article>
            <article class="im1-workspace-card span-12">
                <header class="im1-section-header"><div><h2>Recent Activity</h2><p>Timeline events across CRM and service work.</p></div></header>
                <ol class="company-activity-list">
                    @foreach (var item in Model.Timeline.Take(6))
                    {
                        <li><strong>@item.EventType</strong><span>@item.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm")</span><p>@item.Summary</p></li>
                    }
                    @if (Model.Timeline.Count == 0)
                    {
                        <li>No timeline events found.</li>
                    }
                </ol>
            </article>
        </section>
    </section>

    <section class="tab-panel" id="general" role="tabpanel" hidden>
        <form asp-action="Update" method="post" class="im1-form im1-record-form">
            <input type="hidden" name="CustomerId" value="@Model.Id" />
            <fieldset class="im1-form-section">
                <legend>Identity</legend>
                <div class="im1-form-grid">
                    <label>Customer Number <input value="@(Model.CustomerNumber ?? "Not assigned")" readonly /></label>
                    <label>Display Name <input value="@Model.DisplayName" readonly /></label>
                    <label>Customer Type
                        <select name="CustomerType">
                            @foreach (var type in customerTypeOptions)
                            {
                                <option value="@type" selected="@(Model.CustomerType == type)">@type</option>
                            }
                        </select>
                    </label>
                    <label>Status
                        <select name="Status">
                            @foreach (var status in statusOptions)
                            {
                                <option value="@status" selected="@(Model.Status == status)">@status</option>
                            }
                        </select>
                    </label>
                    <label>Company Name <input name="CompanyName" value="@Model.CompanyName" maxlength="150" /></label>
                    <label>First Name <input name="FirstName" value="@Model.FirstName" maxlength="100" /></label>
                    <label>Middle Name <input name="MiddleName" value="@Model.MiddleName" maxlength="100" /></label>
                    <label>Last Name <input name="LastName" value="@Model.LastName" maxlength="100" /></label>
                    <label>Nickname <input name="Nickname" value="@Model.Nickname" maxlength="100" /></label>
                </div>
            </fieldset>

            <fieldset class="im1-form-section">
                <legend>Contact</legend>
                <div class="im1-form-grid">
                    <label>Email <input name="Email" value="@Model.Email" type="email" /></label>
                    <label>Mobile Phone <input name="MobilePhone" value="@(Model.MobilePhone ?? Model.Phone)" /></label>
                    <label>Work Phone <input name="WorkPhone" value="@Model.WorkPhone" /></label>
                    <label>Preferred Contact
                        <select name="PreferredContactMethod">
                            <option value="">Not Set</option>
                            @foreach (var method in preferredContactOptions)
                            {
                                <option value="@method" selected="@(Model.PreferredContactMethod == method)">@method</option>
                            }
                        </select>
                    </label>
                    <label>Preferred Language
                        <select name="PreferredLanguage">
                            @foreach (var language in languageOptions)
                            {
                                <option value="@language" selected="@(Model.PreferredLanguage == language)">@language</option>
                            }
                        </select>
                    </label>
                </div>
            </fieldset>

            <fieldset class="im1-form-section">
                <legend>Primary Address</legend>
                <div class="im1-form-grid" data-zip-lookup>
                    <label>Address Line 1 <input name="Line1" value="@primaryAddress?.Line1" /></label>
                    <label>Address Line 2 <input name="Line2" value="@primaryAddress?.Line2" /></label>
                    <label>City <input name="City" value="@primaryAddress?.City" data-zip-lookup-city /></label>
                    <label>State
                        <select name="Region" data-zip-lookup-state>
                            <option value="">Select</option>
                            @foreach (var state in stateOptions)
                            {
                                <option value="@state" selected="@(primaryAddress?.Region == state)">@state</option>
                            }
                        </select>
                    </label>
                    <label>Postal Code <input name="PostalCode" value="@primaryAddress?.PostalCode" data-zip-lookup-postal /></label>
                    <input type="hidden" name="Country" value="US" data-zip-lookup-country />
                </div>
            </fieldset>

            <fieldset class="im1-form-section">
                <legend>Preferences & Accounting</legend>
                <div class="im1-form-grid">
                    <label>Referral Source
                        <select name="Source">
                            <option value="">Not Set</option>
                            @foreach (var source in referralSourceOptions)
                            {
                                <option value="@source" selected="@(Model.Source == source)">@source</option>
                            }
                        </select>
                    </label>
                    <label>Date of Birth <input name="DateOfBirth" value="@Model.DateOfBirth?.ToString("yyyy-MM-dd")" type="date" /></label>
                    <label>Customer Since <input value="@((Model.CustomerSince ?? DateOnly.FromDateTime(Model.CreatedAtUtc.DateTime)).ToString("yyyy-MM-dd"))" readonly /></label>
                    <label>Last Purchase <input value="@(Model.LastPurchaseAtUtc?.ToString("yyyy-MM-dd") ?? "None")" readonly /></label>
                    <label>Reseller Tax Certificate Number <input name="TaxExemptNumber" value="@Model.TaxExemptNumber" maxlength="50" data-tax-exempt-number /></label>
                    <label>Credit Limit <input name="CreditLimit" value="@Model.CreditLimit" type="number" step="0.01" min="0" /></label>
                    <div class="im1-checkbox-group">
                        <span class="im1-checkbox-group-title">Communication & Tax Flags</span>
                        <div class="im1-checkbox-options">
                            <label class="im1-checkbox"><input name="AllowEmailMarketing" type="checkbox" value="true" checked="@Model.AllowEmailMarketing" /> Email Marketing</label><input name="AllowEmailMarketing" type="hidden" value="false" />
                            <label class="im1-checkbox"><input name="AllowSmsMarketing" type="checkbox" value="true" checked="@Model.AllowSmsMarketing" /> SMS Marketing</label><input name="AllowSmsMarketing" type="hidden" value="false" />
                            <label class="im1-checkbox"><input name="AllowPhoneCalls" type="checkbox" value="true" checked="@Model.AllowPhoneCalls" /> Phone Calls</label><input name="AllowPhoneCalls" type="hidden" value="false" />
                            <label class="im1-checkbox"><input name="TaxExempt" type="checkbox" value="true" checked="@Model.TaxExempt" data-tax-exempt-toggle /> Tax Exempt</label><input name="TaxExempt" type="hidden" value="false" />
                        </div>
                    </div>
                </div>
            </fieldset>

            <fieldset class="im1-form-section">
                <legend>Audit</legend>
                <div class="im1-form-grid">
                    <label>Created By <input value="@(Model.CreatedByUserId ?? "System")" readonly /></label>
                    <label>Created Date <input value="@Model.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")" readonly /></label>
                    <label>Modified By <input value="@(Model.UpdatedByUserId ?? "")" readonly /></label>
                    <label>Modified Date <input value="@(Model.UpdatedAtUtc?.ToString("yyyy-MM-dd HH:mm") ?? "")" readonly /></label>
                </div>
            </fieldset>
            <div class="im1-form-actions">
                <button class="im1-button im1-button-primary" type="submit">Save Customer</button>
            </div>
        </form>
    </section>

    <section class="tab-panel" id="units" role="tabpanel" hidden>
        <form asp-action="AddUnit" method="post" class="im1-form im1-record-form">
            <input type="hidden" name="CustomerId" value="@Model.Id" />
            <fieldset class="im1-form-section">
                <legend>Motorcycle / Unit Information</legend>
                <div class="im1-form-grid">
                    <label>Type
                        <select name="Type" required>
                            @foreach (var type in unitTypeOptions)
                            {
                                <option value="@type" selected="@(type == "Off-Road")">@type</option>
                            }
                        </select>
                    </label>
                    <label>Year <input name="Year" type="number" min="1900" max="2100" /></label>
                    <label>Make <input name="Make" maxlength="120" /></label>
                    <label>Model <input name="Model" maxlength="160" /></label>
                    <label>VIN <input name="Vin" maxlength="80" /></label>
                    <label>Color <input name="Color" maxlength="80" /></label>
                    <label>Tag / Plate <input name="TagPlate" maxlength="80" /></label>
                    <label>Mileage In <input name="MileageIn" type="number" step="0.1" min="0" /></label>
                    <label>Mileage Out <input name="MileageOut" type="number" step="0.1" min="0" /></label>
                    <label class="im1-full-span">Notes <textarea name="Notes" rows="3" maxlength="1000"></textarea></label>
                </div>
            </fieldset>
            <fieldset class="im1-form-section">
                <legend>YYM Database Placeholder</legend>
                <div class="im1-form-grid">
                    <label class="im1-full-span">Year / Make / Model Lookup <input value="Placeholder" readonly /></label>
                </div>
            </fieldset>
            <div class="im1-form-actions">
                <button class="im1-button im1-button-primary" type="submit">Add Unit</button>
            </div>
        </form>

        <div class="im1-data-grid">
            <table>
                <thead>
                    <tr>
                        <th>Type</th>
                        <th>Year</th>
                        <th>Make</th>
                        <th>Model</th>
                        <th>VIN</th>
                        <th>Color</th>
                        <th>Tag / Plate</th>
                        <th>Mileage In</th>
                        <th>Mileage Out</th>
                        <th>Attachments</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var unit in Model.Units)
                    {
                        <tr>
                            <td>@unit.Type</td>
                            <td>@unit.Year</td>
                            <td>@unit.Make</td>
                            <td>@unit.Model</td>
                            <td>@unit.Vin</td>
                            <td>@unit.Color</td>
                            <td>@unit.TagPlate</td>
                            <td>@unit.MileageIn</td>
                            <td>@unit.MileageOut</td>
                            <td>@unit.Attachments.Count</td>
                        </tr>
                        @if (!string.IsNullOrWhiteSpace(unit.Notes))
                        {
                            <tr>
                                <td colspan="10"><strong>Notes:</strong> @unit.Notes</td>
                            </tr>
                        }
                        @foreach (var attachment in unit.Attachments)
                        {
                            <tr>
                                <td colspan="10">
                                    <strong>@attachment.AttachmentType:</strong>
                                    @if (!string.IsNullOrWhiteSpace(attachment.Url))
                                    {
                                        <a href="@attachment.Url" target="_blank" rel="noopener">@attachment.FileName</a>
                                    }
                                    else
                                    {
                                        @attachment.FileName
                                    }
                                    <span class="subtle">@attachment.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm")</span>
                                </td>
                            </tr>
                        }
                    }
                    @if (Model.Units.Count == 0)
                    {
                        <tr><td colspan="10">No units found.</td></tr>
                    }
                </tbody>
            </table>
        </div>

        <form asp-action="AddUnitAttachment" method="post" class="im1-form">
            <input type="hidden" name="CustomerId" value="@Model.Id" />
            <fieldset class="im1-form-section">
                <legend>Attachments / Photos and Videos</legend>
                <div class="im1-form-grid">
                    <label>Unit
                        <select name="CustomerVehicleId" required>
                            <option value="">Select unit</option>
                            @foreach (var unit in Model.Units)
                            {
                                var label = string.Join(" ", new[] { unit.Year?.ToString(), unit.Make, unit.Model, unit.Vin }.Where(value => !string.IsNullOrWhiteSpace(value)));
                                <option value="@unit.Id">@(string.IsNullOrWhiteSpace(label) ? unit.Type : label)</option>
                            }
                        </select>
                    </label>
                    <label>Attachment Type
                        <select name="AttachmentType" required>
                            @foreach (var type in attachmentTypeOptions)
                            {
                                <option>@type</option>
                            }
                        </select>
                    </label>
                    <label>File Name <input name="FileName" required maxlength="260" /></label>
                    <label>URL <input name="Url" /></label>
                    <label>Content Type <input name="ContentType" placeholder="image/jpeg, video/mp4" /></label>
                </div>
            </fieldset>
            <div class="im1-form-actions">
                <button class="im1-button im1-button-primary" type="submit">Add Attachment</button>
            </div>
        </form>
    </section>

    <section class="tab-panel" id="purchases" role="tabpanel" hidden>
        <div class="im1-data-grid">
            <table>
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Reference</th>
                        <th>Status</th>
                        <th>Description</th>
                        <th>Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var purchase in Model.Purchases)
                    {
                        <tr>
                            <td>@purchase.PurchasedAtUtc.ToString("yyyy-MM-dd")</td>
                            <td>@purchase.PurchaseType</td>
                            <td>@purchase.ReferenceNumber</td>
                            <td>@purchase.Status</td>
                            <td>@purchase.Description</td>
                            <td>@(purchase.Total?.ToString("C") ?? "-")</td>
                        </tr>
                    }
                    @if (Model.Purchases.Count == 0)
                    {
                        <tr><td colspan="6">No in-store, online, work order, or special order purchases found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="tab-panel" id="timeline" role="tabpanel" hidden>
        <ol class="company-activity-list">
            @foreach (var item in Model.Timeline)
            {
                <li><strong>@item.EventType</strong><span>@item.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm")</span><p>@item.Summary</p></li>
            }
            @if (Model.Timeline.Count == 0)
            {
                <li>No timeline events found.</li>
            }
        </ol>
    </section>

    <section class="tab-panel" id="notes" role="tabpanel" hidden>
        <form asp-action="AddNote" method="post" class="im1-form im1-note-composer">
            <input type="hidden" name="CustomerId" value="@Model.Id" />
            <div class="im1-form-header">
                <h2>Insert Note</h2>
                <p>Notes are stamped with the date, time, and person who entered them.</p>
            </div>
            <div class="im1-form-grid">
                <label>Note Type
                    <select name="NoteType">
                        <option>General</option>
                        <option>Sales</option>
                        <option>Service</option>
                        <option>Billing</option>
                        <option>Marketing</option>
                    </select>
                </label>
                <label class="im1-checkbox"><input name="IsPinned" type="checkbox" value="true" /> Anchor to top</label><input name="IsPinned" type="hidden" value="false" />
                <label class="im1-full-span">Insert Note <textarea name="Body" rows="4" required></textarea></label>
            </div>
            <div class="im1-form-actions">
                <button class="im1-button im1-button-primary" type="submit">Insert Note</button>
            </div>
        </form>
        <ol class="company-activity-list">
            @foreach (var note in Model.Notes)
            {
                <li>
                    <strong>@(note.IsPinned ? "Anchored " : "")@note.NoteType</strong>
                    <span>@note.OccurredAtUtc.ToString("yyyy-MM-dd HH:mm") by @(note.AuthorDisplayName ?? "Unknown")</span>
                    <p>@note.Body</p>
                </li>
            }
            @if (Model.Notes.Count == 0)
            {
                <li>No notes found.</li>
            }
        </ol>
    </section>

    <section class="tab-panel" id="documents" role="tabpanel" hidden>
        @await Html.PartialAsync("IM1DocumentDropzone", new IM1DocumentDropzoneModel(
            Url.Action("AddDocument", "Customers") ?? "/Customers/AddDocument",
            "CustomerId",
            Model.Id,
            "documents",
            "Add Customer Document",
            "Drop customer documents, photos, videos, or add an external document link.",
            "Add Document",
            new[] { "General", "Tax", "Agreement", "Photo", "Video", "Finance", "Service", "Marketing" }))
        <div class="im1-data-grid">
            <table>
                <thead><tr><th>Type</th><th>File</th><th>Uploaded</th><th>Link</th></tr></thead>
                <tbody>
                    @foreach (var document in Model.Documents)
                    {
                        <tr><td>@document.DocumentType</td><td>@document.FileName</td><td>@document.UploadedAtUtc.ToString("yyyy-MM-dd HH:mm")</td><td>@if (!string.IsNullOrWhiteSpace(document.Url)) { <a href="@document.Url" target="_blank" rel="noopener">Open</a> }</td></tr>
                    }
                    @if (Model.Documents.Count == 0)
                    {
                        <tr><td colspan="4">No documents found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

    <section class="tab-panel" id="marketing" role="tabpanel" hidden>
        <form asp-action="AddTag" method="post" class="im1-form">
            <input type="hidden" name="CustomerId" value="@Model.Id" />
            <div class="im1-form-grid">
                <label>Tag <input name="Tag" required /></label>
            </div>
            <div class="im1-form-actions"><button class="im1-button im1-button-primary" type="submit">Add Tag</button></div>
        </form>
        <form asp-action="AddCustomField" method="post" class="im1-form">
            <input type="hidden" name="CustomerId" value="@Model.Id" />
            <div class="im1-form-grid">
                <label>Field Key <input name="FieldKey" required /></label>
                <label>Label <input name="FieldLabel" /></label>
                <label>Value <input name="FieldValue" /></label>
            </div>
            <div class="im1-form-actions"><button class="im1-button im1-button-primary" type="submit">Save Custom Field</button></div>
        </form>
        <div class="company-security-grid">
            <article><span>Tags</span><strong>@string.Join(", ", Model.Tags.Select(x => x.Tag))</strong></article>
            @foreach (var field in Model.CustomFields)
            {
                <article><span>@(field.FieldLabel ?? field.FieldKey)</span><strong>@field.FieldValue</strong></article>
            }
        </div>
    </section>

    <section class="tab-panel" id="financial" role="tabpanel" hidden>
        <div class="company-security-grid">
            <article><span>Lifetime Sales</span><strong>@Model.LifetimeSales.ToString("C")</strong></article>
            <article><span>Credit Limit</span><strong>@(Model.CreditLimit?.ToString("C") ?? "Not set")</strong></article>
            <article><span>Current Balance</span><strong>@Model.CurrentBalance.ToString("C")</strong></article>
            <article><span>Store Credit</span><strong>@Model.StoreCredit.ToString("C")</strong></article>
            @if (!string.IsNullOrWhiteSpace(Model.SquareCustomerId))
            {
                <article><span>Square Customer ID</span><strong>@Model.SquareCustomerId</strong></article>
            }
        </div>
        <form asp-action="AddExternalLink" method="post" class="im1-form">
            <input type="hidden" name="CustomerId" value="@Model.Id" />
            <div class="im1-form-grid">
                <label>Provider
                    <select name="Provider">
                        <option>Square</option>
                        <option>QuickBooks</option>
                        <option>Stripe</option>
                        <option>Authorize.Net</option>
                    </select>
                </label>
                <label>External Customer ID <input name="ExternalCustomerId" required /></label>
                <label>External URL <input name="ExternalUrl" /></label>
            </div>
            <div class="im1-form-actions"><button class="im1-button im1-button-primary" type="submit">Add External Link</button></div>
        </form>
        <div class="im1-data-grid">
            <table>
                <thead><tr><th>Provider</th><th>External ID</th><th>Status</th><th>Link</th></tr></thead>
                <tbody>
                    @foreach (var link in Model.ExternalLinks)
                    {
                        <tr><td>@link.Provider</td><td>@link.ExternalCustomerId</td><td>@(link.IsActive ? "Active" : "Inactive")</td><td>@if (!string.IsNullOrWhiteSpace(link.ExternalUrl)) { <a href="@link.ExternalUrl">Open</a> }</td></tr>
                    }
                    @if (Model.ExternalLinks.Count == 0)
                    {
                        <tr><td colspan="4">No external links found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</section>
