@model iM1os.Application.Customers.CustomerWorkspace

@{
    ViewData["Title"] = "Customers";
    var showNewCustomer = Context.Request.Query["newCustomer"] == "true";
    var grid = new IM1DataGridModel(
        Columns: new[]
        {
            new IM1DataGridColumnModel("name", "Name"),
            new IM1DataGridColumnModel("company", "Company"),
            new IM1DataGridColumnModel("email", "Email"),
            new IM1DataGridColumnModel("phone", "Phone"),
            new IM1DataGridColumnModel("status", "Status"),
            new IM1DataGridColumnModel("stage", "Stage"),
            new IM1DataGridColumnModel("source", "Source"),
            new IM1DataGridColumnModel("created", "Created"),
            new IM1DataGridColumnModel("actions", "Actions", false, false)
        },
        Rows: Model.Customers.Select(customer => new Dictionary<string, object?>
        {
            ["name"] = customer.DisplayName,
            ["company"] = customer.CompanyName ?? "",
            ["email"] = customer.Email ?? "",
            ["phone"] = customer.Phone ?? "",
            ["status"] = customer.Status,
            ["stage"] = customer.LifecycleStage ?? "",
            ["source"] = customer.Source ?? "",
            ["created"] = customer.CreatedAtUtc.ToString("yyyy-MM-dd"),
            ["actions"] = new Microsoft.AspNetCore.Html.HtmlString($"<a class=\"im1-button im1-button-secondary\" href=\"{Url.Action("Detail", "Customers", new { customerId = customer.Id })}\">Open</a>")
        }).ToArray(),
        Toolbar: new IM1ToolbarModel(
            Actions: new[] { new IM1ActionModel("New Customer", Url.Action("Index", "Customers", new { newCustomer = true }), "primary") },
            SearchPlaceholder: "Search customers",
            ShowRefresh: true,
            ShowExport: true),
        EmptyText: "No customers found.",
        PageSize: 20);
    var page = new IM1PageModel(
        "Customers",
        "CRM",
        "Master customer records shared across sales, service, work orders, invoicing, payments, scheduling, marketing, and future modules.",
        Breadcrumbs: new[]
        {
            new IM1BreadcrumbModel("Company", Url.Action("Dashboard", "Business")),
            new IM1BreadcrumbModel("CRM"),
            new IM1BreadcrumbModel("Customers")
        });
}

@await Html.PartialAsync("IM1Page", page)

<form class="im1-toolbar" method="get" asp-controller="Customers" asp-action="Index">
    <select name="status">
        <option value="">All statuses</option>
        @foreach (var status in new[] { "Active", "Inactive", "Prospect", "Do Not Contact" })
        {
            <option value="@status" selected="@(Model.Status == status)">@status</option>
        }
    </select>
    <button class="im1-button im1-button-secondary" type="submit">Apply Filters</button>
</form>

@await Html.PartialAsync("IM1DataGrid", grid)

@if (showNewCustomer)
{
    <div class="im1-side-panel-backdrop is-open" data-side-panel="new-customer">
        <aside class="im1-side-panel" aria-labelledby="new-customer-title">
            <header class="im1-side-panel-header">
                <div>
                    <h2 id="new-customer-title">New Customer</h2>
                    <p>Create the shared CRM customer record.</p>
                </div>
                <a class="im1-dialog-close" asp-controller="Customers" asp-action="Index" aria-label="Close">X</a>
            </header>
            <div class="im1-side-panel-body">
                <form asp-action="Create" method="post" class="im1-form">
                    <div class="im1-form-grid">
                        <label>Display Name <input name="DisplayName" required /></label>
                        <label>Customer Type
                            <select name="CustomerType">
                                <option>Individual</option>
                                <option>Company</option>
                                <option>Fleet</option>
                            </select>
                        </label>
                        <label>First Name <input name="FirstName" /></label>
                        <label>Last Name <input name="LastName" /></label>
                        <label>Company <input name="CompanyName" /></label>
                        <label>Email <input name="Email" type="email" /></label>
                        <label>Phone <input name="Phone" /></label>
                        <label>Status
                            <select name="Status">
                                <option>Active</option>
                                <option>Prospect</option>
                                <option>Inactive</option>
                                <option>Do Not Contact</option>
                            </select>
                        </label>
                        <label>Lifecycle Stage <input name="LifecycleStage" /></label>
                        <label>Source <input name="Source" /></label>
                        <label>Preferred Contact Method
                            <select name="PreferredContactMethod">
                                <option value="">Not Set</option>
                                <option>Email</option>
                                <option>Phone</option>
                                <option>Text</option>
                                <option>Mail</option>
                            </select>
                        </label>
                    </div>
                    <div class="im1-form-actions">
                        <button class="im1-button im1-button-primary" type="submit">Create Customer</button>
                    </div>
                </form>
            </div>
        </aside>
    </div>
}
