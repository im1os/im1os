@model iM1os.Application.GlobalCatalog.SupplierItemSearchPage

@{
    ViewData["Title"] = "Item Search";
    var hero = new IM1WorkspaceHeroModel(
        "Item Search",
        "Suppliers / Catalog",
        "Search imported supplier items by SKU, manufacturer part number, title, or vehicle fitment.",
        new[]
        {
            new IM1WorkspaceStatModel("Results", Model.IsSearchExecuted ? Model.TotalResults.ToString() : "Ready", string.IsNullOrWhiteSpace(Model.Query) ? "Use text or YMM" : Model.Query),
            new IM1WorkspaceStatModel("Sources", "Supplier Catalog", "Global match included")
        },
        Array.Empty<IM1ActionModel>(),
        "Read-only supplier item lookup");

    static string FormatCurrency(decimal? value)
    {
        if (value is null)
        {
            return "-";
        }

        var amount = value.Value;
        var prefix = amount < 0 ? "-$" : "$";
        return $"{prefix}{Math.Abs(amount).ToString("N2", System.Globalization.CultureInfo.InvariantCulture)}";
    }

    static string FormatInventoryTotal(int? value, bool hasInventory)
    {
        return value is not null
            ? value.Value.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)
            : hasInventory ? "Available" : "-";
    }
}

<nav class="im1-breadcrumbs" aria-label="Breadcrumb">
    <span>Platform Suppliers</span>
    <span>Catalog</span>
    <span>Item Search</span>
</nav>

@await Html.PartialAsync("IM1WorkspaceHero", hero)

<section class="im1-settings-panel">
    <header class="im1-section-header">
        <div>
            <h2>Search Items</h2>
            <p>Find supplier catalog rows by supplier SKU, MFG part number, UPC, title, or year/make/model fitment.</p>
        </div>
    </header>
    <div class="im1-inline-action-bar">
        <strong>Configured suppliers</strong>
        @if (Model.ConfiguredSuppliers.Count == 0)
        {
            <span>No suppliers configured.</span>
        }
        else
        {
            @foreach (var supplier in Model.ConfiguredSuppliers)
            {
                <span class="im1-status-pill">@supplier.Code - @(supplier.IsEnabled ? "Enabled" : "Disabled")</span>
            }
        }
    </div>

    <form class="im1-item-search-form im1-item-search-form-ymm" asp-action="ItemSearch" method="get">
        <input type="hidden" name="searchExecuted" value="true" />
        <label class="im1-field im1-field-wide">
            <span>Search</span>
            <input name="query" value="@Model.Query" placeholder="SKU, MFG Part#, title, or UPC" autocomplete="off" />
        </label>
        <label class="im1-field">
            <span>Supplier</span>
            <select name="supplierCode">
                <option value="">All suppliers</option>
                @foreach (var supplier in Model.AvailableSuppliers)
                {
                    <option value="@supplier.Code" selected="@(string.Equals(Model.SupplierCode, supplier.Code, StringComparison.OrdinalIgnoreCase))">@supplier.Name</option>
                }
            </select>
        </label>
        <label class="im1-field">
            <span>Type</span>
            <select name="vehicleType" data-ymm-parent>
                <option value="">Any type</option>
                @foreach (var vehicleType in Model.AvailableVehicleTypes)
                {
                    <option value="@vehicleType" selected="@(string.Equals(Model.VehicleType, vehicleType, StringComparison.OrdinalIgnoreCase))">@vehicleType</option>
                }
            </select>
        </label>
        <label class="im1-field">
            <span>Year</span>
            <select name="year" data-ymm-parent>
                <option value="">Any year</option>
                @foreach (var year in Model.AvailableYears)
                {
                    <option value="@year" selected="@(Model.Year == year)">@year</option>
                }
            </select>
        </label>
        <label class="im1-field">
            <span>Make</span>
            <select name="make" data-ymm-parent disabled="@(Model.Year is null)">
                <option value="">Any make</option>
                @foreach (var make in Model.AvailableMakes)
                {
                    <option value="@make" selected="@(string.Equals(Model.Make, make, StringComparison.OrdinalIgnoreCase))">@make</option>
                }
            </select>
        </label>
        <label class="im1-field">
            <span>Model</span>
            <select name="model" disabled="@(Model.Year is null || string.IsNullOrWhiteSpace(Model.Make))">
                <option value="">Any model</option>
                @foreach (var vehicleModel in Model.AvailableModels)
                {
                    <option value="@vehicleModel" selected="@(string.Equals(Model.Model, vehicleModel, StringComparison.OrdinalIgnoreCase))">@vehicleModel</option>
                }
            </select>
        </label>
        <button class="im1-button im1-button-primary" type="submit">Search</button>
        <a class="im1-button im1-button-secondary" asp-action="ItemSearch">Reset</a>
    </form>
</section>

<section class="im1-settings-panel">
    @Html.AntiForgeryToken()
    <header class="im1-section-header">
        <div>
            <h2>Items</h2>
            <p>Read-only supplier catalog matches.</p>
        </div>
    </header>

    @if (!Model.IsSearchExecuted)
    {
        <p class="im1-empty-state">Enter a search, choose a supplier, or select a full year/make/model fitment, then run the search.</p>
    }
    else if (Model.Results.Count == 0)
    {
        <p class="im1-empty-state">No supplier items matched this search.</p>
    }
    else
    {
        <div class="im1-item-result-list"
             data-item-results
             data-results-url="@Url.Action("ItemSearchResults")"
             data-next-offset="@Model.TotalResults"
             data-has-more="@Model.HasMore.ToString().ToLowerInvariant()">
            @foreach (var item in Model.Results)
            {
                <article class="im1-item-result" data-item-result>
                    <div class="im1-item-result-media">
                        <div class="im1-item-result-image">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="" loading="lazy" referrerpolicy="no-referrer" />
                            }
                            else
                            {
                                <span>No Image</span>
                            }
                        </div>
                        @if ((item.Offers?.Count ?? 0) > 0)
                        {
                            <div class="im1-inventory-summary im1-inventory-summary-primary" aria-label="Inventory">
                                @foreach (var offer in item.Offers!)
                                {
                                    if (offer.SupplierCode == "WPS")
                                    {
                                        <span data-inventory-summary-code="@offer.SupplierCode" data-supplier-product-id="@offer.SupplierProductId" data-inventory-summary-url="@Url.Action("WpsInventory", new { supplierProductId = offer.SupplierProductId })">@offer.SupplierCode: @FormatInventoryTotal(offer.CachedInventoryTotal, offer.HasCachedInventory)</span>
                                    }
                                    else if (offer.SupplierCode == "TURN14")
                                    {
                                        <span data-inventory-summary-code="@offer.SupplierCode" data-supplier-product-id="@offer.SupplierProductId" data-inventory-summary-url="@Url.Action("Turn14Inventory", new { supplierProductId = offer.SupplierProductId })">@offer.SupplierCode: @FormatInventoryTotal(offer.CachedInventoryTotal, offer.HasCachedInventory)</span>
                                    }
                                    else if (offer.SupplierCode == "PU")
                                    {
                                        <span data-inventory-summary-code="@offer.SupplierCode" data-inventory-summary-batch-url="@Url.Action("PartsUnlimitedInventory")" data-supplier-product-id="@offer.SupplierProductId">@offer.SupplierCode: @FormatInventoryTotal(offer.CachedInventoryTotal, offer.HasCachedInventory)</span>
                                    }
                                    else
                                    {
                                        <span data-inventory-summary-code="@offer.SupplierCode">@offer.SupplierCode: @FormatInventoryTotal(offer.CachedInventoryTotal, offer.HasCachedInventory)</span>
                                    }
                                }
                            </div>
                        }
                    </div>
                    <div class="im1-item-result-body">
                        <div class="im1-item-result-title">
                            <strong>@item.Title</strong>
                            <span>@item.Brand</span>
                        </div>
                        <dl>
                            <div>
                                <dt>Supplier</dt>
                                <dd>@item.SupplierCode</dd>
                            </div>
                            <div>
                                <dt>SKU</dt>
                                <dd>@item.SupplierSku</dd>
                            </div>
                            <div>
                                <dt>MFG Part#</dt>
                                <dd>@(item.ManufacturerPartNumber ?? "-")</dd>
                            </div>
                            <div>
                                <dt>UPC</dt>
                                <dd>@(item.Upc ?? "-")</dd>
                            </div>
                            <div>
                                <dt>Status</dt>
                                <dd>@item.Status</dd>
                            </div>
                            <div>
                                <dt>Fitment</dt>
                                <dd class="im1-fitment-cell">
                                    <span>@item.FitmentRecordCount.ToString("N0") records</span>
                                    <button class="im1-fitment-refresh-button" type="button" title="Fetch fitment" aria-label="Fetch fitment for @item.SupplierSku" data-fetch-fitment-url="@Url.Action("FetchItemFitment", new { supplierProductId = item.SupplierProductId })">
                                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                            <path d="M17 1v5h-5"></path>
                                            <path d="M20 11a8 8 0 0 0-14.9-4"></path>
                                            <path d="M7 23v-5h5"></path>
                                            <path d="M4 13a8 8 0 0 0 14.9 4"></path>
                                        </svg>
                                    </button>
                                    <span class="im1-fitment-fetch-status" data-fitment-fetch-status></span>
                                </dd>
                            </div>
                            <div>
                                <dt>MSRP</dt>
                                <dd>@FormatCurrency(item.Msrp)</dd>
                            </div>
                            <div>
                                <dt>Category</dt>
                                <dd>@(item.Category ?? "-")</dd>
                            </div>
                        </dl>
                        @if ((item.Fitment?.Count ?? 0) > 0)
                        {
                            <details class="im1-fitment-popout">
                                <summary>Fitment (@item.Fitment!.Count.ToString("N0"))</summary>
                                <div class="im1-fitment-grid-wrap">
                                    <table class="im1-fitment-grid">
                                        <thead>
                                            <tr>
                                                <th>Year</th>
                                                <th>Make</th>
                                                <th>Model</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var fitment in item.Fitment!)
                                            {
                                                <tr>
                                                    <td>@fitment.Year</td>
                                                    <td>@fitment.Make</td>
                                                    <td>@fitment.Model</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </details>
                        }
                        @if ((item.Offers?.Count ?? 0) > 0)
                        {
                            <details class="im1-supplier-offers">
                                <summary>Supplier options (@item.Offers!.Count.ToString("N0"))</summary>
                                <div class="im1-supplier-offer-grid">
                                    @foreach (var offer in item.Offers!)
                                    {
                                        <article class="im1-supplier-offer @(offer.IsDefaultOffer ? "im1-supplier-offer-selected" : string.Empty)" data-offer-row data-offer-supplier-product-id="@offer.SupplierProductId" data-offer-cost="@(offer.ActualCost ?? offer.DealerCost ?? decimal.MaxValue)" data-has-inventory="@offer.HasCachedInventory.ToString().ToLowerInvariant()">
                                            <header>
                                                <strong>@offer.SupplierName</strong>
                                                <span>@(offer.IsDefaultOffer ? "Selected" : "Option")</span>
                                            </header>
                                            <dl>
                                                <div><dt>SKU</dt><dd>@offer.SupplierSku</dd></div>
                                                <div><dt>MFG Part#</dt><dd>@(offer.ManufacturerPartNumber ?? "-")</dd></div>
                                                <div><dt>Retail</dt><dd>@FormatCurrency(offer.Msrp)</dd></div>
                                            </dl>
                                            @if (offer.SupplierCode == "WPS")
                                            {
                                                <section class="im1-live-inventory" data-supplier-code="@offer.SupplierCode" data-supplier-product-id="@offer.SupplierProductId" data-inventory-url="@Url.Action("WpsInventory", new { supplierProductId = offer.SupplierProductId })">
                                                    <header><strong>WPS Warehouses</strong><span>Loading live inventory...</span></header>
                                                    <div class="im1-live-inventory-grid"></div>
                                                </section>
                                            }
                                            @if (offer.SupplierCode == "TURN14")
                                            {
                                                <section class="im1-live-inventory" data-supplier-code="@offer.SupplierCode" data-supplier-product-id="@offer.SupplierProductId" data-inventory-url="@Url.Action("Turn14Inventory", new { supplierProductId = offer.SupplierProductId })">
                                                    <header><strong>Turn14 Warehouses</strong><span>Loading live inventory...</span></header>
                                                    <div class="im1-live-inventory-grid"></div>
                                                </section>
                                            }
                                            @if (offer.SupplierCode == "PU")
                                            {
                                                <section class="im1-live-inventory" data-supplier-code="@offer.SupplierCode" data-inventory-batch-url="@Url.Action("PartsUnlimitedInventory")" data-supplier-product-id="@offer.SupplierProductId">
                                                    <header><strong>Parts Unlimited Warehouses</strong><span>Loading live inventory...</span></header>
                                                    <div class="im1-live-inventory-grid"></div>
                                                </section>
                                            }
                                        </article>
                                    }
                                </div>
                            </details>
                        }
                    </div>
                </article>
            }
        </div>
        <div class="im1-infinite-scroll-status" data-scroll-status>
            @(Model.HasMore ? "Load more items" : "All loaded items are shown.")
        </div>
    }
</section>

@section Scripts {
    <script>
        (() => {
            const searchForm = document.querySelector(".im1-item-search-form-ymm");
            if (searchForm) {
                const vehicleType = searchForm.querySelector("[name='vehicleType']");
                const year = searchForm.querySelector("[name='year']");
                const make = searchForm.querySelector("[name='make']");
                const model = searchForm.querySelector("[name='model']");
                vehicleType?.addEventListener("change", () => {
                    if (year) year.value = "";
                    if (make) make.value = "";
                    if (model) model.value = "";
                    searchForm.submit();
                });
                year?.addEventListener("change", () => {
                    if (make) make.value = "";
                    if (model) model.value = "";
                    searchForm.submit();
                });
                make?.addEventListener("change", () => {
                    if (model) model.value = "";
                    searchForm.submit();
                });
            }

            const formatCurrency = (value) => {
                if (value === null || value === undefined) return "-";
                const amount = Number(value);
                if (!Number.isFinite(amount)) return "-";
                return `${amount < 0 ? "-$" : "$"}${Math.abs(amount).toFixed(2)}`;
            };
            const valueOrDash = (value) => value === null || value === undefined || value === "" ? "-" : value;
            const formatInventoryTotal = (offer) => offer?.cachedInventoryTotal !== null && offer?.cachedInventoryTotal !== undefined
                ? Number(offer.cachedInventoryTotal).toLocaleString()
                : offer?.hasCachedInventory ? "Available" : "-";
            const cleanWarehouseName = (warehouse) => (warehouse.warehouseName || warehouse.warehouseCode || "Warehouse")
                .replace(/\s+Warehouse$/i, "");
            const inventoryPanelTitle = (item) => (item.inventoryLabel || "Warehouses")
                .replace(/\s+Warehouse Inventory$/i, " Warehouses");
            const inventoryTotalFromWarehouses = (warehouses) => {
                if (!(warehouses || []).length) return "-";
                let total = 0;
                let hasNumber = false;
                let hasPlus = false;
                for (const warehouse of warehouses || []) {
                    if (Number.isFinite(Number(warehouse.quantity))) {
                        total += Number(warehouse.quantity);
                        hasNumber = true;
                        continue;
                    }

                    const display = warehouse.quantityDisplay || "";
                    const match = display.match(/\d+/);
                    if (match) {
                        total += Number(match[0]);
                        hasNumber = true;
                        hasPlus = hasPlus || display.includes("+");
                    }
                }

                return hasNumber ? `${total.toLocaleString()}${hasPlus ? "+" : ""}` : "Available";
            };
            const hasInventoryFromWarehouses = (warehouses) => {
                let hasWarehouse = false;
                for (const warehouse of warehouses || []) {
                    hasWarehouse = true;
                    if (Number.isFinite(Number(warehouse.quantity))) {
                        if (Number(warehouse.quantity) > 0) return true;
                        continue;
                    }

                    const display = warehouse.quantityDisplay || "";
                    const match = display.match(/\d+/);
                    if (match && Number(match[0]) > 0) return true;
                    if (!match && /available|in stock/i.test(display)) return true;
                }

                return hasWarehouse && !(warehouses || []).some((warehouse) => Number(warehouse.quantity) === 0 || /^0$/.test(warehouse.quantityDisplay || ""));
            };
            const selectLeastCostInStockOffer = (item) => {
                const rows = [...(item?.querySelectorAll("[data-offer-row]") || [])];
                if (!rows.length) return;
                const inStockRows = rows.filter((row) => row.dataset.hasInventory === "true");
                const candidates = inStockRows.length ? inStockRows : rows;
                const selected = candidates
                    .map((row) => ({ row, cost: Number(row.dataset.offerCost) }))
                    .sort((a, b) => (Number.isFinite(a.cost) ? a.cost : Number.MAX_VALUE) - (Number.isFinite(b.cost) ? b.cost : Number.MAX_VALUE))[0]?.row;
                if (!selected) return;
                rows.forEach((row) => {
                    const isSelected = row === selected;
                    row.classList.toggle("im1-supplier-offer-selected", isSelected);
                    const status = row.querySelector("header span");
                    if (status) status.textContent = isSelected ? "Lowest in stock" : "Option";
                });
            };
            const updateOfferInventoryState = (source, result) => {
                const supplierProductId = source.dataset.supplierProductId;
                const item = source.closest("[data-item-result]");
                if (!supplierProductId || !item || !result?.isAvailable) return;
                const row = item.querySelector(`[data-offer-supplier-product-id="${supplierProductId}"]`);
                if (!row) return;
                row.dataset.hasInventory = hasInventoryFromWarehouses(result.warehouses || []) ? "true" : "false";
                selectLeastCostInStockOffer(item);
            };
            const updateInventorySummary = (panel, warehouses) => {
                const supplierCode = panel.dataset.supplierCode;
                if (!supplierCode) return;
                const item = panel.closest("[data-item-result]");
                const summary = item?.querySelector(`[data-inventory-summary-code="${supplierCode}"]`);
                if (summary) summary.textContent = `${supplierCode}: ${inventoryTotalFromWarehouses(warehouses)}`;
            };
            const renderInventorySummaryResult = (summary, result) => {
                const supplierCode = summary.dataset.inventorySummaryCode;
                if (!supplierCode || !result?.isAvailable) return;
                summary.textContent = `${supplierCode}: ${inventoryTotalFromWarehouses(result.warehouses || [])}`;
                updateOfferInventoryState(summary, result);
            };
            const loadInventorySummaries = async (scope = document) => {
                const singleSummaries = [...scope.querySelectorAll("[data-inventory-summary-url]")]
                    .filter((summary) => summary.dataset.inventorySummaryLoaded !== "true");
                for (const summary of singleSummaries) {
                    summary.dataset.inventorySummaryLoaded = "true";
                    const cached = inventoryResultCache.get(summary.dataset.inventorySummaryUrl);
                    if (cached) {
                        renderInventorySummaryResult(summary, cached);
                        continue;
                    }

                    try {
                        const response = await fetch(summary.dataset.inventorySummaryUrl, {
                            credentials: "same-origin",
                            headers: { "Accept": "application/json" }
                        });
                        if (response.ok) {
                            const result = await response.json();
                            inventoryResultCache.set(summary.dataset.inventorySummaryUrl, result);
                            renderInventorySummaryResult(summary, result);
                        }
                    } catch {
                    }
                    await delay(125);
                }

                const batchSummaries = [...scope.querySelectorAll("[data-inventory-summary-batch-url]")]
                    .filter((summary) => summary.dataset.inventorySummaryLoaded !== "true");
                const summariesByUrl = new Map();
                batchSummaries.forEach((summary) => {
                    const url = summary.dataset.inventorySummaryBatchUrl;
                    if (!url) return;
                    const cached = inventoryResultCache.get(batchInventoryCacheKey(url, summary.dataset.supplierProductId));
                    if (cached) {
                        summary.dataset.inventorySummaryLoaded = "true";
                        renderInventorySummaryResult(summary, cached);
                        return;
                    }

                    if (!summariesByUrl.has(url)) summariesByUrl.set(url, []);
                    summariesByUrl.get(url).push(summary);
                });

                for (const [batchUrl, summaries] of summariesByUrl) {
                    for (let index = 0; index < summaries.length; index += 25) {
                        const chunk = summaries.slice(index, index + 25);
                        const url = new URL(batchUrl, window.location.origin);
                        chunk.forEach((summary) => {
                            summary.dataset.inventorySummaryLoaded = "true";
                            url.searchParams.append("supplierProductIds", summary.dataset.supplierProductId);
                        });

                        try {
                            const response = await fetch(url.toString(), {
                                credentials: "same-origin",
                                headers: { "Accept": "application/json" }
                            });
                            if (response.ok) {
                                const result = await response.json();
                                const items = new Map((result.items || []).map((item) => [item.supplierProductId, item]));
                                chunk.forEach((summary) => {
                                    const item = items.get(summary.dataset.supplierProductId);
                                    if (item) {
                                        inventoryResultCache.set(batchInventoryCacheKey(batchUrl, summary.dataset.supplierProductId), item);
                                        renderInventorySummaryResult(summary, item);
                                    }
                                });
                            }
                        } catch {
                        }

                        await delay(125);
                    }
                }
            };
            const delay = (milliseconds) => new Promise((resolve) => window.setTimeout(resolve, milliseconds));
            const inventoryResultCache = new Map();
            const batchInventoryCacheKey = (batchUrl, supplierProductId) => `${batchUrl || ""}::${supplierProductId || ""}`;
            const antiForgeryToken = document.querySelector("input[name='__RequestVerificationToken']")?.value || "";
            const wireFitmentButtons = (scope = document) => {
                scope.querySelectorAll("[data-fetch-fitment-url]").forEach((button) => {
                    if (button.dataset.fitmentButtonWired === "true") return;
                    button.dataset.fitmentButtonWired = "true";
                    button.addEventListener("click", async () => {
                        const status = button.parentElement?.querySelector("[data-fitment-fetch-status]");
                        button.disabled = true;
                        if (status) status.textContent = "Queueing...";
                        try {
                            const response = await fetch(button.dataset.fetchFitmentUrl, {
                                method: "POST",
                                credentials: "same-origin",
                                headers: {
                                    "Accept": "application/json",
                                    "RequestVerificationToken": antiForgeryToken
                                }
                            });
                            if (!response.ok) {
                                if (status) status.textContent = `Could not queue fitment (${response.status}).`;
                                return;
                            }

                            const result = await response.json();
                            if (status) status.textContent = result.message || (result.queued ? "Fitment queued." : "Could not queue fitment.");
                        } catch {
                            if (status) status.textContent = "Could not queue fitment.";
                        } finally {
                            button.disabled = false;
                        }
                    });
                });
            };
            const renderInventoryResult = (panel, result, emptyMessage) => {
                const status = panel.querySelector("header span");
                const grid = panel.querySelector(".im1-live-inventory-grid");
                if (!result?.isAvailable) {
                    status.textContent = result?.message || "Inventory unavailable.";
                    return;
                }

                const warehouses = result.warehouses || [];
                if (warehouses.length === 0) {
                    status.textContent = result.message || emptyMessage;
                    updateOfferInventoryState(panel, result);
                    return;
                }

                status.textContent = result.message || "Live";
                updateInventorySummary(panel, warehouses);
                updateOfferInventoryState(panel, result);
                grid.replaceChildren(...warehouses.map((warehouse) => {
                    const row = document.createElement("div");
                    row.className = "im1-live-inventory-row";

                    const label = document.createElement("span");
                    label.textContent = `${cleanWarehouseName(warehouse)}:`;

                    const quantity = document.createElement("strong");
                    quantity.textContent = warehouse.quantityDisplay || "-";

                    row.append(label, quantity);
                    return row;
                }));
            };
            const loadInventory = async (panel) => {
                if (!panel || panel.dataset.inventoryLoaded === "true") return;
                panel.dataset.inventoryLoaded = "true";
                const status = panel.querySelector("header span");
                const cached = inventoryResultCache.get(panel.dataset.inventoryUrl);
                if (cached) {
                    renderInventoryResult(panel, cached, "No warehouse inventory returned.");
                    return;
                }

                try {
                    const response = await fetch(panel.dataset.inventoryUrl, {
                        credentials: "same-origin",
                        headers: { "Accept": "application/json" }
                    });
                    if (!response.ok) {
                        status.textContent = `Inventory unavailable (${response.status}).`;
                        return;
                    }

                    const result = await response.json();
                    inventoryResultCache.set(panel.dataset.inventoryUrl, result);
                    renderInventoryResult(panel, result, "No warehouse inventory returned.");
                } catch {
                    status.textContent = "Inventory unavailable.";
                }
            };
            const loadPartsUnlimitedInventoryPanels = async (scope = document) => {
                const panels = [...scope.querySelectorAll("[data-inventory-batch-url]")]
                    .filter((panel) => panel.dataset.inventoryLoaded !== "true" && !panel.closest(".im1-supplier-offers:not([open])"))
                    .filter((panel) => {
                        const cached = inventoryResultCache.get(batchInventoryCacheKey(panel.dataset.inventoryBatchUrl, panel.dataset.supplierProductId));
                        if (!cached) return true;
                        panel.dataset.inventoryLoaded = "true";
                        renderInventoryResult(panel, cached, "No Parts Unlimited warehouse inventory returned.");
                        return false;
                    });
                const panelsByUrl = new Map();
                panels.forEach((panel) => {
                    const url = panel.dataset.inventoryBatchUrl;
                    if (!url) return;
                    if (!panelsByUrl.has(url)) panelsByUrl.set(url, []);
                    panelsByUrl.get(url).push(panel);
                });

                for (const [batchUrl, batchPanels] of panelsByUrl) {
                    for (let index = 0; index < batchPanels.length; index += 25) {
                        const chunk = batchPanels.slice(index, index + 25);
                        const url = new URL(batchUrl, window.location.origin);
                        chunk.forEach((panel) => {
                            panel.dataset.inventoryLoaded = "true";
                            url.searchParams.append("supplierProductIds", panel.dataset.supplierProductId);
                        });

                        try {
                            const response = await fetch(url.toString(), {
                                credentials: "same-origin",
                                headers: { "Accept": "application/json" }
                            });
                            if (!response.ok) {
                                chunk.forEach((panel) => {
                                    panel.querySelector("header span").textContent = `Inventory unavailable (${response.status}).`;
                                });
                                continue;
                            }

                            const result = await response.json();
                            const items = new Map((result.items || []).map((item) => [item.supplierProductId, item]));
                            chunk.forEach((panel) => {
                                const item = items.get(panel.dataset.supplierProductId);
                                if (item) {
                                    inventoryResultCache.set(batchInventoryCacheKey(batchUrl, panel.dataset.supplierProductId), item);
                                    renderInventoryResult(panel, item, "No Parts Unlimited warehouse inventory returned.");
                                } else {
                                    panel.querySelector("header span").textContent = result.message || "Inventory unavailable.";
                                }
                            });
                        } catch {
                            chunk.forEach((panel) => {
                                panel.querySelector("header span").textContent = "Inventory unavailable.";
                            });
                        }

                        await delay(250);
                    }
                }
            };
            const loadInventoryPanels = async (scope = document) => {
                await loadInventorySummaries(scope);
                await loadPartsUnlimitedInventoryPanels(scope);
                const inventoryPanels = [...scope.querySelectorAll("[data-inventory-url]")]
                    .filter((panel) => !panel.closest(".im1-supplier-offers:not([open])"));
                for (const panel of inventoryPanels) {
                    await loadInventory(panel);
                    await delay(250);
                }
            };
            const wireSupplierOfferDetails = (scope = document) => {
                scope.querySelectorAll(".im1-supplier-offers").forEach((details) => {
                    if (details.dataset.supplierOffersWired === "true") return;
                    details.dataset.supplierOffersWired = "true";
                    details.addEventListener("toggle", () => {
                        if (details.open) loadInventoryPanels(details);
                    });
                });
            };
            const createMetric = (label, value) => {
                const wrapper = document.createElement("div");
                const term = document.createElement("dt");
                const description = document.createElement("dd");
                term.textContent = label;
                if (value instanceof Node) {
                    description.append(value);
                } else {
                    description.textContent = value;
                }
                wrapper.append(term, description);
                return wrapper;
            };
            const createFitmentValue = (item) => {
                const wrapper = document.createElement("span");
                wrapper.className = "im1-fitment-cell";
                const count = document.createElement("span");
                const fitmentCount = item.fitmentRecordCount?.toLocaleString?.() ?? item.fitmentRecordCount ?? 0;
                count.textContent = `${fitmentCount} records`;
                wrapper.append(count);
                if (item.fetchFitmentUrl) {
                    const fitmentButton = document.createElement("button");
                    fitmentButton.className = "im1-fitment-refresh-button";
                    fitmentButton.type = "button";
                    fitmentButton.title = "Fetch fitment";
                    fitmentButton.setAttribute("aria-label", `Fetch fitment for ${item.supplierSku || "this item"}`);
                    fitmentButton.dataset.fetchFitmentUrl = item.fetchFitmentUrl;
                    fitmentButton.innerHTML = '<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M17 1v5h-5"></path><path d="M20 11a8 8 0 0 0-14.9-4"></path><path d="M7 23v-5h5"></path><path d="M4 13a8 8 0 0 0 14.9 4"></path></svg>';
                    const fitmentStatus = document.createElement("span");
                    fitmentStatus.className = "im1-fitment-fetch-status";
                    fitmentStatus.dataset.fitmentFetchStatus = "";
                    wrapper.append(fitmentButton, fitmentStatus);
                }
                return wrapper;
            };
            const createFitmentPopout = (item) => {
                const fitmentRows = item.fitment || [];
                if (!fitmentRows.length) return null;
                const details = document.createElement("details");
                details.className = "im1-fitment-popout";
                const summary = document.createElement("summary");
                summary.textContent = `Fitment (${fitmentRows.length.toLocaleString()})`;
                const wrapper = document.createElement("div");
                wrapper.className = "im1-fitment-grid-wrap";
                const table = document.createElement("table");
                table.className = "im1-fitment-grid";
                const thead = document.createElement("thead");
                const headerRow = document.createElement("tr");
                ["Year", "Make", "Model"].forEach((label) => {
                    const cell = document.createElement("th");
                    cell.textContent = label;
                    headerRow.append(cell);
                });
                thead.append(headerRow);
                const tbody = document.createElement("tbody");
                fitmentRows.forEach((fitment) => {
                    const row = document.createElement("tr");
                    [
                        fitment.year,
                        fitment.make,
                        fitment.model
                    ].forEach((value) => {
                        const cell = document.createElement("td");
                        cell.textContent = valueOrDash(value);
                        row.append(cell);
                    });
                    tbody.append(row);
                });
                table.append(thead, tbody);
                wrapper.append(table);
                details.append(summary, wrapper);
                return details;
            };
            const createInventoryPanel = (item) => {
                if ((!item.inventoryUrl && !item.inventoryBatchUrl) || !item.inventoryLabel) return null;
                const section = document.createElement("section");
                section.className = "im1-live-inventory";
                if (item.supplierCode) section.dataset.supplierCode = item.supplierCode;
                if (item.supplierProductId) section.dataset.supplierProductId = item.supplierProductId;
                if (item.inventoryUrl) section.dataset.inventoryUrl = item.inventoryUrl;
                if (item.inventoryBatchUrl) {
                    section.dataset.inventoryBatchUrl = item.inventoryBatchUrl;
                    section.dataset.supplierProductId = item.supplierProductId;
                }
                const header = document.createElement("header");
                const title = document.createElement("strong");
                const status = document.createElement("span");
                title.textContent = inventoryPanelTitle(item);
                status.textContent = "Loading live inventory...";
                header.append(title, status);
                const grid = document.createElement("div");
                grid.className = "im1-live-inventory-grid";
                section.append(header, grid);
                return section;
            };
            const createInventorySummary = (offers) => {
                if (!offers.length) return null;
                const summary = document.createElement("div");
                summary.className = "im1-inventory-summary im1-inventory-summary-primary";
                summary.setAttribute("aria-label", "Inventory");
                offers.forEach((offer) => {
                    const value = document.createElement("span");
                    value.dataset.inventorySummaryCode = offer.supplierCode || "";
                    if (offer.supplierProductId) value.dataset.supplierProductId = offer.supplierProductId;
                    if (offer.inventoryUrl) value.dataset.inventorySummaryUrl = offer.inventoryUrl;
                    if (offer.inventoryBatchUrl) {
                        value.dataset.inventorySummaryBatchUrl = offer.inventoryBatchUrl;
                        value.dataset.supplierProductId = offer.supplierProductId;
                    }
                    value.textContent = `${offer.supplierCode}: ${formatInventoryTotal(offer)}`;
                    summary.append(value);
                });
                return summary;
            };
            const createSupplierOffers = (item) => {
                const offers = item.offers || [];
                if (offers.length === 0) return null;
                const details = document.createElement("details");
                details.className = "im1-supplier-offers";
                const summary = document.createElement("summary");
                summary.textContent = `Supplier options (${offers.length.toLocaleString()})`;
                const grid = document.createElement("div");
                grid.className = "im1-supplier-offer-grid";
                offers.forEach((offer) => {
                    const row = document.createElement("article");
                    row.className = `im1-supplier-offer${offer.isDefaultOffer ? " im1-supplier-offer-selected" : ""}`;
                    row.dataset.offerRow = "";
                    row.dataset.offerSupplierProductId = offer.supplierProductId || "";
                    row.dataset.offerCost = String(offer.actualCost ?? offer.dealerCost ?? Number.MAX_VALUE);
                    row.dataset.hasInventory = offer.hasCachedInventory ? "true" : "false";
                    const header = document.createElement("header");
                    const supplier = document.createElement("strong");
                    const status = document.createElement("span");
                    supplier.textContent = offer.supplierName || offer.supplierCode || "-";
                    status.textContent = offer.isDefaultOffer ? "Selected" : "Option";
                    header.append(supplier, status);
                    const metrics = document.createElement("dl");
                    metrics.append(
                        createMetric("SKU", offer.supplierSku || "-"),
                        createMetric("MFG Part#", valueOrDash(offer.manufacturerPartNumber)),
                        createMetric("Retail", formatCurrency(offer.msrp)));
                    row.append(header, metrics);
                    const inventory = createInventoryPanel(offer);
                    if (inventory) row.append(inventory);
                    grid.append(row);
                });
                details.append(summary, grid);
                return details;
            };
            const createItemResult = (item) => {
                const article = document.createElement("article");
                article.className = "im1-item-result";
                article.dataset.itemResult = "";

                const media = document.createElement("div");
                media.className = "im1-item-result-media";
                const image = document.createElement("div");
                image.className = "im1-item-result-image";
                if (item.imageUrl) {
                    const img = document.createElement("img");
                    img.src = item.imageUrl;
                    img.alt = "";
                    img.loading = "lazy";
                    img.referrerPolicy = "no-referrer";
                    image.append(img);
                } else {
                    const placeholder = document.createElement("span");
                    placeholder.textContent = "No Image";
                    image.append(placeholder);
                }
                media.append(image);

                const body = document.createElement("div");
                body.className = "im1-item-result-body";
                const heading = document.createElement("div");
                heading.className = "im1-item-result-title";
                const title = document.createElement("strong");
                const brand = document.createElement("span");
                title.textContent = item.title || "-";
                brand.textContent = item.brand || "";
                heading.append(title, brand);

                const metrics = document.createElement("dl");
                metrics.append(
                    createMetric("Supplier", item.supplierCode),
                    createMetric("SKU", item.supplierSku),
                    createMetric("MFG Part#", valueOrDash(item.manufacturerPartNumber)),
                    createMetric("UPC", valueOrDash(item.upc)),
                    createMetric("Status", valueOrDash(item.status)),
                    createMetric("Fitment", createFitmentValue(item)),
                    createMetric("MSRP", formatCurrency(item.msrp)),
                    createMetric("Category", valueOrDash(item.category)));
                const offers = item.offers || [];
                const inventorySummary = createInventorySummary(offers);
                if (inventorySummary) media.append(inventorySummary);
                body.append(heading, metrics);
                const fitmentPopout = createFitmentPopout(item);
                if (fitmentPopout) body.append(fitmentPopout);
                const supplierOffers = createSupplierOffers(item);
                if (supplierOffers) body.append(supplierOffers);
                article.append(media, body);
                return article;
            };
            const resultList = document.querySelector("[data-item-results]");
            const scrollStatus = document.querySelector("[data-scroll-status]");
            let loadingResults = false;
            const loadMoreResults = async () => {
                if (!resultList || loadingResults || resultList.dataset.hasMore !== "true") return;
                loadingResults = true;
                if (scrollStatus) scrollStatus.textContent = "Loading more items...";
                const params = new URLSearchParams(window.location.search);
                params.set("offset", resultList.dataset.nextOffset || "0");
                try {
                    const response = await fetch(`${resultList.dataset.resultsUrl}?${params.toString()}`, {
                        credentials: "same-origin",
                        headers: { "Accept": "application/json" }
                    });
                    if (!response.ok) {
                        if (scrollStatus) scrollStatus.textContent = `Could not load more items (${response.status}).`;
                        return;
                    }

                    const page = await response.json();
                    const items = page.results || [];
                    const fragment = document.createDocumentFragment();
                    items.forEach((item) => fragment.append(createItemResult(item)));
                    resultList.append(fragment);
                    wireFitmentButtons(resultList);
                    wireSupplierOfferDetails(resultList);
                    resultList.dataset.nextOffset = page.nextOffset?.toString() || resultList.dataset.nextOffset;
                    resultList.dataset.hasMore = page.hasMore ? "true" : "false";
                    if (scrollStatus) scrollStatus.textContent = page.hasMore ? "Load more items" : "All loaded items are shown.";
                    await loadInventoryPanels(resultList);
                } catch {
                    if (scrollStatus) scrollStatus.textContent = "Could not load more items.";
                } finally {
                    loadingResults = false;
                }
            };
            if (scrollStatus && resultList?.dataset.hasMore === "true" && "IntersectionObserver" in window) {
                const observer = new IntersectionObserver((entries) => {
                    if (entries.some((entry) => entry.isIntersecting)) {
                        loadMoreResults();
                    }
                }, { rootMargin: "600px" });
                observer.observe(scrollStatus);
            }
            scrollStatus?.addEventListener("click", loadMoreResults);
            wireFitmentButtons();
            wireSupplierOfferDetails();
            loadInventoryPanels();
        })();
    </script>
}
