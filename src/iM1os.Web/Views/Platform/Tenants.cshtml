@model IReadOnlyCollection<iM1os.Application.Platform.TenantManagerRow>

@{
    ViewData["Title"] = "Company Manager";
    var activeCount = Model.Count(x => x.Status == "Active");
    var trialCount = Model.Count(x => x.Status == "Trial");
    var suspendedCount = Model.Count(x => x.Status == "Suspended");
    var hero = new IM1WorkspaceHeroModel(
        "IM1OS Companies",
        "Company manager",
        "Review company health, billing state, provisioning status, and open the company workspace when support is needed.",
        new[]
        {
            new IM1WorkspaceStatModel("Companies", Model.Count.ToString(), "Visible records"),
            new IM1WorkspaceStatModel("Active", activeCount.ToString(), "Operational"),
            new IM1WorkspaceStatModel("Trials", trialCount.ToString(), "Evaluating"),
            new IM1WorkspaceStatModel("Suspended", suspendedCount.ToString(), "Needs attention")
        },
        new[] { new IM1ActionModel("Create Company", Url.Action("CreateTenant"), "primary") },
        suspendedCount > 0 ? $"{suspendedCount} companies need review" : "No suspended companies");
}

@await Html.PartialAsync("IM1WorkspaceHero", hero)

<form method="get" class="toolbar">
    <input name="query" value="@ViewData["Query"]" placeholder="Search companies" />
    <select name="status">
        <option value="">All statuses</option>
        <option value="Trial">Trial</option>
        <option value="Active">Active</option>
        <option value="Suspended">Suspended</option>
    </select>
    <button class="secondary-action" type="submit">Search</button>
</form>

<section class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Company</th>
                <th>Status</th>
                <th>Plan</th>
                <th>Version</th>
                <th>Users</th>
                <th>Locations</th>
                <th>Trial Ends</th>
                <th>Billing</th>
                <th>Health</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tenant in Model)
            {
                var tenantUrl = Url.Action("Tenant", new { organizationId = tenant.OrganizationId });
                <tr data-row-url="@tenantUrl" tabindex="0">
                    <td><a asp-action="Tenant" asp-route-organizationId="@tenant.OrganizationId">@tenant.OrganizationName</a></td>
                    <td>@tenant.Status</td>
                    <td>@tenant.SubscriptionPlan</td>
                    <td>@tenant.CurrentVersion</td>
                    <td>@tenant.ActiveUsers</td>
                    <td>@tenant.Locations</td>
                    <td>@(tenant.TrialExpiresAtUtc?.ToString("yyyy-MM-dd") ?? "-")</td>
                    <td>@tenant.BillingStatus</td>
                    <td>@tenant.HealthStatus</td>
                </tr>
            }
        </tbody>
    </table>
</section>
