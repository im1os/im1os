@model iM1os.Application.Platform.PlatformDashboardSummary

@{
    ViewData["Title"] = "Platform Dashboard";
    var hero = new IM1WorkspaceHeroModel(
        "IM1 Platform",
        "SaaS control plane",
        "Provision companies, monitor health, and manage platform-level operational exceptions.",
        new[]
        {
            new IM1WorkspaceStatModel("Total Companies", Model.TotalTenants.ToString(), "All provisioned companies"),
            new IM1WorkspaceStatModel("Active", Model.ActiveTenants.ToString(), "Currently active"),
            new IM1WorkspaceStatModel("Trials", Model.TrialTenants.ToString(), "Trial companies"),
            new IM1WorkspaceStatModel("Suspended", Model.SuspendedTenants.ToString(), "Needs attention")
        },
        new[]
        {
            new IM1ActionModel("Create Company", Url.Action("CreateTenant"), "primary"),
            new IM1ActionModel("Company Manager", Url.Action("Tenants"), "secondary"),
            new IM1ActionModel("Operations", Url.Action("Operations"), "secondary")
        },
        Model.SuspendedTenants > 0 ? $"{Model.SuspendedTenants} suspended companies" : "Platform healthy");
}

@await Html.PartialAsync("IM1WorkspaceHero", hero)

<section class="im1-workspace-grid">
    <article class="im1-workspace-card span-6">
        <header class="im1-section-header"><div><h2>Recent Provisioning</h2><p>Newest company lifecycle events.</p></div></header>
        <ul class="event-list">
            @foreach (var item in Model.RecentProvisioningActivity)
            {
                <li>@item</li>
            }
        </ul>
    </article>
    <article class="im1-workspace-card span-6">
        <header class="im1-section-header"><div><h2>Latest Platform Events</h2><p>Operational events that may need review.</p></div></header>
        <ul class="event-list">
            @foreach (var item in Model.LatestPlatformEvents)
            {
                <li>@item</li>
            }
        </ul>
    </article>
</section>
