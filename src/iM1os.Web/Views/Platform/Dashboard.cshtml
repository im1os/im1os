@model iM1os.Application.Platform.PlatformDashboardSummary

@{
    ViewData["Title"] = "Platform Dashboard";
}

<section class="dashboard-header">
    <div class="platform-title">
        <p class="eyebrow">SaaS control plane</p>
        <h1>IM1 Platform</h1>
        <p class="subtle">Provision and manage IM1OS companies from the platform control plane.</p>
    </div>
    <a class="primary-action" asp-action="CreateTenant">Create New IM1OS Company</a>
</section>

<section class="metric-grid" aria-label="Company status">
    <article><span>Total Companies</span><strong>@Model.TotalTenants</strong><p>All provisioned companies.</p></article>
    <article><span>Trial Companies</span><strong>@Model.TrialTenants</strong><p>Companies currently in trial.</p></article>
    <article><span>Active Companies</span><strong>@Model.ActiveTenants</strong><p>Companies currently active.</p></article>
    <article><span>Suspended</span><strong>@Model.SuspendedTenants</strong><p>Companies requiring attention.</p></article>
</section>

<section class="split-grid">
    <article class="page-band">
        <h2>Recent Provisioning Activity</h2>
        <ul class="event-list">
            @foreach (var item in Model.RecentProvisioningActivity)
            {
                <li>@item</li>
            }
        </ul>
    </article>
    <article class="page-band">
        <h2>Latest Platform Events</h2>
        <ul class="event-list">
            @foreach (var item in Model.LatestPlatformEvents)
            {
                <li>@item</li>
            }
        </ul>
    </article>
</section>
