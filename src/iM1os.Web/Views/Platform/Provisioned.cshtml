@model iM1os.Application.Platform.TenantManagerDetail

@{
    ViewData["Title"] = "Company Provisioned";
    var hero = new IM1WorkspaceHeroModel(
        $"{Model.Tenant.OrganizationName} is ready",
        "Provisioning complete",
        "The company foundation is created and ready for owner onboarding.",
        new[]
        {
            new IM1WorkspaceStatModel("Company", "Created", "Organization record"),
            new IM1WorkspaceStatModel("Owner", Model.OwnerActivated ? "Activated" : "Pending", "Initial access"),
            new IM1WorkspaceStatModel("Location", "Created", "Default shop"),
            new IM1WorkspaceStatModel("Modules", Model.ModulesEnabled.Count.ToString(), "Enabled")
        },
        new[]
        {
            new IM1ActionModel("Open Company Details", Url.Action("Tenant", new { organizationId = Model.Tenant.OrganizationId }), "primary"),
            new IM1ActionModel("Open IM1OS", Url.Action("Index", "Dashboard"), "secondary")
        },
        "Ready");
}

@await Html.PartialAsync("IM1WorkspaceHero", hero)

<section class="im1-workspace-card">
    <header class="im1-section-header"><div><h2>Provisioning Checklist</h2><p>Foundation tasks completed for the new company.</p></div></header>
    <ul class="check-list">
        <li>Company Created</li>
        <li>Owner Created</li>
        <li>Default Location Created</li>
        <li>Modules Enabled</li>
        <li>Welcome Email Sent</li>
    </ul>
</section>
