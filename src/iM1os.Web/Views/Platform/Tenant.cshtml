@model iM1os.Application.Platform.TenantManagerDetail

@{
    ViewData["Title"] = Model.Tenant.OrganizationName;
    var hero = new IM1WorkspaceHeroModel(
        Model.Tenant.OrganizationName,
        "Company workspace",
        $"{Model.Tenant.Status} company on {Model.Tenant.SubscriptionPlan}. Health: {Model.Tenant.HealthStatus}.",
        new[]
        {
            new IM1WorkspaceStatModel("Users", Model.Tenant.ActiveUsers.ToString(), "Active company users"),
            new IM1WorkspaceStatModel("Locations", Model.Tenant.Locations.ToString(), "Provisioned locations"),
            new IM1WorkspaceStatModel("Billing", Model.Tenant.BillingStatus, "Current billing state"),
            new IM1WorkspaceStatModel("Version", Model.Tenant.CurrentVersion, "Deployed company version")
        },
        new[]
        {
            new IM1ActionModel("Edit Company", Url.Action("EditTenant", new { organizationId = Model.Tenant.OrganizationId }), "primary"),
            new IM1ActionModel("Open Dashboard", Url.Action("Dashboard", "Business", new { organizationId = Model.Tenant.OrganizationId }), "secondary"),
            new IM1ActionModel("Company Admin", Url.Action("Administration", "Business", new { organizationId = Model.Tenant.OrganizationId }), "secondary"),
            new IM1ActionModel("Company Manager", Url.Action("Tenants"), "secondary")
        },
        Model.Tenant.HealthStatus);
}

@await Html.PartialAsync("IM1WorkspaceHero", hero)

<section class="im1-workspace-grid">
    <article class="im1-workspace-card span-4">
        <header class="im1-section-header"><div><h2>Owner Access</h2><p>Primary owner account state.</p></div></header>
        <p><strong>@(Model.OwnerName ?? "No owner found")</strong></p>
        <p>@(Model.OwnerEmail ?? "Owner email unavailable")</p>
        <p>@(Model.OwnerActivated ? "Activated" : "Pending activation")</p>
        <form asp-action="ResendOwnerInvitation" method="post">
            <input type="hidden" name="organizationId" value="@Model.Tenant.OrganizationId" />
            <button class="secondary-action" type="submit">Resend Owner Invitation</button>
        </form>
    </article>
    <article class="im1-workspace-card span-4">
        <header class="im1-section-header"><div><h2>Modules Enabled</h2><p>Available company capabilities.</p></div></header>
        <form asp-action="TenantModules" method="post" class="im1-settings-form">
            @Html.AntiForgeryToken()
            <input type="hidden" name="OrganizationId" value="@Model.Tenant.OrganizationId" />
            <div class="module-grid">
                @foreach (var option in Model.ModuleOptions)
                {
                    <label class="checkbox" title="@option.Description">
                        <input type="checkbox" name="EnabledModules" value="@option.Key" checked="@option.IsEnabled" />
                        @option.Label
                    </label>
                }
            </div>
            <footer class="im1-settings-actions">
                <button class="secondary-action" type="submit">Save Modules</button>
            </footer>
        </form>
    </article>
    <article class="im1-workspace-card span-4">
        <header class="im1-section-header"><div><h2>Provisioning History</h2><p>Recent lifecycle movement.</p></div></header>
        <ul class="event-list">@foreach (var item in Model.ProvisioningHistory) { <li>@item</li> }</ul>
    </article>
    <article class="im1-workspace-card span-6">
        <header class="im1-section-header"><div><h2>Audit History</h2><p>Platform changes against this company.</p></div></header>
        <ul class="event-list">@foreach (var item in Model.AuditHistory) { <li>@item</li> }</ul>
    </article>
    <article class="im1-workspace-card span-6">
        <header class="im1-section-header"><div><h2>Welcome Emails</h2><p>Outbound owner onboarding messages.</p></div></header>
        <ul class="event-list">@foreach (var item in Model.WelcomeEmails) { <li>@item</li> }</ul>
    </article>
</section>
