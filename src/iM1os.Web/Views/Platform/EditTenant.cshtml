@model iM1os.Application.Platform.UpdateTenantManagementRequest

@{
    ViewData["Title"] = "Edit Company";
    var hero = new IM1WorkspaceHeroModel(
        Model.OrganizationName,
        "Focused company edit",
        "Update lifecycle, billing, plan, health, and deployment metadata for this company.",
        new[]
        {
            new IM1WorkspaceStatModel("Status", Model.Status, "Lifecycle state"),
            new IM1WorkspaceStatModel("Plan", Model.SubscriptionPlan, "Subscription"),
            new IM1WorkspaceStatModel("Health", Model.HealthStatus, "Operational signal"),
            new IM1WorkspaceStatModel("Billing", Model.BillingStatus, "Payment state")
        },
        new[] { new IM1ActionModel("Cancel", Url.Action("Tenant", new { organizationId = Model.OrganizationId }), "secondary") },
        "Edit mode");
}

@await Html.PartialAsync("IM1WorkspaceHero", hero)

<section class="im1-workspace-card">
    <header class="im1-section-header"><div><h2>Company Metadata</h2><p>Change only the platform state needed for support, billing, or deployment work.</p></div></header>
    <form asp-action="EditTenant" method="post" class="form-grid">
        <input asp-for="OrganizationId" type="hidden" />
        <label>Company Name <input asp-for="OrganizationName" /></label>
        <label>Status
            <select asp-for="Status">
                <option>Trial</option>
                <option>Active</option>
                <option>Suspended</option>
                <option>Cancelled</option>
            </select>
        </label>
        <label>Subscription Plan
            <select asp-for="SubscriptionPlan">
                <option>Starter</option>
                <option>Professional</option>
                <option>Enterprise</option>
            </select>
        </label>
        <label>Current Version <input asp-for="CurrentVersion" /></label>
        <label>Health Status
            <select asp-for="HealthStatus">
                <option>Healthy</option>
                <option>Degraded</option>
                <option>Offline</option>
            </select>
        </label>
        <label>Billing Status
            <select asp-for="BillingStatus">
                <option>Trial</option>
                <option>Active</option>
                <option>Past Due</option>
                <option>Suspended</option>
                <option>Cancelled</option>
            </select>
        </label>
        <label>Provisioning Status
            <select asp-for="ProvisioningStatus">
                <option>Provisioned</option>
                <option>Provisioning</option>
                <option>Failed</option>
            </select>
        </label>
        <label>Trial Expires At UTC <input asp-for="TrialExpiresAtUtc" type="datetime-local" /></label>
        <button class="primary-action" type="submit">Save Company</button>
    </form>
</section>
