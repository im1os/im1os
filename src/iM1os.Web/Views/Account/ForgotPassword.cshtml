@model iM1os.Application.TenantIdentity.PasswordResetRequestDto

@{
    ViewData["Title"] = "Reset Password";
}

<section class="auth-panel">
    <p class="eyebrow">Password reset</p>
    <h1>Reset Password</h1>

    @if (ViewData["ResetRequested"] is true)
    {
        <p class="subtle">If the account exists, a reset link has been sent.</p>
    }

    <form asp-action="ForgotPassword" method="post" class="form-grid single">
        <label>Email <input asp-for="Email" autocomplete="username" /></label>
        <button class="primary-action" type="submit">Send Reset Link</button>
        <a class="secondary-action" asp-action="Login">Back To Login</a>
    </form>
</section>
