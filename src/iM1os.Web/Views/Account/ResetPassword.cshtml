@model iM1os.Application.TenantIdentity.CompletePasswordResetRequest

@{
    ViewData["Title"] = "Set New Password";
}

<section class="auth-panel">
    <p class="eyebrow">Password reset</p>
    <h1>Set New Password</h1>

    <form asp-action="ResetPassword" method="post" class="form-grid single">
        <input asp-for="Token" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="validation"></div>
        <label>Password <input asp-for="Password" type="password" autocomplete="new-password" /></label>
        <label>Confirm Password <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" /></label>
        <button class="primary-action" type="submit">Update Password</button>
    </form>
</section>
