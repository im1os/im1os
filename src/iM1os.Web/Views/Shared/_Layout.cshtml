@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isCustomerContext = User.FindFirst("auth_context")?.Value == "tenant";
    var isBusinessAuthPage = string.Equals(currentController, "Account", StringComparison.OrdinalIgnoreCase);
    var isBusinessShell = isCustomerContext || isBusinessAuthPage;
    var isMarketingSite = ViewData["MarketingSite"] is true;
    var showShellNavigation = isAuthenticated;
    var productName = isBusinessShell ? "iM1 Company" : "IM1 Platform";
    var brandController = isCustomerContext ? "Business" : isBusinessAuthPage ? "Account" : "Platform";
    var brandAction = isCustomerContext ? "Dashboard" : isBusinessAuthPage ? "Login" : "Dashboard";
    var navigationItems = isCustomerContext
        ? IM1ShellNavigation.AppShell.CompanyItems
        : IM1ShellNavigation.AppShell.PlatformItems;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @productName</title>
    <link rel="icon" type="image/png" sizes="32x32" href="~/images/favicon-32.png" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="16x16" href="~/images/favicon-16.png" asp-append-version="true" />
    <link rel="icon" type="image/png" sizes="512x512" href="~/images/site-icon.png" asp-append-version="true" />
    <link rel="apple-touch-icon" href="~/images/site-icon.png" asp-append-version="true" />
    <link rel="icon" href="~/favicon.ico" sizes="any" asp-append-version="true" />
    <link rel="shortcut icon" href="~/favicon.ico" asp-append-version="true" />
    @await RenderSectionAsync("Head", required: false)
    <link rel="stylesheet" href="~/css/im1-ui.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (isMarketingSite)
    {
        <header class="marketing-header" data-marketing-header>
            <a class="marketing-brand" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">
                    <img src="~/images/im1-logo.png" asp-append-version="true" alt="" />
                </span>
                <span>iM1 OS</span>
            </a>
            <nav class="marketing-nav" aria-label="Public navigation">
                <a href="/">Home</a>
                <a href="/#platform">Platform</a>
                <a href="/#products">Products</a>
                <a href="/#integrations">Integrations</a>
                <a href="/#about">About</a>
                <a href="/#contact">Contact</a>
            </nav>
            <div class="marketing-auth-actions">
                <a asp-controller="Platform" asp-action="Login">Platform Login</a>
                <a asp-controller="Account" asp-action="Login">Company Login</a>
                <a class="im1-button im1-button-primary" href="/#contact">Request Demo</a>
            </div>
        </header>
        <main class="marketing-main">
            @RenderBody()
        </main>
    }
    else
    {
        <div class="im1-app-shell @(showShellNavigation ? null : "im1-app-shell-no-sidebar")">
            <header class="im1-shell-header">
                <a class="im1-shell-brand" asp-controller="@brandController" asp-action="@brandAction" aria-label="@productName">
                    <span class="brand-mark">
                        <img src="~/images/im1-logo.png" asp-append-version="true" alt="" />
                    </span>
                    <span>@productName</span>
                </a>
                <div class="im1-shell-status">
                    <span>Healthy</span>
                </div>
                <div class="im1-shell-account">
                    @if (!isAuthenticated)
                    {
                        <a class="im1-shell-home-link" asp-controller="Home" asp-action="Index">Home</a>
                    }
                    else if (isCustomerContext)
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button class="link-button" type="submit">Logout</button>
                        </form>
                    }
                    else if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Platform" asp-action="Logout" method="post">
                            <button class="link-button" type="submit">Logout</button>
                        </form>
                    }
                </div>
            </header>
            @if (showShellNavigation)
            {
                <aside class="im1-sidebar">
                    @await Html.PartialAsync("IM1ShellNavigation", new IM1ShellNavigationModel(productName, navigationItems, currentController, currentAction))
                </aside>
            }
            <main class="im1-main-content">
                @RenderBody()
            </main>
            <section class="im1-notifications" aria-live="polite"></section>
        </div>
    }
    <script src="~/js/im1-ui.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
