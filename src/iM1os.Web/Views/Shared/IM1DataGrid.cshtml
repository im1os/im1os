@model IM1DataGridModel

<section class="im1-data-grid-shell" data-im1-data-grid data-page-size="@Model.PageSize">
    @if (Model.Toolbar is not null)
    {
        @await Html.PartialAsync("IM1Toolbar", Model.Toolbar)
    }
    <div class="im1-data-grid">
        <table>
            <thead>
                <tr>
                    @foreach (var column in Model.Columns)
                    {
                        <th data-column-key="@column.Key" data-sortable="@column.Sortable.ToString().ToLowerInvariant()" data-filterable="@column.Filterable.ToString().ToLowerInvariant()">
                            @if (column.Sortable)
                            {
                                <button class="im1-grid-sort" type="button">@column.Header</button>
                            }
                            else
                            {
                                @column.Header
                            }
                        </th>
                    }
                    @if (Model.RowActions?.Count > 0)
                    {
                        <th>Actions</th>
                    }
                </tr>
            </thead>
            <tbody>
                @if (Model.Rows.Count == 0)
                {
                    <tr>
                        <td colspan="@(Model.Columns.Count + (Model.RowActions?.Count > 0 ? 1 : 0))">@Model.EmptyText</td>
                    </tr>
                }
                else
                {
                    @foreach (var row in Model.Rows)
                    {
                        var rowUrl = row.TryGetValue("__url", out var urlValue) ? urlValue?.ToString() : null;
                        <tr data-im1-grid-row data-row-url="@rowUrl" tabindex="@(string.IsNullOrWhiteSpace(rowUrl) ? null : "0")">
                            @foreach (var column in Model.Columns)
                            {
                                <td>@(row.TryGetValue(column.Key, out var value) ? value : null)</td>
                            }
                            @if (Model.RowActions?.Count > 0)
                            {
                                <td>
                                    <div class="im1-row-actions">
                                        @foreach (var action in Model.RowActions)
                                        {
                                            <a class="im1-button im1-button-quiet" href="@action.Url">@action.Label</a>
                                        }
                                    </div>
                                </td>
                            }
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
    @if (Model.PageSize is not null)
    {
        <footer class="im1-data-grid-status">
            <span data-im1-grid-status>
                Page @(Model.PageNumber ?? 1) of @Math.Max(1, (int)Math.Ceiling((Model.TotalRows ?? Model.Rows.Count) / (double)Model.PageSize.Value)) - @(Model.TotalRows ?? Model.Rows.Count) rows
            </span>
            <div class="im1-data-grid-pager">
                <button class="im1-button im1-button-secondary" type="button" data-im1-grid-prev>Previous</button>
                <button class="im1-button im1-button-secondary" type="button" data-im1-grid-next>Next</button>
            </div>
        </footer>
    }
</section>
